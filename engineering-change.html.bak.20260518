                        <div>
                            <div style="color: #666; font-size: 12px; margin-bottom: 4px;">关联项目</div>
                            <div>智能手环 V2.0</div>
                        </div>
                        <div>
                            <div style="color: #666; font-size: 12px; margin-bottom: 4px;">关联BOM</div>
                            <div>智能手环主板 BOM v2.3</div>
                        </div>
                        <div>
                            <div style="color: #666; font-size: 12px; margin-bottom: 4px;">优先级</div>
                            <div><span class="priority-high">🔴 高优先级</span></div>
                        </div>
                        <div>
                            <div style="color: #666; font-size: 12px; margin-bottom: 4px;">变更类型</div>
                            <div>元器件替换</div>
                        </div>
                        <div>
                            <div style="color: #666; font-size: 12px; margin-bottom: 4px;">提交人</div>
                            <div>李明</div>
                        </div>
                        <div>
                            <div style="color: #666; font-size: 12px; margin-bottom: 4px;">提交时间</div>
                            <div>2024-10-25 14:30</div>
                        </div>
                    </div>
                </div>

                <!-- 变更描述 -->
                <div style="margin-bottom: 24px;">
                    <h4 style="margin-bottom: 12px;">📝 变更描述</h4>
                    <div style="background: #f8f9fa; padding: 16px; border-radius: 8px;">
                        <p><strong>变更内容：</strong>主控芯片从STM32F103替换为STM32F407</p>
                        <p style="margin-top: 12px;"><strong>变更原因：</strong>当前STM32F103性能不足以支持新增的AI算法处理需求，需要更高性能的MCU。</p>
                        <p style="margin-top: 12px;"><strong>预期效果：</strong>处理速度提升3倍，支持更复杂的算法，为未来功能扩展预留空间。</p>
                    </div>
                </div>

                <!-- 受影响物料 -->
                <div style="margin-bottom: 24px;">
                    <h4 style="margin-bottom: 12px;">🔧 受影响物料</h4>
                    <table style="width: 100%; font-size: 13px;">
                        <thead>
                            <tr style="background: #f8f9fa;">
                                <th style="padding: 8px;">位号</th>
                                <th style="padding: 8px;">原物料</th>
                                <th style="padding: 8px;">新物料</th>
                                <th style="padding: 8px;">数量</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="padding: 8px;">U1</td>
                                <td style="padding: 8px;">STM32F103C8T6</td>
                                <td style="padding: 8px;">STM32F407VGT6</td>
                                <td style="padding: 8px;">1</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px;">C20-C23</td>
                                <td style="padding: 8px;">100nF (新增)</td>
                                <td style="padding: 8px;">100nF 0402</td>
                                <td style="padding: 8px;">4</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- 审批流程 -->
                <div style="margin-bottom: 24px;">
                    <h4 style="margin-bottom: 12px;">✅ 审批流程</h4>
                    <div class="approval-flow">
                        <div class="approval-step completed">
                            <div class="approval-circle">✓</div>
                            <div class="approval-label">提交人</div>
                            <div style="font-size: 12px; margin-top: 4px;">李明</div>
                        </div>
                        <div class="approval-step active">
                            <div class="approval-circle">2</div>
                            <div class="approval-label">技术评审</div>
                            <div style="font-size: 12px; margin-top: 4px;">王芳</div>
                        </div>
                        <div class="approval-step">
                            <div class="approval-circle">3</div>
                            <div class="approval-label">项目经理</div>
                            <div style="font-size: 12px; margin-top: 4px;">赵强</div>
                        </div>
                        <div class="approval-step">
                            <div class="approval-circle">4</div>
                            <div class="approval-label">最终批准</div>
                            <div style="font-size: 12px; margin-top: 4px;">总监</div>
                        </div>
                    </div>
                </div>

                <!-- 审批意见 -->
                <div style="margin-bottom: 24px;">
                    <h4 style="margin-bottom: 12px;">💬 审批意见</h4>
                    <div style="background: #e8f5e9; padding: 12px; border-radius: 8px; margin-bottom: 8px; border-left: 4px solid #00890b;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                            <strong>李明 (提交人)</strong>
                            <span style="font-size: 12px; color: #666;">2024-10-25 14:30</span>
                        </div>
                        <div>提交变更请求，请审批。</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeChangeDetailModal()">关闭</button>
                <button class="btn btn-primary" onclick="approveChange()">批准变更</button>
            </div>
        </div>
    </div>

    <!-- 影响分析模态框 -->
    <div id="impactAnalysisModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">📊 变更影响分析 - ECR-2024-001</h3>
                <button class="modal-close" onclick="closeImpactAnalysisModal()">×</button>
            </div>
            <div class="modal-body">
                <div class="impact-card">
                    <div class="impact-header">
                        <span>📊</span>
                        <span>影响的项目 (1个)</span>
                    </div>
                    <ul class="impact-list">
                        <li class="impact-item">
                            <strong>智能手环 V2.0</strong>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                项目状态: 进行中 | 项目经理: 李明
                            </div>
                        </li>
                    </ul>
                </div>

                <div class="impact-card">
                    <div class="impact-header">
                        <span>📝</span>
                        <span>影响的BOM (2个)</span>
                    </div>
                    <ul class="impact-list">
                        <li class="impact-item">
                            <strong>智能手环主板 BOM v2.3</strong>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                当前版本 → 需升级到 v2.4 | 物料数: 156 → 160
                            </div>
                        </li>
                        <li class="impact-item">
                            <strong>智能手环总装 BOM v1.8</strong>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                当前版本 → 需升级到 v1.9 | 物料数: 23 (无变化)
                            </div>
                        </li>
                    </ul>
                </div>

                <div class="impact-card">
                    <div class="impact-header">
                        <span>🛒</span>
                        <span>影响的采购订单 (3个)</span>
                    </div>
                    <ul class="impact-list">
                        <li class="impact-item">
                            <strong>PO-2024-089</strong>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                包含STM32F103C8T6 x 500 | 状态: 待发货 | 建议: 取消或修改订单
                            </div>
                        </li>
                        <li class="impact-item">
                            <strong>PO-2024-092</strong>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                包含配套外围电路 | 状态: 已下单 | 建议: 补充新增物料订单
                            </div>
                        </li>
                        <li class="impact-item">
                            <strong>PO-2024-095</strong>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                PCB订单 | 状态: 生产中 | 建议: 可能需要重新设计PCB
                            </div>
                        </li>
                    </ul>
                </div>

                <div class="impact-card">
                    <div class="impact-header">
                        <span>📦</span>
                        <span>库存影响</span>
                    </div>
                    <ul class="impact-list">
                        <li class="impact-item">
                            <strong>STM32F103C8T6</strong>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                当前库存: 320 PCS | 建议: 转移到其他项目或退货
                            </div>
                        </li>
                        <li class="impact-item">
                            <strong>STM32F407VGT6</strong>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                当前库存: 0 PCS | 建议: 立即采购 500 PCS
                            </div>
                        </li>
                    </ul>
                </div>

                <div class="impact-card" style="border-color: #f39c12; background: #fff9e6;">
                    <div class="impact-header">
                        <span>⚠️</span>
                        <span>成本影响分析</span>
                    </div>
                    <ul class="impact-list">
                        <li class="impact-item">
                            <strong>物料成本增加</strong>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                STM32F407 单价 ¥45.8 vs STM32F103 单价 ¥12.5 | 增加: ¥33.3/PCS
                            </div>
                        </li>
                        <li class="impact-item">
                            <strong>预计总成本影响</strong>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                500 PCS产量 | 物料成本增加: ¥16,650 | PCB改板费用: ¥8,000 | 合计: ¥24,650
                            </div>
                        </li>
                    </ul>
                </div>

                <div class="impact-card" style="border-color: #3498db; background: #e3f2fd;">
                    <div class="impact-header">
                        <span>⏱️</span>
                        <span>时间影响</span>
                    </div>
                    <ul class="impact-list">
                        <li class="impact-item">
                            <strong>预计延期时间</strong>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                PCB改版: 7天 | 物料采购: 15天 | 测试验证: 10天 | 合计: 约32天
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeImpactAnalysisModal()">关闭</button>
                <button class="btn btn-primary" onclick="exportImpactReport()">导出分析报告</button>
            </div>
        </div>
    </div>

    <script>
        // 标签页切换
        function switchTab(tab) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
            console.log('切换到:', tab);
        }

        // 新建变更请求
        function openNewChangeModal() {
            document.getElementById('newChangeModal').classList.add('active');
        }

        function closeNewChangeModal() {
            document.getElementById('newChangeModal').classList.remove('active');
        }

        function submitNewChange() {
            alert('✅ 变更请求已提交！\n\n系统将自动进行影响分析，并通知相关审批人。');
            closeNewChangeModal();
        }

        // 变更详情
        function openChangeDetail(id) {
            document.getElementById('changeDetailModal').classList.add('active');
        }

        function closeChangeDetailModal() {
            document.getElementById('changeDetailModal').classList.remove('active');
        }

        function approveChange() {
            if (confirm('确认批准此变更请求吗？\n\n批准后将自动更新相关BOM版本。')) {
                alert('✅ 变更已批准！\n\n系统正在自动更新BOM版本...\n• 智能手环主板 BOM: v2.3 → v2.4\n• 智能手环总装 BOM: v1.8 → v1.9');
                closeChangeDetailModal();
            }
        }

        // 影响分析
        function openImpactAnalysis(id) {
            document.getElementById('impactAnalysisModal').classList.add('active');
        }

        function closeImpactAnalysisModal() {
            document.getElementById('impactAnalysisModal').classList.remove('active');
        }

        function exportImpactReport() {
            alert('📊 正在生成影响分析报告...\n\n报告将包含：\n• 受影响项目清单\n• BOM版本变更清单\n• 采购订单影响\n• 成本和时间分析');
        }

        // 实施变更
        function implementChange(id) {
            if (confirm('确认实施此变更吗？\n\n实施后将：\n1. 自动更新所有相关BOM到新版本\n2. 更新库存状态\n3. 通知相关采购和生产部门')) {
                alert('✅ 变更正在实施...\n\n• BOM版本已更新\n• 库存状态已同步\n• 已通知采购和生产部门');
            }
        }

        // 点击模态框背景关闭
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', function(e) {
                if (e.target === this) {
                    this.classList.remove('active');
                }
            });
        });
    </script>
</body>
</html>
