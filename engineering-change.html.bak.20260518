                <a href="category-management.html" class="nav-item">
                    <span class="nav-icon">🏷️</span>
                    <span>分类管理</span>
                </a>
                <a href="numbering-rules.html" class="nav-item">
                    <span class="nav-icon">🔢</span>
                    <span>编号规则</span>
                </a>
                <a href="organization-settings.html" class="nav-item">
                    <span class="nav-icon">🏛️</span>
                    <span>组织管理</span>
                </a>
                <a href="settings.html" class="nav-item">
                    <span class="nav-icon">⚙️</span>
                    <span>系统设置</span>
                </a>
            </div>

        </div>

        <!-- 主内容区 -->
        <div class="main-content">
            <!-- 页面头部 -->
            <div class="page-header">
                <h1 class="page-title">🔄 工程变更管理 (ECO/ECR)</h1>
                <p class="page-subtitle">管理工程变更请求、审批流程及BOM版本控制</p>
            </div>

            <!-- 统计卡片 -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-value">28</div>
                    <div class="stat-label">总变更请求</div>
                </div>
                <div class="stat-card warning">
                    <div class="stat-value">7</div>
                    <div class="stat-label">待审批</div>
                </div>
                <div class="stat-card info">
                    <div class="stat-value">12</div>
                    <div class="stat-label">审批中</div>
                </div>
                <div class="stat-card danger">
                    <div class="stat-value">3</div>
                    <div class="stat-label">待实施</div>
                </div>
            </div>

            <!-- 标签页和表格 -->
            <div class="tabs">
                <button class="tab active" onclick="switchTab('all')">全部变更</button>
                <button class="tab" onclick="switchTab('pending')">待审批</button>
                <button class="tab" onclick="switchTab('reviewing')">审批中</button>
                <button class="tab" onclick="switchTab('approved')">已批准</button>
                <button class="tab" onclick="switchTab('implemented')">已实施</button>
            </div>

            <div class="table-container">
                <!-- 工具栏 -->
                <div class="toolbar">
                    <div class="toolbar-left">
                        <input type="text" class="search-input" placeholder="搜索变更编号、描述...">
                        <select class="filter-select">
                            <option>所有优先级</option>
                            <option>高优先级</option>
                            <option>中优先级</option>
                            <option>低优先级</option>
                        </select>
                        <select class="filter-select">
                            <option>所有项目</option>
                            <option>智能手环 V2.0</option>
                            <option>无线充电器</option>
                            <option>智能音箱</option>
                        </select>
                    </div>
                    <button class="btn btn-primary" onclick="openNewChangeModal()">
                        ➕ 新建变更请求
                    </button>
                </div>

                <!-- 变更列表表格 -->
                <table>
                    <thead>
                        <tr>
                            <th>变更编号</th>
                            <th>变更描述</th>
                            <th>关联项目</th>
                            <th>优先级</th>
                            <th>提交人</th>
                            <th>提交日期</th>
                            <th>状态</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr onclick="openChangeDetail('ECR-2024-001')">
                            <td><strong>ECR-2024-001</strong></td>
                            <td>主控芯片从STM32F103替换为STM32F407</td>
                            <td>智能手环 V2.0</td>
                            <td><span class="priority-high">🔴 高</span></td>
                            <td>李明</td>
                            <td>2024-10-25</td>
                            <td><span class="status-badge status-reviewing">审批中</span></td>
                            <td>
                                <button class="btn-icon" onclick="event.stopPropagation(); openChangeDetail('ECR-2024-001')" title="查看详情">👁️</button>
                                <button class="btn-icon" onclick="event.stopPropagation(); openImpactAnalysis('ECR-2024-001')" title="影响分析">📊</button>
                            </td>
                        </tr>
                        <tr onclick="openChangeDetail('ECR-2024-002')">
                            <td><strong>ECR-2024-002</strong></td>
                            <td>电容C15容值从10uF改为22uF</td>
                            <td>无线充电器</td>
                            <td><span class="priority-medium">🟡 中</span></td>
                            <td>王芳</td>
                            <td>2024-10-23</td>
                            <td><span class="status-badge status-pending">待审批</span></td>
                            <td>
                                <button class="btn-icon" onclick="event.stopPropagation(); openChangeDetail('ECR-2024-002')" title="查看详情">👁️</button>
                                <button class="btn-icon" onclick="event.stopPropagation(); openImpactAnalysis('ECR-2024-002')" title="影响分析">📊</button>
                            </td>
                        </tr>
                        <tr onclick="openChangeDetail('ECR-2024-003')">
                            <td><strong>ECR-2024-003</strong></td>
                            <td>增加USB-C接口保护电路</td>
                            <td>智能音箱</td>
                            <td><span class="priority-high">🔴 高</span></td>
                            <td>赵强</td>
                            <td>2024-10-20</td>
                            <td><span class="status-badge status-approved">已批准</span></td>
                            <td>
                                <button class="btn-icon" onclick="event.stopPropagation(); openChangeDetail('ECR-2024-003')" title="查看详情">👁️</button>
                                <button class="btn-icon" onclick="event.stopPropagation(); implementChange('ECR-2024-003')" title="实施变更">✅</button>
                            </td>
                        </tr>
                        <tr onclick="openChangeDetail('ECR-2024-004')">
                            <td><strong>ECR-2024-004</strong></td>
                            <td>PCB板厚从1.6mm改为1.2mm</td>
                            <td>智能手环 V2.0</td>
                            <td><span class="priority-low">🔵 低</span></td>
                            <td>孙丽</td>
                            <td>2024-10-18</td>
                            <td><span class="status-badge status-rejected">已拒绝</span></td>
                            <td>
                                <button class="btn-icon" onclick="event.stopPropagation(); openChangeDetail('ECR-2024-004')" title="查看详情">👁️</button>
                            </td>
                        </tr>
                        <tr onclick="openChangeDetail('ECR-2024-005')">
                            <td><strong>ECR-2024-005</strong></td>
                            <td>WiFi模块从ESP8266升级到ESP32</td>
                            <td>智能音箱</td>
                            <td><span class="priority-medium">🟡 中</span></td>
                            <td>张三</td>
                            <td>2024-10-15</td>
                            <td><span class="status-badge status-implemented">已实施</span></td>
                            <td>
                                <button class="btn-icon" onclick="event.stopPropagation(); openChangeDetail('ECR-2024-005')" title="查看详情">👁️</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 新建变更请求模态框 -->
    <div id="newChangeModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">新建工程变更请求 (ECR)</h3>
                <button class="modal-close" onclick="closeNewChangeModal()">×</button>
            </div>
            <div class="modal-body">
                <form id="newChangeForm">
                    <div class="form-group">
                        <label class="form-label required">变更标题</label>
                        <input type="text" class="form-input" placeholder="简要描述变更内容" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label required">关联项目</label>
                        <select class="form-input" required>
                            <option value="">请选择项目</option>
                            <option>智能手环 V2.0</option>
                            <option>无线充电器优化</option>
                            <option>智能音箱 Mini版</option>
                            <option>运动相机 4K版</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label required">关联BOM</label>
                        <select class="form-input" required>
                            <option value="">请选择BOM</option>
                            <option>智能手环主板 BOM v2.3</option>
                            <option>充电模块 BOM v1.5</option>
                            <option>音箱主控板 BOM v1.2</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label required">优先级</label>
                        <select class="form-input" required>
                            <option value="">请选择优先级</option>
                            <option value="high">🔴 高 - 影响产品功能/安全</option>
                            <option value="medium">🟡 中 - 影响性能优化</option>
                            <option value="low">🔵 低 - 一般性改进</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label required">变更类型</label>
                        <select class="form-input" required>
                            <option value="">请选择类型</option>
                            <option>元器件替换</option>
                            <option>参数调整</option>
                            <option>新增元器件</option>
                            <option>删除元器件</option>
                            <option>PCB设计变更</option>
                            <option>其他</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label required">变更原因</label>
                        <textarea class="form-input" placeholder="详细说明为什么需要进行此变更..." required></textarea>
                    </div>

                    <div class="form-group">
                        <label class="form-label required">变更详细描述</label>
                        <textarea class="form-input" placeholder="描述具体的变更内容，包括：&#10;- 哪些物料需要变更&#10;- 变更前后的对比&#10;- 技术参数变化&#10;- 相关电路/结构调整" required></textarea>
                    </div>

                    <div class="form-group">
                        <label class="form-label">受影响物料清单</label>
                        <textarea class="form-input" placeholder="列出所有受影响的物料编号和描述&#10;例如：&#10;- C15: 10uF → 22uF&#10;- U3: STM32F103 → STM32F407"></textarea>
                    </div>

                    <div class="form-group">
                        <label class="form-label">预期效果</label>
                        <textarea class="form-input" placeholder="说明变更后期望达到的效果..."></textarea>
                    </div>

                    <div class="form-group">
                        <label class="form-label">附件</label>
                        <input type="file" class="form-input" multiple>
                        <small style="color: #666; font-size: 12px;">支持上传对比图、原理图、测试报告等文件</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeNewChangeModal()">取消</button>
                <button class="btn btn-primary" onclick="submitNewChange()">提交变更请求</button>
            </div>
        </div>
    </div>

    <!-- 变更详情模态框 -->
    <div id="changeDetailModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">变更详情 - ECR-2024-001</h3>
                <button class="modal-close" onclick="closeChangeDetailModal()">×</button>
            </div>
            <div class="modal-body">
                <!-- 基本信息 -->
                <div style="margin-bottom: 24px;">
                    <h4 style="margin-bottom: 12px;">📋 基本信息</h4>
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
                        <div>
                            <div style="color: #666; font-size: 12px; margin-bottom: 4px;">变更编号</div>
