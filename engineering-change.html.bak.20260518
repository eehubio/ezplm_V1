<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EZPLM - 工程变更管理</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f4f4f4;
            color: #3d4647;
        }

        /* 顶部导航栏 */
        .top-bar {
            background: white;
            height: 80px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .logo {
            font-size: 28px;
            font-weight: 800;
            color: #00890b;
            cursor: pointer;
        }
        .top-nav-links {
            display: flex;
            align-items: center;
            gap: 24px;
        }
        .top-nav-links a {
            color: #3d4647;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: color 0.2s;
        }
        .top-nav-links a:hover {
            color: #00890b;
        }
        .top-bar-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .notification-bell {
            font-size: 20px;
            color: #3d4647;
            cursor: pointer;
            position: relative;
        }
        .notification-dot {
            position: absolute;
            top: -4px;
            right: -4px;
            width: 8px;
            height: 8px;
            background: #ff4d4f;
            border-radius: 50%;
        }
        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #00890b, #00b96b);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            cursor: pointer;
        }

        /* 布局 */
        .layout {
            display: flex;
            min-height: calc(100vh - 80px);
        }

        /* 侧边栏 */
        .sidebar {
            width: 260px;
            background: white;
            box-shadow: 2px 0 8px rgba(0,0,0,0.05);
            padding: 24px 0;
            flex-shrink: 0;
        }
        .nav-section {
            margin-bottom: 24px;
        }
        .nav-section-title {
            padding: 8px 24px;
            font-size: 12px;
            font-weight: 600;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 24px;
            color: #3d4647;
            text-decoration: none;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }
        .nav-item:hover {
            background: #f0f9f0;
            border-left-color: #00890b;
        }
        .nav-item.active {
            background: #e8f5e9;
            border-left-color: #00890b;
            color: #00890b;
            font-weight: 600;
        }
        .nav-icon {
            font-size: 18px;
        }

        /* 主内容区 */
        .main-content {
            flex: 1;
            padding: 24px;
            overflow-y: auto;
        }

        /* 页面头部 */
        .page-header {
            background: white;
            padding: 24px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            margin-bottom: 24px;
        }
        .page-title {
            font-size: 24px;
            font-weight: 600;
            color: #1a1a1a;
            margin-bottom: 8px;
        }
        .page-subtitle {
            font-size: 14px;
            color: #666;
        }

        /* 统计卡片 */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }
        .stat-card {
            background: white;
            padding: 24px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            border-left: 4px solid #00890b;
        }
        .stat-card.warning { border-left-color: #f39c12; }
        .stat-card.danger { border-left-color: #e74c3c; }
        .stat-card.info { border-left-color: #3498db; }
        .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 8px;
        }
        .stat-label {
            font-size: 14px;
            color: #666;
        }

        /* 标签页 */
        .tabs {
            display: flex;
            gap: 8px;
            background: white;
            padding: 16px 24px 0;
            border-radius: 8px 8px 0 0;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        .tab {
            padding: 12px 24px;
            border: none;
            background: transparent;
            color: #666;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            transition: all 0.2s;
        }
        .tab:hover {
            color: #00890b;
        }
        .tab.active {
            color: #00890b;
            border-bottom-color: #00890b;
        }

        /* 表格 */
        .table-container {
            background: white;
            border-radius: 0 0 8px 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            overflow: hidden;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        thead {
            background: #f8f9fa;
        }
        th {
            padding: 16px;
            text-align: left;
            font-weight: 600;
            font-size: 13px;
            color: #3d4647;
            border-bottom: 2px solid #e0e0e0;
        }
        td {
            padding: 16px;
            border-bottom: 1px solid #f0f0f0;
            font-size: 14px;
        }
        tr:hover {
            background: #f9f9f9;
        }

        /* 状态标签 */
        .status-badge {
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
            display: inline-block;
        }
        .status-pending {
            background: #fff3e0;
            color: #e65100;
        }
        .status-reviewing {
            background: #e3f2fd;
            color: #1976d2;
        }
        .status-approved {
            background: #e8f5e9;
            color: #00890b;
        }
        .status-rejected {
            background: #ffebee;
            color: #c62828;
        }
        .status-implemented {
            background: #f3e5f5;
            color: #7b1fa2;
        }

        /* 优先级标签 */
        .priority-high {
            color: #e74c3c;
            font-weight: 600;
        }
        .priority-medium {
            color: #f39c12;
            font-weight: 600;
        }
        .priority-low {
            color: #3498db;
            font-weight: 600;
        }

        /* 按钮 */
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-primary {
            background: #00890b;
            color: white;
        }
        .btn-primary:hover {
            background: #00a00d;
        }
        .btn-secondary {
            background: #e0e0e0;
            color: #3d4647;
        }
        .btn-secondary:hover {
            background: #d0d0d0;
        }
        .btn-icon {
            padding: 8px 12px;
            font-size: 16px;
            border: none;
            background: transparent;
            cursor: pointer;
            border-radius: 4px;
            transition: all 0.2s;
        }
        .btn-icon:hover {
            background: #f0f0f0;
        }

        /* 模态框 */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }
        .modal.active {
            display: flex;
        }
        .modal-content {
            background: white;
            border-radius: 8px;
            width: 90%;
            max-width: 900px;
            max-height: 90vh;
            overflow-y: auto;
        }
        .modal-header {
            padding: 20px 24px;
            border-bottom: 1px solid #e0e0e0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .modal-title {
            font-size: 20px;
            font-weight: 600;
        }
        .modal-close {
            font-size: 28px;
            border: none;
            background: none;
            cursor: pointer;
            color: #999;
            line-height: 1;
        }
        .modal-body {
            padding: 24px;
        }
        .modal-footer {
            padding: 16px 24px;
            border-top: 1px solid #e0e0e0;
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }

        /* 表单 */
        .form-group {
            margin-bottom: 20px;
        }
        .form-label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 14px;
            color: #3d4647;
        }
        .form-label.required::after {
            content: '*';
            color: #e74c3c;
            margin-left: 4px;
        }
        .form-input {
            width: 100%;
            padding: 10px 12px;
            border: 2px solid #e0e0e0;
            border-radius: 6px;
            font-size: 14px;
            transition: all 0.2s;
        }
        .form-input:focus {
            outline: none;
            border-color: #00890b;
        }
        textarea.form-input {
            resize: vertical;
            min-height: 100px;
        }
        select.form-input {
            cursor: pointer;
        }

        /* 影响分析卡片 */
        .impact-card {
            background: #f8f9fa;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 16px;
        }
        .impact-header {
            font-weight: 600;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .impact-list {
            list-style: none;
        }
        .impact-item {
            padding: 8px 0;
            border-bottom: 1px solid #e0e0e0;
        }
        .impact-item:last-child {
            border-bottom: none;
        }

        /* 审批流程 */
        .approval-flow {
            display: flex;
            align-items: center;
            gap: 16px;
            margin: 24px 0;
        }
        .approval-step {
            flex: 1;
            text-align: center;
            position: relative;
        }
        .approval-step::after {
            content: '';
            position: absolute;
            top: 20px;
            left: 50%;
            width: 100%;
            height: 2px;
            background: #e0e0e0;
            z-index: -1;
        }
        .approval-step:last-child::after {
            display: none;
        }
        .approval-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #e0e0e0;
            margin: 0 auto 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }
        .approval-step.completed .approval-circle {
            background: #00890b;
            color: white;
        }
        .approval-step.active .approval-circle {
            background: #3498db;
            color: white;
        }
        .approval-step.rejected .approval-circle {
            background: #e74c3c;
            color: white;
        }
        .approval-label {
            font-size: 12px;
            color: #666;
        }

        /* 工具栏 */
        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 24px;
            background: white;
            border-bottom: 1px solid #e0e0e0;
        }
        .toolbar-left {
            display: flex;
            gap: 12px;
            align-items: center;
        }
        .search-input {
            padding: 8px 12px;
            border: 2px solid #e0e0e0;
            border-radius: 6px;
            font-size: 14px;
            width: 300px;
        }
        .filter-select {
            padding: 8px 12px;
            border: 2px solid #e0e0e0;
            border-radius: 6px;
            font-size: 14px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <!-- 顶部导航栏 -->
    <div class="top-bar">
        <div class="logo" onclick="location.href='index.html'">EZPLM</div>
        <div class="top-bar-right">
            <div class="top-nav-links">
                <a href="cloud-search.html">🌐 云端元器件库</a>
                <a href="reference-designs.html">📚 参考设计库</a>
