                <a href="pcb-editor-styled.html">📐 PCB预布局</a>
            </div>
            <button style="background: none; border: none; cursor: pointer; font-size: 20px; position: relative;" onclick="location.href='notification-center.html'" title="消息">
                🔔
                <span style="position: absolute; top: -4px; right: -4px; background: #ff6b6b; color: white; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 10px;">15</span>
            </button>
            <div style="width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, #00890b 0%, #00b30e 100%); color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; cursor: pointer;" onclick="location.href='profile.html'" title="账号">用</div>
        </div>
    </div>

    <div class="layout">
                <!-- 侧边栏 -->
        <div class="sidebar">
            <div class="nav-section">
                <div class="nav-section-title">工作台</div>
                <a href="dashboard-pro.html" class="nav-item">
                    <span class="nav-icon">📊</span>
                    <span>看板</span>
                </a>
                <a href="approval-center.html" class="nav-item">
                    <span class="nav-icon">✅</span>
                    <span>审批</span>
                    <span style="background: #4dabf7; color: white; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 10px; margin-left: auto;">8</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">项目</div>
