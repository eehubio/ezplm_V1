    <script>
        // 价格对比工具相关函数
        function showCostByProject() {
            alert('按项目展示成本分析');
        }
        function showCostBySupplier() {
            alert('按供应商展示成本分析');
        }
        function showCostTrend() {
            alert('展示成本趋势分析');
        }

        // 批量导入工具相关函数
        function handleFileUpload(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                alert(`文件上传成功！\n\n文件名：${file.name}\n大小：${(file.size / 1024).toFixed(2)} KB\n\n正在解析文件内容...`);
                setTimeout(() => {
                    alert('✅ 文件解析完成！\n\n识别到 25 条物料记录\n准备导入采购系统...');
                    closeToolModal('batchImportModal');
                }, 1500);
            }
        }

        function downloadTemplate() {
            alert('📥 正在下载导入模板...\n\n文件名：采购物料导入模板.xlsx');
        }

        // 库存预警工具相关函数
        function quickProcurement(material) {
            alert(`快速采购 ${material}\n\n已自动填充物料信息\n请确认采购数量和供应商`);
            closeToolModal('inventoryAlertModal');
            setTimeout(() => {
                openProcurementModal();
            }, 500);
        }

        // 报表生成工具相关函数
        function generateReport() {
            const reportType = document.getElementById('reportType').value;
            const format = document.querySelector('input[name="format"]:checked').value;
            alert(`正在生成报表...\n\n类型：${reportType}\n格式：${format}\n\n预计需要 10-15 秒`);
            setTimeout(() => {
                alert('✅ 报表生成成功！\n\n文件已保存到下载目录');
                closeToolModal('reportGenerationModal');
            }, 2000);
        }

        // 从价格对比创建采购单相关函数
        function createPOFromComparison() {
            closeToolModal('priceComparisonModal');
            setTimeout(() => {
                openModal('createPOFromComparisonModal');
                // 设置默认交期为两周后
                const expectedDate = new Date();
                expectedDate.setDate(expectedDate.getDate() + 14);
                document.getElementById('expectedDateFromComparison').value = expectedDate.toISOString().split('T')[0];
            }, 300);
        }

        async function submitPOFromComparison() {
            // 权限检查
            if (typeof PermissionControl !== 'undefined') {
                if (!PermissionControl.hasPermission('procurement', 'create')) {
                    PermissionControl.showPermissionError('创建采购单');
                    return;
                }
            }

            const poName = document.getElementById('poNameFromComparison').value;
            const project = document.getElementById('projectFromComparison').value;
            const quantity = document.getElementById('quantityFromComparison').value;
            const expectedDate = document.getElementById('expectedDateFromComparison').value;

            if (!poName || !project || !quantity || !expectedDate) {
                alert('❌ 请填写所有必填项');
                return;
            }

            const estimatedPrice = 850;  // 从价格对比获取的预计总价

            // 预算检查
            const budgetCheck = checkBudgetOverrun(project, estimatedPrice);
            if (budgetCheck.warning || budgetCheck.overrun) {
                const confirmed = await showBudgetWarning(budgetCheck);

                if (!confirmed) {
                    // 用户取消采购
                    return;
                } else if (confirmed === '申请追加预算') {
                    // 用户选择申请预算追加
                    alert('💼 预算追加申请\n\n系统将创建预算追加申请单，并发送给项目经理审批。\n\n您可以在"审批中心"查看申请进度。');
                    // 实际应跳转到预算申请页面或创建申请单
                    return;
                }
                // 用户确认继续，记录预算预警
                if (typeof AuditLog !== 'undefined') {
                    AuditLog.logWarning('procurement_budget', project,
                        `采购单创建时预算${budgetCheck.overrun ? '超支' : '预警'}：¥${estimatedPrice}，剩余预算：¥${budgetCheck.remainingBudget}`
                    );
                }
            }

            // 生成采购单数据
            const poId = 'PO-' + Date.now();
            const poData = {
                id: poId,
                name: poName,
                project: project,
                quantity: quantity,
                expectedDate: expectedDate,
                estimatedPrice: estimatedPrice,
                status: 'pending_approval',
                budgetWarning: budgetCheck.warning || budgetCheck.overrun,
                createdAt: new Date().toISOString()
            };

            // 记录审计日志
            if (typeof AuditLog !== 'undefined') {
                AuditLog.logCreate('procurement', poId, poData, '从价格对比创建采购单');
            }

            alert(`✅ 采购单创建成功！\n\n采购单编号：${poId}\n采购单名称：${poName}\n采购数量：${quantity}个\n预计总价：¥${estimatedPrice}\n${budgetCheck.warning ? '\n⚠️ 注意：本次采购存在预算预警' : ''}\n\n采购单已提交审批流程`);
            closeModal('createPOFromComparisonModal');
        }

        // 创建采购计划相关函数
        function createProcurementPlan() {
            closeToolModal('demandForecastModal');
            setTimeout(() => {
                openModal('createProcurementPlanModal');
                // 设置默认日期：开始日期为今天，结束日期为3个月后
                const startDate = new Date();
                const endDate = new Date();
                endDate.setMonth(endDate.getMonth() + 3);
                document.getElementById('planStartDate').value = startDate.toISOString().split('T')[0];
                document.getElementById('planEndDate').value = endDate.toISOString().split('T')[0];
            }, 300);
        }

        function toggleAllPlanItems(checkbox) {
            const checkboxes = document.querySelectorAll('.plan-item-check');
            checkboxes.forEach(cb => {
                cb.checked = checkbox.checked;
            });
        }

        function savePlanDraft() {
            const planName = document.getElementById('planName').value;
            alert(`💾 采购计划草稿已保存\n\n计划名称：${planName}\n\n您可以稍后继续编辑`);
        }

        // ========== 新增：附件上传功能 ==========
        let uploadedFiles = [];

        function handleFileSelect(event) {
            const files = event.target.files;
            if (!files.length) return;

            // 验证文件
            for (let file of files) {
                // 文件大小检查（10MB限制）
                if (file.size > 10 * 1024 * 1024) {
                    alert(`❌ 文件 "${file.name}" 超过10MB限制，请选择较小的文件`);
                    continue;
                }

                // 添加到上传列表
                uploadedFiles.push({
                    name: file.name,
                    size: file.size,
                    type: file.type,
                    file: file
                });
            }

            // 更新文件列表显示
            updateFileList();
        }

        function updateFileList() {
            const fileListDiv = document.getElementById('fileList');
            if (uploadedFiles.length === 0) {
                fileListDiv.innerHTML = '';
                return;
            }

            const listHTML = uploadedFiles.map((file, index) => {
                const sizeKB = (file.size / 1024).toFixed(1);
                const fileIcon = getFileIcon(file.name);
                return `
                    <div style="display: flex; align-items: center; padding: 12px; background: white; border: 1px solid #e0e0e0; border-radius: 6px; margin-bottom: 8px;">
                        <div style="font-size: 24px; margin-right: 12px;">${fileIcon}</div>
                        <div style="flex: 1;">
                            <div style="font-weight: 600; font-size: 14px; color: #3d4647;">${file.name}</div>
                            <div style="font-size: 12px; color: #999;">${sizeKB} KB</div>
                        </div>
                        <button onclick="removeFile(${index})" style="background: #ff4d4f; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 12px;">移除</button>
                    </div>
                `;
            }).join('');

            fileListDiv.innerHTML = `
                <div style="margin-bottom: 8px; font-size: 13px; color: #666; font-weight: 600;">
                    已选择 ${uploadedFiles.length} 个文件
                </div>
                ${listHTML}
            `;
        }

        function getFileIcon(filename) {
            const ext = filename.split('.').pop().toLowerCase();
            const iconMap = {
                'pdf': '📕',
                'doc': '📘',
                'docx': '📘',
                'xls': '📗',
                'xlsx': '📗',
                'png': '🖼️',
                'jpg': '🖼️',
                'jpeg': '🖼️'
            };
            return iconMap[ext] || '📄';
        }

        function removeFile(index) {
            uploadedFiles.splice(index, 1);
            updateFileList();
        }

        function submitProcurementPlan() {
            // 权限检查
            if (typeof PermissionControl !== 'undefined') {
                if (!PermissionControl.hasPermission('procurement', 'create')) {
                    PermissionControl.showPermissionError('创建采购计划');
                    return;
                }
            }

            const planName = document.getElementById('planName').value;
            const startDate = document.getElementById('planStartDate').value;
            const endDate = document.getElementById('planEndDate').value;
            const strategy = document.getElementById('procurementStrategy').value;

            if (!planName || !startDate || !endDate) {
                alert('❌ 请填写所有必填项');
                return;
            }

            const selectedItems = document.querySelectorAll('.plan-item-check:checked').length;

            // 生成采购计划数据
            const planId = 'PLAN-' + Date.now();
            const planData = {
                id: planId,
                name: planName,
                startDate: startDate,
                endDate: endDate,
                strategy: strategy,
                itemCount: selectedItems,
                attachments: uploadedFiles.map(f => ({ name: f.name, size: f.size, type: f.type })),
                status: 'active',
                createdAt: new Date().toISOString()
            };

            // 记录审计日志
            if (typeof AuditLog !== 'undefined') {
                AuditLog.logCreate('procurement_plan', planId, planData, `创建采购计划: ${planName}`);
            }

            const attachmentInfo = uploadedFiles.length > 0 ? `\n附件：${uploadedFiles.length} 个文件` : '';
            alert(`✅ 采购计划创建成功！\n\n计划编号：${planId}\n计划名称：${planName}\n包含物料：${selectedItems}项\n计划周期：${startDate} 至 ${endDate}${attachmentInfo}\n\n系统将根据需求预测自动生成采购提醒`);

            // 清空上传的文件
            uploadedFiles = [];
            updateFileList();
            document.getElementById('attachmentInput').value = '';

            closeModal('createProcurementPlanModal');
        }

        // 批量采购相关函数
        function batchProcurement() {
            closeToolModal('inventoryAlertModal');
            setTimeout(() => {
                openModal('batchProcurementModal');
                updateBatchCount();
            }, 300);
        }

        function toggleAllBatchItems(checkbox) {
            const checkboxes = document.querySelectorAll('.batch-item-check');
            checkboxes.forEach(cb => {
                cb.checked = checkbox.checked;
            });
            updateBatchCount();
        }

        function updateBatchCount() {
            const checked = document.querySelectorAll('.batch-item-check:checked');
            const count = checked.length;
            let total = 0;

            checked.forEach(check => {
                total += parseInt(check.getAttribute('data-amount'));
            });

            document.getElementById('batchSelectedCount').textContent = count;
            document.getElementById('batchSelectedMaterialCount').textContent = count;
            document.getElementById('batchTotalAmount').textContent = '¥' + total.toLocaleString();
        }

        function exportBatchList() {
            const checked = document.querySelectorAll('.batch-item-check:checked');
            alert(`📥 正在导出批量采购清单...\n\n已选择 ${checked.length} 项物料\n\n文件格式：Excel (.xlsx)`);
            setTimeout(() => {
                alert('✅ 清单导出成功！\n\n文件已保存到下载目录');
            }, 1000);
        }

        function submitBatchProcurement() {
            const checked = document.querySelectorAll('.batch-item-check:checked');
            const priority = document.getElementById('batchPriority').value;
            const method = document.getElementById('batchMethod').value;

            if (checked.length === 0) {
                alert('❌ 请至少选择一项物料');
                return;
            }

            let total = 0;
            checked.forEach(check => {
                total += parseInt(check.getAttribute('data-amount'));
            });

            alert(`✅ 批量采购单创建成功！\n\n采购物料：${checked.length}项\n预计总价：¥${total.toLocaleString()}\n优先级：${priority}\n\n系统将自动为每项物料创建采购单并进入审批流程`);
            closeModal('batchProcurementModal');
        }

