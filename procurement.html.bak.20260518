                                    </tr>
                                </thead>
                                <tbody>
                                    ${priceInfo.recommendedSuppliers.map((s, index) => `
                                        <tr style="border-bottom: 1px solid #f0f0f0; ${index === 0 ? 'background: rgba(0,137,11,0.05);' : ''}">
                                            <td style="padding: 12px; font-size: 13px; font-weight: ${index === 0 ? '600' : '400'};">
                                                ${s.name}
                                                ${index === 0 ? '<span style="background: #00890b; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; margin-left: 8px;">推荐</span>' : ''}
                                            </td>
                                            <td style="padding: 12px; text-align: right; font-weight: 700; color: ${index === 0 ? '#00890b' : '#333'};">¥${s.price.toFixed(2)}</td>
                                            <td style="padding: 12px; text-align: right; font-size: 12px; color: #999;">${s.moq}</td>
                                            <td style="padding: 12px; text-align: right; font-size: 12px; color: #999;">${s.stock}+</td>
                                            <td style="padding: 12px; font-size: 12px; color: #999;">${s.leadTime}</td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="modal-footer" style="padding: 16px 24px; border-top: 1px solid #e0e0e0; text-align: right;">
                        <button class="btn" style="background: #f0f0f0; color: #666; padding: 10px 20px; border-radius: 6px; border: none; cursor: pointer; font-weight: 600;" onclick="this.closest('.modal-overlay').remove()">关闭</button>
                    </div>
                </div>
            `;

            modal.addEventListener('click', function(e) {
                if (e.target === modal) {
                    modal.remove();
                }
            });

            document.body.appendChild(modal);
        }

        // ==================== 预算预警系统 ====================

        /**
         * 项目预算数据库（实际应从后端API获取）
         */
        const projectBudgetDatabase = {
            'proj1': {
                projectId: 'proj1',
                projectName: '智能温控器开发项目',
                totalBudget: 50000,      // 总预算
                usedBudget: 35000,       // 已使用预算
                remainingBudget: 15000,  // 剩余预算
                budgetDetails: [
                    { category: '物料采购', budget: 30000, used: 22000, remaining: 8000 },
                    { category: '人力成本', budget: 15000, used: 10000, remaining: 5000 },
                    { category: '其他费用', budget: 5000, used: 3000, remaining: 2000 }
                ]
            },
            'proj2': {
                projectId: 'proj2',
                projectName: '物联网网关产品',
                totalBudget: 80000,
                usedBudget: 65000,
                remainingBudget: 15000,
                budgetDetails: [
                    { category: '物料采购', budget: 50000, used: 42000, remaining: 8000 },
                    { category: '人力成本', budget: 25000, used: 20000, remaining: 5000 },
                    { category: '其他费用', budget: 5000, used: 3000, remaining: 2000 }
                ]
            },
            'proj3': {
                projectId: 'proj3',
                projectName: '工业传感器模块',
                totalBudget: 100000,
                usedBudget: 45000,
                remainingBudget: 55000,
                budgetDetails: [
                    { category: '物料采购', budget: 60000, used: 28000, remaining: 32000 },
                    { category: '人力成本', budget: 30000, used: 15000, remaining: 15000 },
                    { category: '其他费用', budget: 10000, used: 2000, remaining: 8000 }
                ]
            }
        };

        /**
         * 获取项目预算信息
         */
        function getProjectBudget(projectId) {
            // 实际应调用后端API: GET /api/projects/{projectId}/budget
            return projectBudgetDatabase[projectId] || null;
        }

        /**
         * 检查采购金额是否超预算
         */
        function checkBudgetOverrun(projectId, purchaseAmount, category = '物料采购') {
            const budget = getProjectBudget(projectId);
            if (!budget) {
                console.warn('未找到项目预算信息');
                return { overrun: false, warning: false };
            }

            const categoryBudget = budget.budgetDetails.find(d => d.category === category);
            const remainingBudget = categoryBudget ? categoryBudget.remaining : budget.remainingBudget;

            return {
                overrun: purchaseAmount > remainingBudget,
                warning: purchaseAmount > remainingBudget * 0.8,  // 超过80%预警
                projectName: budget.projectName,
                totalBudget: budget.totalBudget,
                usedBudget: budget.usedBudget,
                remainingBudget: remainingBudget,
                purchaseAmount: purchaseAmount,
                overrunAmount: Math.max(0, purchaseAmount - remainingBudget),
                utilizationRate: ((budget.usedBudget + purchaseAmount) / budget.totalBudget * 100).toFixed(1)
            };
        }

        /**
         * 显示预算预警对话框
         */
        function showBudgetWarning(budgetCheck) {
            return new Promise((resolve) => {
                const modal = document.createElement('div');
                modal.className = 'modal-overlay active';
                modal.style.cssText = `
                    position: fixed;
                    top: 0;
                    left: 0;
                    right: 0;
                    bottom: 0;
                    background: rgba(0, 0, 0, 0.5);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    z-index: 9999;
                `;

                const isOverrun = budgetCheck.overrun;
                const bgColor = isOverrun ? '#ffebee' : '#fff3e0';
                const borderColor = isOverrun ? '#f44336' : '#ff9800';
                const icon = isOverrun ? '⚠️' : '⚡';
                const title = isOverrun ? '预算超支警告' : '预算预警';

                modal.innerHTML = `
                    <div class="modal-content" style="background: white; border-radius: 12px; width: 600px; max-height: 80vh; overflow: auto; box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
                        <div class="modal-header" style="padding: 24px; background: ${bgColor}; border-bottom: 1px solid #e0e0e0; border-radius: 12px 12px 0 0; border-top: 4px solid ${borderColor};">
                            <div style="font-size: 20px; font-weight: 700; color: #1a1a1a;">${icon} ${title}</div>
                            <div style="font-size: 13px; color: #666; margin-top: 4px;">${budgetCheck.projectName}</div>
                        </div>
                        <div class="modal-body" style="padding: 24px;">
                            <!-- 预算概览 -->
                            <div style="background: #f8f9fa; padding: 16px; border-radius: 8px; margin-bottom: 20px;">
                                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 12px;">
                                    <div>
                                        <div style="font-size: 12px; color: #999; margin-bottom: 4px;">总预算</div>
                                        <div style="font-size: 20px; font-weight: 700; color: #333;">¥${budgetCheck.totalBudget.toLocaleString()}</div>
                                    </div>
                                    <div>
                                        <div style="font-size: 12px; color: #999; margin-bottom: 4px;">已使用</div>
                                        <div style="font-size: 20px; font-weight: 700; color: #ff9800;">¥${budgetCheck.usedBudget.toLocaleString()}</div>
                                    </div>
                                    <div>
                                        <div style="font-size: 12px; color: #999; margin-bottom: 4px;">剩余预算</div>
                                        <div style="font-size: 20px; font-weight: 700; color: ${budgetCheck.overrun ? '#f44336' : '#00890b'};">¥${budgetCheck.remainingBudget.toLocaleString()}</div>
                                    </div>
                                </div>
                                <!-- 预算使用率进度条 -->
                                <div style="margin-top: 12px;">
                                    <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                                        <span style="font-size: 12px; color: #666;">预算使用率</span>
                                        <span style="font-size: 12px; font-weight: 700; color: ${budgetCheck.utilizationRate > 100 ? '#f44336' : '#666'};">${budgetCheck.utilizationRate}%</span>
                                    </div>
                                    <div style="background: #e0e0e0; height: 8px; border-radius: 4px; overflow: hidden;">
                                        <div style="background: ${budgetCheck.utilizationRate > 100 ? '#f44336' : budgetCheck.utilizationRate > 80 ? '#ff9800' : '#00890b'}; height: 100%; width: ${Math.min(100, budgetCheck.utilizationRate)}%; transition: width 0.3s;"></div>
                                    </div>
                                </div>
                            </div>

                            <!-- 本次采购信息 -->
                            <div style="background: ${isOverrun ? '#ffebee' : '#fff3e0'}; padding: 16px; border-radius: 8px; border-left: 4px solid ${borderColor}; margin-bottom: 20px;">
                                <div style="font-weight: 600; margin-bottom: 8px; color: ${borderColor};">本次采购金额</div>
                                <div style="font-size: 28px; font-weight: 800; color: ${borderColor};">¥${budgetCheck.purchaseAmount.toLocaleString()}</div>
                                ${isOverrun ? `
                                    <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(244, 67, 54, 0.2);">
                                        <div style="font-size: 13px; color: #666; margin-bottom: 4px;">超支金额</div>
                                        <div style="font-size: 20px; font-weight: 700; color: #f44336;">¥${budgetCheck.overrunAmount.toLocaleString()}</div>
                                    </div>
                                ` : ''}
                            </div>

                            <!-- 警告消息 -->
                            <div style="background: ${isOverrun ? '#fff5f5' : '#fffbf0'}; padding: 14px; border-radius: 6px; margin-bottom: 20px;">
                                <div style="font-size: 14px; color: #666; line-height: 1.6;">
                                    ${isOverrun
                                        ? `⚠️ <strong style="color: #f44336;">本次采购将超出剩余预算 ¥${budgetCheck.overrunAmount.toLocaleString()}</strong><br><br>建议：<br>1. 申请预算追加<br>2. 调整采购数量<br>3. 寻找更优惠的供应商<br>4. 与项目经理协调预算分配`
                                        : `⚡ <strong style="color: #ff9800;">本次采购将使用剩余预算的 ${((budgetCheck.purchaseAmount / budgetCheck.remainingBudget) * 100).toFixed(1)}%</strong><br><br>请确认采购必要性，避免后续预算不足。`
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer" style="padding: 16px 24px; border-top: 1px solid #e0e0e0; display: flex; justify-content: space-between; align-items: center;">
                            <button class="btn" style="background: #f0f0f0; color: #666; padding: 10px 20px; border-radius: 6px; border: none; cursor: pointer; font-weight: 600;" onclick="this.closest('.modal-overlay').remove(); window.budgetWarningResolve(false);">取消采购</button>
                            <div style="display: flex; gap: 12px;">
                                ${isOverrun
                                    ? '<button class="btn" style="background: #ff9800; color: white; padding: 10px 20px; border-radius: 6px; border: none; cursor: pointer; font-weight: 600;" onclick="this.closest(\'.modal-overlay\').remove(); window.budgetWarningResolve(\'申请追加预算\');">申请预算追加</button>'
                                    : ''
                                }
                                <button class="btn btn-primary" style="background: #00890b; color: white; padding: 10px 20px; border-radius: 6px; border: none; cursor: pointer; font-weight: 600;" onclick="this.closest('.modal-overlay').remove(); window.budgetWarningResolve(true);">确认继续</button>
                            </div>
                        </div>
                `;

                modal.addEventListener('click', function(e) {
                    if (e.target === modal) {
                        modal.remove();
                        resolve(false);
                    }
                });

                // 保存resolve函数供按钮调用
                window.budgetWarningResolve = (result) => {
                    resolve(result);
                };

                document.body.appendChild(modal);
            });
        }

        /**
         * 物料选择时自动同步价格
         */
        function onMaterialSelected(materialId, targetPriceElementId) {
            const priceInfo = getMaterialPriceInfo(materialId);
            if (!priceInfo) return;

            // 显示价格信息提示
            const notification = document.createElement('div');
            notification.style.cssText = `
                position: fixed;
                top: 100px;
                right: 30px;
                background: white;
                padding: 16px 20px;
                border-radius: 8px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.15);
                z-index: 9998;
                min-width: 300px;
                border-left: 4px solid #00890b;
            `;
            notification.innerHTML = `
                <div style="font-weight: 600; margin-bottom: 8px; color: #00890b;">💰 价格信息已同步</div>
                <div style="font-size: 13px; color: #666; margin-bottom: 4px;">标准价格: ¥${priceInfo.standardPrice.toFixed(2)}</div>
                <div style="font-size: 13px; color: #666; margin-bottom: 4px;">最近采购价: ¥${priceInfo.recentPrice.toFixed(2)}</div>
                <div style="font-size: 13px; color: #666;">推荐供应商: ${priceInfo.recommendedSuppliers[0].name}</div>
                <button onclick="showMaterialPriceDetail('${materialId}')" style="margin-top: 12px; background: #00890b; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: 600;">查看详情</button>
            `;
            document.body.appendChild(notification);

            // 3秒后自动消失
            setTimeout(() => {
                notification.remove();
            }, 5000);

            // 如果指定了目标元素，自动填充价格
            if (targetPriceElementId) {
                const targetElement = document.getElementById(targetPriceElementId);
                if (targetElement) {
                    targetElement.value = priceInfo.recentPrice.toFixed(2);
                }
            }
        }

        // ==================== 页面加载时初始化 ====================
        document.addEventListener('DOMContentLoaded', function() {
            // 检查页面访问权限
            if (typeof PermissionControl !== 'undefined') {
                PermissionControl.checkPageAccess('procurement', 'read');
                PermissionControl.applyUIPermissions();
            }

            // 定期检查过期物料占料
            if (typeof MaterialReservation !== 'undefined') {
                MaterialReservation.checkAndReleaseExpired();
            }

            // 为物料选择下拉框添加价格自动同步
            const materialSelect = document.getElementById('materialForComparison');
            if (materialSelect) {
                materialSelect.addEventListener('change', function(e) {
                    const materialId = e.target.value;
                    if (materialId) {
                        onMaterialSelected(materialId);
                    }
                });
            }
        });
    </script>

    <!-- 引入核心系统脚本 -->
    <script src="js/permission-control.js"></script>
    <script src="js/audit-log.js"></script>
    <script src="js/material-reservation.js"></script>
</body>
</html>
