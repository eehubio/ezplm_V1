                    <div style="text-align: right;">
                        <div style="font-size: 13px; color: #666; margin-bottom: 4px;">已选择物料</div>
                        <div style="font-size: 20px; font-weight: 700; color: #3498db;"><span id="batchSelectedMaterialCount">3</span> 项</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeModal('batchProcurementModal')">取消</button>
                <button class="btn-secondary" onclick="exportBatchList()">导出清单</button>
                <button class="btn-primary" onclick="submitBatchProcurement()">提交批量采购</button>
            </div>
        </div>
    </div>

    <!-- 审批采购单Modal -->
