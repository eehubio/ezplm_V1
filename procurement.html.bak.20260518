                                <tr>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <input type="checkbox" class="batch-item-check" data-amount="940" onchange="updateBatchCount()" checked>
                                    </td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <div style="font-weight: 600; margin-bottom: 4px;">0805 100nF 电容</div>
                                        <div style="font-size: 12px; color: #666;">型号：0805 100nF | ¥0.02/个</div>
                                    </td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0; color: #f39c12; font-weight: 700;">1,200个</td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">5,000个</td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <input type="number" class="form-input" value="47000" style="width: 80px; padding: 6px;">
