    <!-- 新建采购单Modal -->
    <div class="modal-overlay" id="procurementModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">🛒 新建采购单</h3>
                <button class="modal-close" onclick="closeProcurementModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="procurementForm">
                    <div class="form-group">
                        <label class="form-label required">采购单名称</label>
                        <input type="text" class="form-input" id="poName" placeholder="请输入采购单名称" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label required">供应商选择</label>
                        <select class="form-select" id="supplier" required>
                            <option value="">请选择供应商</option>
                            <option value="lcsc">深圳立创商城</option>
                            <option value="digikey">得捷电子 Digi-Key</option>
                            <option value="mouser">贸泽电子 Mouser</option>
                            <option value="arrow">艾睿电子 Arrow</option>
                            <option value="szlcsc">深圳华强北</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label required">采购项目</label>
                        <select class="form-select" id="poProject" required>
                            <option value="">请选择关联项目</option>
                            <option value="proj1">智能手环 V2.0</option>
                            <option value="proj2">无线充电器设计优化</option>
                            <option value="proj3">智能音箱 Mini版</option>
                        </select>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label required">交货日期</label>
                            <input type="date" class="form-input" id="deliveryDate" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label required">预算金额</label>
                            <input type="number" class="form-input" id="budget" placeholder="¥" min="0" step="0.01" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label required">采购负责人</label>
                        <select class="form-select" id="poOwner" required>
                            <option value="">请选择采购负责人</option>
                            <option value="user1">钱七 (采购专员)</option>
                            <option value="user2">李明 (项目经理)</option>
                            <option value="user3">张三 (硬件工程师)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">采购说明</label>
                        <textarea class="form-textarea" id="poNotes" placeholder="请输入采购说明和特殊要求（可选）"></textarea>
                    </div>

                    <!-- 附件上传 -->
                    <div class="form-group">
                        <label class="form-label">上传附件</label>
                        <div style="margin-bottom: 12px;">
                            <div id="uploadZone" style="border: 2px dashed #d0d0d0; border-radius: 8px; padding: 32px; text-align: center; background: #fafafa; cursor: pointer; transition: all 0.3s;" onclick="document.getElementById('fileInput').click()">
                                <div style="font-size: 48px; margin-bottom: 12px;">📎</div>
                                <div style="font-size: 15px; color: #3d4647; font-weight: 600; margin-bottom: 8px;">点击或拖拽文件到此处上传</div>
                                <div style="font-size: 13px; color: #999;">
                                    支持格式：Excel (.xlsx, .xls)、PDF、Word (.docx)、图片 (jpg, png)
                                </div>
                                <div style="font-size: 12px; color: #999; margin-top: 4px;">
                                    单个文件不超过 10MB
                                </div>
                            </div>
                            <input type="file" id="fileInput" multiple style="display: none;" accept=".xlsx,.xls,.pdf,.doc,.docx,.jpg,.jpeg,.png" onchange="handleFileUpload(event)">
                        </div>

                        <!-- 已上传文件列表 -->
                        <div id="attachmentList" style="display: none;">
                            <div style="font-size: 13px; color: #666; font-weight: 600; margin-bottom: 8px;">📋 已上传附件</div>
                            <div id="fileListContainer"></div>
                        </div>
                    </div>

                    <div style="background: #f9f9f9; padding: 16px; border-radius: 6px; border-left: 4px solid #00890b; margin-top: 20px;">
                        <div style="font-size: 13px; color: #666; margin-bottom: 8px;">📋 注意事项</div>
                        <ul style="font-size: 13px; color: #666; margin-left: 20px;">
                            <li>批量采购建议上传物料明细表（Excel格式）</li>
                            <li>特殊要求可上传相关技术文档或费用说明</li>
                            <li>采购单需经审批后才能发送给供应商</li>
                            <li>请确认预算金额和交货日期准确无误</li>
                        </ul>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeProcurementModal()">取消</button>
                <button class="btn-primary" onclick="submitProcurement()">创建采购单</button>
            </div>
        </div>
    </div>

    <!-- 供应商匹配详情模态框 -->
    <div class="modal-overlay" id="matchDetailModal">
        <div class="modal-content" style="max-width: 900px;">
            <div class="modal-header">
                <h3 class="modal-title" id="matchModalTitle">🏪 供应商物料匹配详情</h3>
