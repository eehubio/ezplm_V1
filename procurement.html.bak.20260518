                            <thead style="position: sticky; top: 0; background: #f9f9f9; z-index: 10;">
                                <tr>
                                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">
                                        <input type="checkbox" id="selectAllBatch" onchange="toggleAllBatchItems(this)" checked>
