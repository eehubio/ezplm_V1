                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <input type="number" class="form-input" value="1050" style="width: 80px; padding: 6px;">
                                    </td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <span style="background: #f39c12; color: white; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: 600;">偏低</span>
                                    </td>
