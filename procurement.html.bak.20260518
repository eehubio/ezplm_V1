                        <label class="form-label">开始日期</label>
                        <input type="date" class="form-input" id="reportStartDate">
                    </div>
                    <div class="form-group">
                        <label class="form-label">结束日期</label>
                        <input type="date" class="form-input" id="reportEndDate">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">筛选条件</label>
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
                        <select class="form-select">
                            <option value="">全部项目</option>
                            <option value="p1">智能手环 V2.0</option>
                            <option value="p2">智能门锁项目</option>
                            <option value="p3">无线充电器优化</option>
                        </select>
                        <select class="form-select">
                            <option value="">全部供应商</option>
                            <option value="s1">深圳立创商城</option>
                            <option value="s2">得捷电子 Digi-Key</option>
                            <option value="s3">贸泽电子 Mouser</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">输出格式</label>
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">
                        <label style="display: flex; align-items: center; padding: 12px; border: 2px solid #e0e0e0; border-radius: 6px; cursor: pointer;">
                            <input type="radio" name="format" value="excel" checked style="margin-right: 8px;">
                            <span>📊 Excel</span>
                        </label>
                        <label style="display: flex; align-items: center; padding: 12px; border: 2px solid #e0e0e0; border-radius: 6px; cursor: pointer;">
                            <input type="radio" name="format" value="pdf" style="margin-right: 8px;">
                            <span>📄 PDF</span>
                        </label>
                        <label style="display: flex; align-items: center; padding: 12px; border: 2px solid #e0e0e0; border-radius: 6px; cursor: pointer;">
                            <input type="radio" name="format" value="csv" style="margin-right: 8px;">
                            <span>📋 CSV</span>
                        </label>
                    </div>
                </div>
                <div style="background: #f9f9f9; padding: 16px; border-radius: 6px; margin-top: 20px;">
                    <div style="font-weight: 600; margin-bottom: 12px; font-size: 14px;">📋 报表内容预览</div>
                    <ul style="font-size: 13px; color: #666; margin-left: 20px; line-height: 1.8;">
                        <li>采购订单统计：总订单数、总金额、平均周期</li>
                        <li>供应商分布：各供应商采购占比</li>
                        <li>物料类别分析：各类别采购金额和数量</li>
                        <li>成本趋势图表：按月度、季度统计</li>
                        <li>异常情况汇总：逾期订单、质量问题等</li>
                    </ul>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeToolModal('reportGenerationModal')">取消</button>
                <button class="btn-primary" onclick="generateReport()">生成报表</button>
            </div>
        </div>
    </div>

    <!-- 从价格对比创建采购单Modal -->
    <div class="modal-overlay" id="createPOFromComparisonModal">
        <div class="modal-content" style="max-width: 700px;">
            <div class="modal-header">
                <h3 class="modal-title">📝 创建采购单 - 基于价格对比</h3>
                <button class="modal-close" onclick="closeModal('createPOFromComparisonModal')">&times;</button>
            </div>
            <div class="modal-body">
                <div style="background: rgba(0,137,11,0.05); padding: 16px; border-radius: 8px; margin-bottom: 24px; border-left: 4px solid #00890b;">
                    <div style="font-weight: 600; margin-bottom: 8px; color: #00890b;">✅ 已选择最优供应商</div>
                    <div style="font-size: 14px; color: #666;">供应商：深圳立创商城 | 预计总价：¥850 | 预计节省：¥180</div>
                </div>
                <div class="form-group">
                    <label class="form-label"><span style="color: #e74c3c;">*</span> 采购单名称</label>
                    <input type="text" class="form-input" id="poNameFromComparison" placeholder="请输入采购单名称" value="STM32F103C8T6 芯片采购">
                </div>
                <div class="form-group">
                    <label class="form-label"><span style="color: #e74c3c;">*</span> 关联项目</label>
                    <select class="form-select" id="projectFromComparison">
                        <option value="proj1">智能温控器开发项目</option>
                        <option value="proj2">物联网网关产品</option>
                        <option value="proj3">工业传感器模块</option>
                    </select>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                    <div class="form-group">
                        <label class="form-label"><span style="color: #e74c3c;">*</span> 采购数量</label>
                        <input type="number" class="form-input" id="quantityFromComparison" value="100">
                    </div>
                    <div class="form-group">
                        <label class="form-label"><span style="color: #e74c3c;">*</span> 期望交期</label>
                        <input type="date" class="form-input" id="expectedDateFromComparison">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">物料明细</label>
                    <div style="background: #f9f9f9; padding: 14px; border-radius: 6px; border: 1px solid #e0e0e0;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                            <div style="font-weight: 600;">STM32F103C8T6 MCU芯片</div>
                            <div style="color: #00890b; font-weight: 700;">¥8.50/个</div>
                        </div>
                        <div style="font-size: 13px; color: #666; margin-bottom: 4px;">型号：STM32F103C8T6 | 封装：LQFP48</div>
                        <div style="font-size: 13px; color: #666;">供应商：深圳立创商城 | 库存：5000+ | 交货期：3-5天</div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">备注说明</label>
                    <textarea class="form-textarea" id="remarkFromComparison" rows="3" placeholder="请输入备注信息（选填）"></textarea>
                </div>
                <div style="background: #f0f9ff; padding: 14px; border-radius: 6px; display: flex; justify-content: space-between; align-items: center; border: 1px solid #bfdbfe;">
                    <div style="font-weight: 600; font-size: 15px;">预计总价：</div>
                    <div style="font-size: 24px; font-weight: 800; color: #00890b;">¥850</div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeModal('createPOFromComparisonModal')">取消</button>
                <button class="btn-primary" onclick="submitPOFromComparison()">提交采购单</button>
            </div>
        </div>
    </div>

    <!-- 创建采购计划Modal（需求预测） -->
    <div class="modal-overlay" id="createProcurementPlanModal">
        <div class="modal-content" style="max-width: 800px;">
            <div class="modal-header">
                <h3 class="modal-title">📋 创建采购计划 - 基于需求预测</h3>
                <button class="modal-close" onclick="closeModal('createProcurementPlanModal')">&times;</button>
            </div>
            <div class="modal-body">
                <div style="background: rgba(155,89,182,0.05); padding: 16px; border-radius: 8px; margin-bottom: 24px; border-left: 4px solid #9b59b6;">
                    <div style="font-weight: 600; margin-bottom: 8px; color: #9b59b6;">🔮 AI智能预测建议</div>
                    <div style="font-size: 13px; color: #666;">系统已根据历史数据和项目排期预测未来3个月的物料需求，建议创建分批采购计划以优化成本。</div>
                </div>
                <div class="form-group">
                    <label class="form-label"><span style="color: #e74c3c;">*</span> 采购计划名称</label>
                    <input type="text" class="form-input" id="planName" placeholder="请输入采购计划名称" value="Q1季度物料采购计划">
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                    <div class="form-group">
                        <label class="form-label"><span style="color: #e74c3c;">*</span> 计划开始日期</label>
                        <input type="date" class="form-input" id="planStartDate">
                    </div>
                    <div class="form-group">
                        <label class="form-label"><span style="color: #e74c3c;">*</span> 计划结束日期</label>
                        <input type="date" class="form-input" id="planEndDate">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">预测物料清单</label>
                    <div style="max-height: 280px; overflow-y: auto; border: 1px solid #e0e0e0; border-radius: 6px;">
                        <table style="width: 100%;">
                            <thead style="position: sticky; top: 0; background: #f9f9f9; z-index: 10;">
                                <tr>
                                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">
                                        <input type="checkbox" id="selectAllPlan" onchange="toggleAllPlanItems(this)" checked>
                                    </th>
                                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">物料名称</th>
                                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">预计需求</th>
                                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">建议采购</th>
                                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">紧急度</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <input type="checkbox" class="plan-item-check" checked>
                                    </td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <div style="font-weight: 600;">STM32F103C8T6</div>
                                        <div style="font-size: 12px; color: #666;">当前库存：120个</div>
                                    </td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">450个</td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0; font-weight: 700; color: #00890b;">330个</td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <span style="background: rgba(231,76,60,0.1); color: #e74c3c; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: 600;">高</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <input type="checkbox" class="plan-item-check" checked>
                                    </td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <div style="font-weight: 600;">AMS1117-3.3</div>
                                        <div style="font-size: 12px; color: #666;">当前库存：200个</div>
                                    </td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">380个</td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0; font-weight: 700; color: #f39c12;">180个</td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <span style="background: rgba(255,193,7,0.1); color: #f39c12; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: 600;">中</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <input type="checkbox" class="plan-item-check" checked>
                                    </td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <div style="font-weight: 600;">0805 100nF 电容</div>
                                        <div style="font-size: 12px; color: #666;">当前库存：3,500个</div>
                                    </td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">8,200个</td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0; font-weight: 700; color: #00890b;">4,700个</td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <span style="background: rgba(231,76,60,0.1); color: #e74c3c; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: 600;">高</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">采购策略</label>
                    <select class="form-select" id="procurementStrategy">
                        <option value="batch">集中批量采购（降低单价）</option>
                        <option value="split">分批采购（降低资金占用）</option>
                        <option value="jit">准时制采购（最小化库存）</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">计划说明</label>
                    <textarea class="form-textarea" id="planDescription" rows="3" placeholder="请输入计划说明（选填）"></textarea>
                </div>
                <!-- 附件上传 -->
                <div class="form-group">
                    <label class="form-label">附件上传</label>
                    <div style="border: 2px dashed #e0e0e0; border-radius: 8px; padding: 24px; text-align: center; background: #fafafa; transition: all 0.3s;" id="uploadArea" onmouseover="this.style.borderColor='#00890b'; this.style.background='rgba(0,137,11,0.03)'" onmouseout="this.style.borderColor='#e0e0e0'; this.style.background='#fafafa'">
                        <input type="file" id="attachmentInput" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg" style="display: none;" onchange="handleFileSelect(event)">
                        <div style="font-size: 48px; margin-bottom: 12px;">📎</div>
                        <div style="font-size: 14px; color: #666; margin-bottom: 8px;">点击或拖拽文件到此处上传</div>
                        <div style="font-size: 12px; color: #999;">支持 PDF, Word, Excel, 图片格式，单个文件不超过10MB</div>
                        <button type="button" class="btn-secondary" onclick="document.getElementById('attachmentInput').click()" style="margin-top: 12px;">选择文件</button>
                    </div>
                    <div id="fileList" style="margin-top: 12px;"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeModal('createProcurementPlanModal')">取消</button>
                <button class="btn-secondary" onclick="savePlanDraft()" style="margin-right: auto;">保存草稿</button>
                <button class="btn-primary" onclick="submitProcurementPlan()">创建计划</button>
            </div>
        </div>
    </div>

    <!-- 批量采购Modal（库存预警） -->
