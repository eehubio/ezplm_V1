                        <!-- 采购历史 -->
                        <div style="margin-bottom: 24px;">
                            <div style="font-size: 16px; font-weight: 700; margin-bottom: 12px;">📊 历史采购记录</div>
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead>
                                    <tr style="background: #f8f9fa;">
                                        <th style="padding: 12px; text-align: left; font-size: 12px; color: #666;">日期</th>
                                        <th style="padding: 12px; text-align: left; font-size: 12px; color: #666;">供应商</th>
                                        <th style="padding: 12px; text-align: right; font-size: 12px; color: #666;">单价</th>
                                        <th style="padding: 12px; text-align: right; font-size: 12px; color: #666;">数量</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${priceInfo.priceHistory.map(h => `
                                        <tr style="border-bottom: 1px solid #f0f0f0;">
                                            <td style="padding: 12px; font-size: 13px;">${h.date}</td>
                                            <td style="padding: 12px; font-size: 13px;">${h.supplier}</td>
                                            <td style="padding: 12px; text-align: right; font-weight: 600; color: #00890b;">¥${h.price.toFixed(2)}</td>
                                            <td style="padding: 12px; text-align: right; font-size: 12px; color: #999;">${h.quantity}</td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>

                        <!-- 推荐供应商 -->
                        <div>
                            <div style="font-size: 16px; font-weight: 700; margin-bottom: 12px;">🏪 推荐供应商</div>
                            <table style="width: 100%; border-collapse: collapse;">
