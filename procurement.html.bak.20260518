                        </div>
                        <div style="background: rgba(255,255,255,0.2); padding: 8px 16px; border-radius: 8px;">
                            <span style="font-size: 12px;">供应商编号</span>
                            <div style="font-size: 16px; font-weight: 700; margin-top: 4px;" id="matchSupplierId">SUP-2024-0156</div>
                        </div>
                    </div>
                </div>

                <!-- 匹配的物料信息 -->
                <div style="margin-bottom: 24px;">
                    <h4 style="font-size: 16px; font-weight: 700; color: #3d4647; margin-bottom: 12px;">📦 匹配的物料信息</h4>
                    <div style="background: #f9f9f9; border-radius: 8px; padding: 16px;">
                        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
                            <div>
                                <div style="font-size: 12px; color: #999; margin-bottom: 4px;">物料型号</div>
                                <div style="font-size: 16px; font-weight: 700; color: #3d4647;" id="matchPartNumber">STM32F407VGT6</div>
                            </div>
                            <div>
                                <div style="font-size: 12px; color: #999; margin-bottom: 4px;">制造商</div>
                                <div style="font-size: 14px; font-weight: 600; color: #3d4647;" id="matchManufacturer">STMicroelectronics</div>
                            </div>
                            <div>
                                <div style="font-size: 12px; color: #999; margin-bottom: 4px;">匹配项目</div>
                                <div style="font-size: 14px; font-weight: 600; color: #3d4647;" id="matchProject">智能手环 V2.0</div>
                            </div>
                            <div>
                                <div style="font-size: 12px; color: #999; margin-bottom: 4px;">BOM编号</div>
                                <div style="font-size: 14px; font-weight: 600; color: #3d4647;" id="matchBomNumber">BOM-2024-0156</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 价格和库存信息 -->
                <div style="margin-bottom: 24px;">
                    <h4 style="font-size: 16px; font-weight: 700; color: #3d4647; margin-bottom: 12px;">💰 价格与交期信息</h4>
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
                        <div style="background: white; border: 2px solid #e0e0e0; border-radius: 8px; padding: 16px;">
                            <div style="font-size: 12px; color: #999; margin-bottom: 4px;">单价</div>
                            <div style="font-size: 24px; font-weight: 800; color: #00890b;" id="matchPrice">¥32.50/片</div>
                        </div>
                        <div style="background: white; border: 2px solid #e0e0e0; border-radius: 8px; padding: 16px;">
                            <div style="font-size: 12px; color: #999; margin-bottom: 4px;">最小起订量 (MOQ)</div>
                            <div style="font-size: 24px; font-weight: 800; color: #3d4647;" id="matchMOQ">100片</div>
                        </div>
                        <div style="background: white; border: 2px solid #e0e0e0; border-radius: 8px; padding: 16px;">
                            <div style="font-size: 12px; color: #999; margin-bottom: 4px;">现货库存</div>
                            <div style="font-size: 24px; font-weight: 800; color: #00890b;" id="matchStock">5,000片</div>
                        </div>
                        <div style="background: white; border: 2px solid #e0e0e0; border-radius: 8px; padding: 16px;">
                            <div style="font-size: 12px; color: #999; margin-bottom: 4px;">交货周期</div>
                            <div style="font-size: 24px; font-weight: 800; color: #3d4647;" id="matchLeadTime">3-5天</div>
                        </div>
                    </div>
                </div>

                <!-- 阶梯价格 -->
                <div style="margin-bottom: 24px;">
                    <h4 style="font-size: 16px; font-weight: 700; color: #3d4647; margin-bottom: 12px;">📊 阶梯价格</h4>
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: #f9f9f9;">
                                <th style="padding: 12px; text-align: left; font-size: 13px; color: #666; border-bottom: 2px solid #e0e0e0;">数量范围</th>
                                <th style="padding: 12px; text-align: left; font-size: 13px; color: #666; border-bottom: 2px solid #e0e0e0;">单价</th>
                                <th style="padding: 12px; text-align: left; font-size: 13px; color: #666; border-bottom: 2px solid #e0e0e0;">优惠幅度</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">100-499片</td>
                                <td style="padding: 12px; border-bottom: 1px solid #f0f0f0; font-weight: 700; color: #00890b;">¥32.50</td>
                                <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">基准价</td>
                            </tr>
                            <tr>
                                <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">500-999片</td>
                                <td style="padding: 12px; border-bottom: 1px solid #f0f0f0; font-weight: 700; color: #00890b;">¥30.80</td>
                                <td style="padding: 12px; border-bottom: 1px solid #f0f0f0; color: #00890b;">-5.2%</td>
                            </tr>
                            <tr>
                                <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">1000+片</td>
                                <td style="padding: 12px; border-bottom: 1px solid #f0f0f0; font-weight: 700; color: #00890b;">¥28.50</td>
                                <td style="padding: 12px; border-bottom: 1px solid #f0f0f0; color: #00890b;">-12.3%</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- 供应商联系方式 -->
                <div style="background: #f0f9ff; border-left: 4px solid #3498db; padding: 16px; border-radius: 8px; margin-bottom: 24px;">
                    <h4 style="font-size: 14px; font-weight: 700; color: #3d4647; margin-bottom: 12px;">📞 供应商联系方式</h4>
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; font-size: 14px;">
                        <div><span style="color: #999;">联系人:</span> <span style="font-weight: 600;">张经理</span></div>
                        <div><span style="color: #999;">电话:</span> <span style="font-weight: 600;">0755-8888-8888</span></div>
                        <div><span style="color: #999;">邮箱:</span> <span style="font-weight: 600;">sales@example.com</span></div>
                        <div><span style="color: #999;">地址:</span> <span style="font-weight: 600;">深圳市福田区华强北</span></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeMatchDetailModal()">关闭</button>
                <button class="btn-primary" onclick="addToSupplierList()" style="background: #3498db; display: flex; align-items: center; gap: 6px;">
                    <span>⭐</span>
                    <span>加入候选供应商</span>
                </button>
                <button class="btn-primary" onclick="createInquiryForMatch()" style="display: flex; align-items: center; gap: 6px;">
                    <span>💬</span>
                    <span>发起询价</span>
                </button>
            </div>
        </div>
    </div>

    <script>
        function openProcurementModal() {
            document.getElementById('procurementModal').classList.add('active');
        }
        // 存储上传的文件
        let uploadedFiles = [];

        function closeProcurementModal() {
            document.getElementById('procurementModal').classList.remove('active');
            document.getElementById('procurementForm').reset();
            // 清空附件列表
            uploadedFiles = [];
            document.getElementById('attachmentList').style.display = 'none';
            document.getElementById('fileListContainer').innerHTML = '';
        }

        function submitProcurement() {
            const name = document.getElementById('poName').value;
            const supplier = document.getElementById('supplier').value;
            const project = document.getElementById('poProject').value;
            const date = document.getElementById('deliveryDate').value;
            const budget = document.getElementById('budget').value;
            const owner = document.getElementById('poOwner').value;

            if (!name || !supplier || !project || !date || !budget || !owner) {
                alert('请填写所有必填项！');
                return;
            }

            const poNumber = 'PO-2024-' + String(Math.floor(Math.random() * 9000) + 1000);
            let attachmentInfo = '';
            if (uploadedFiles.length > 0) {
                attachmentInfo = `\n附件: ${uploadedFiles.length} 个文件`;
            }
            alert(`采购单创建成功！\n\n采购单号: ${poNumber}\n名称: ${name}\n供应商: ${supplier}\n交货日期: ${date}\n预算: ¥${budget}${attachmentInfo}\n\n请继续添加物料清单并提交审批。`);
            closeProcurementModal();
            // 跳转到详情页
            setTimeout(() => {
                location.href = 'procurement-detail.html?id=' + poNumber;
            }, 1500);
        }

        // 文件上传处理
        function handleFileUpload(event) {
            const files = event.target.files;
            if (!files || files.length === 0) return;

            Array.from(files).forEach(file => {
                // 检查文件大小（10MB限制）
                if (file.size > 10 * 1024 * 1024) {
                    alert(`文件 "${file.name}" 超过10MB限制，无法上传！`);
                    return;
                }

                // 添加到上传列表
                uploadedFiles.push(file);
                addFileToList(file);
            });

            // 显示附件列表
            if (uploadedFiles.length > 0) {
                document.getElementById('attachmentList').style.display = 'block';
            }

            // 清空input，允许重复选择同一文件
            event.target.value = '';
        }

        // 添加文件到显示列表
        function addFileToList(file) {
            const container = document.getElementById('fileListContainer');
            const fileIndex = uploadedFiles.length - 1;

            const fileItem = document.createElement('div');
            fileItem.style.cssText = 'display: flex; align-items: center; justify-content: space-between; padding: 12px; background: white; border: 1px solid #e0e0e0; border-radius: 6px; margin-bottom: 8px;';
            fileItem.setAttribute('data-file-index', fileIndex);

            const fileIcon = getFileIcon(file.name);
            const fileSize = formatFileSize(file.size);

            fileItem.innerHTML = `
                <div style="display: flex; align-items: center; gap: 12px; flex: 1;">
                    <div style="font-size: 32px;">${fileIcon}</div>
                    <div style="flex: 1;">
                        <div style="font-size: 14px; font-weight: 600; color: #3d4647; margin-bottom: 4px;">${file.name}</div>
                        <div style="font-size: 12px; color: #999;">${fileSize} • ${getFileType(file.name)}</div>
                    </div>
                </div>
                <button onclick="removeFile(${fileIndex})" style="background: #fee; color: #e74c3c; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 13px; font-weight: 600;">删除</button>
            `;

            container.appendChild(fileItem);
        }

        // 删除文件
        function removeFile(index) {
            uploadedFiles.splice(index, 1);

            // 重新渲染文件列表
            const container = document.getElementById('fileListContainer');
            container.innerHTML = '';

            uploadedFiles.forEach((file, idx) => {
                const fileItem = document.createElement('div');
                fileItem.style.cssText = 'display: flex; align-items: center; justify-content: space-between; padding: 12px; background: white; border: 1px solid #e0e0e0; border-radius: 6px; margin-bottom: 8px;';

                const fileIcon = getFileIcon(file.name);
                const fileSize = formatFileSize(file.size);

                fileItem.innerHTML = `
                    <div style="display: flex; align-items: center; gap: 12px; flex: 1;">
                        <div style="font-size: 32px;">${fileIcon}</div>
                        <div style="flex: 1;">
                            <div style="font-size: 14px; font-weight: 600; color: #3d4647; margin-bottom: 4px;">${file.name}</div>
                            <div style="font-size: 12px; color: #999;">${fileSize} • ${getFileType(file.name)}</div>
                        </div>
                    </div>
                    <button onclick="removeFile(${idx})" style="background: #fee; color: #e74c3c; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 13px; font-weight: 600;">删除</button>
                `;

                container.appendChild(fileItem);
            });

            // 如果没有文件了，隐藏列表
            if (uploadedFiles.length === 0) {
                document.getElementById('attachmentList').style.display = 'none';
            }
        }

        // 获取文件图标
        function getFileIcon(filename) {
            const ext = filename.split('.').pop().toLowerCase();
            const iconMap = {
                'xlsx': '📊',
                'xls': '📊',
                'pdf': '📄',
                'doc': '📝',
                'docx': '📝',
                'jpg': '🖼️',
                'jpeg': '🖼️',
                'png': '🖼️',
                'zip': '📦',
                'rar': '📦'
            };
            return iconMap[ext] || '📎';
        }

        // 获取文件类型描述
        function getFileType(filename) {
            const ext = filename.split('.').pop().toLowerCase();
            const typeMap = {
                'xlsx': 'Excel表格',
                'xls': 'Excel表格',
                'pdf': 'PDF文档',
                'doc': 'Word文档',
                'docx': 'Word文档',
                'jpg': '图片',
                'jpeg': '图片',
                'png': '图片',
                'zip': '压缩文件',
                'rar': '压缩文件'
            };
            return typeMap[ext] || '文件';
        }

        // 格式化文件大小
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 B';
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
            return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
        }

        // 拖拽上传功能
        window.addEventListener('DOMContentLoaded', function() {
            const uploadZone = document.getElementById('uploadZone');
            if (!uploadZone) return;

            uploadZone.addEventListener('dragover', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.style.borderColor = '#00890b';
                this.style.background = '#f0f8f0';
            });

            uploadZone.addEventListener('dragleave', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.style.borderColor = '#d0d0d0';
                this.style.background = '#fafafa';
            });

            uploadZone.addEventListener('drop', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.style.borderColor = '#d0d0d0';
                this.style.background = '#fafafa';

                const files = e.dataTransfer.files;
                if (files.length > 0) {
                    // 模拟 file input 的 change 事件
                    const event = { target: { files: files, value: '' } };
                    handleFileUpload(event);
                }
            });
        });

        // 搜索和筛选功能
        function filterTable() {
            const searchInput = document.getElementById('searchInput').value.toLowerCase();
            const statusFilter = document.getElementById('statusFilter').value;
            const table = document.getElementById('procurementTable');
            const rows = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');

            for (let i = 0; i < rows.length; i++) {
                const cells = rows[i].getElementsByTagName('td');
                const poNumber = cells[1].textContent.toLowerCase();
                const supplier = cells[3].textContent.toLowerCase();
                const status = cells[9].textContent;

                let matchSearch = poNumber.includes(searchInput) || supplier.includes(searchInput);
                let matchStatus = !statusFilter || status.includes(statusFilter);

                rows[i].style.display = (matchSearch && matchStatus) ? '' : 'none';
            }
        }

        // 全选功能
        function toggleSelectAll(checkbox) {
            const checkboxes = document.querySelectorAll('.row-checkbox');
            checkboxes.forEach(cb => cb.checked = checkbox.checked);
        }

        // 查看采购单详情
        function viewProcurementDetail(poNumber) {
            location.href = 'procurement-detail.html?id=' + poNumber;
        }

        // 编辑采购单
        function editProcurement(poNumber) {
            location.href = 'procurement-edit.html?id=' + poNumber;
        }

        // 审批采购单
        function approveProcurement(poNumber) {
            document.getElementById('approvePoNumber').textContent = poNumber;
            document.getElementById('approvePoNumberDetail').textContent = poNumber;
            document.getElementById('approveProcurementModal').classList.add('active');
        }

        function selectApprovalDecision(decision, element) {
            // 移除其他选中状态
            element.parentElement.querySelectorAll('label').forEach(label => {
                label.style.border = '2px solid #e0e0e0';
                label.style.background = 'white';
            });

            // 设置选中状态
            if (decision === 'approve') {
                element.style.border = '2px solid #00890b';
                element.style.background = 'rgba(0,137,11,0.05)';
            } else {
                element.style.border = '2px solid #e74c3c';
                element.style.background = 'rgba(231,76,60,0.05)';
            }

            // 选中radio
            element.querySelector('input[type="radio"]').checked = true;
        }

        function submitApproval() {
            const poNumber = document.getElementById('approvePoNumber').textContent;
            const decision = document.querySelector('input[name="approvalDecision"]:checked');
            const comment = document.getElementById('approvalComment').value;

            if (!decision) {
                alert('⚠️ 请选择审批决策');
                return;
            }

            if (!comment.trim()) {
                alert('⚠️ 请输入审批意见');
                return;
            }

            if (decision.value === 'approve') {
                alert(`✅ 采购单审批通过！\n\n采购单号：${poNumber}\n审批意见：${comment}\n\n订单已自动发送给供应商，请等待供应商确认。`);
            } else {
                alert(`❌ 采购单已拒绝\n\n采购单号：${poNumber}\n拒绝原因：${comment}\n\n已通知申请人修改或重新提交。`);
            }

            closeModal('approveProcurementModal');
        }

        // 确认收货
        function confirmReceipt(poNumber) {
            location.href = 'procurement-receipt.html?id=' + poNumber;
        }

        // 入库处理
        function processInbound(poNumber) {
            document.getElementById('inboundPoNumber').textContent = poNumber;
            document.getElementById('inboundPoNumberDetail').value = poNumber;
            document.getElementById('inboundProcessModal').classList.add('active');
        }

        function saveInboundDraft() {
            const poNumber = document.getElementById('inboundPoNumberDetail').value;
            alert(`💾 入库草稿已保存\n\n采购单号：${poNumber}\n\n您可以稍后继续完成入库操作。`);
        }

        function confirmInbound() {
            const poNumber = document.getElementById('inboundPoNumberDetail').value;
            const warehouse = document.getElementById('inboundWarehouse').value;
            const operator = document.getElementById('inboundOperator').value;

            if (!warehouse) {
                alert('⚠️ 请选择入库仓位');
                return;
            }

            if (!operator.trim()) {
                alert('⚠️ 请输入入库经办人');
                return;
            }

            alert(`✅ 入库处理成功！\n\n采购单号：${poNumber}\n入库仓位：${warehouse}\n入库经办人：${operator}\n入库数量：8,080件\n\n库存已自动更新，入库单已生成。`);
            closeModal('inboundProcessModal');
        }

        // 物流跟踪
        function trackShipment(poNumber) {
            location.href = 'procurement-tracking.html?id=' + poNumber;
        }

        // 删除采购单
        function deleteProcurement(poNumber) {
            if (confirm('确认删除采购单 ' + poNumber + ' 吗？\n\n此操作不可恢复！')) {
                alert('❌ 采购单已删除');
            }
        }

        // 导出数据
        function exportData() {
            alert('📥 正在导出采购数据...\n\n文件格式: Excel\n文件名: 采购订单列表_' + new Date().toLocaleDateString() + '.xlsx');
        }

        // 快捷工具函数
        function priceComparison() {
            document.getElementById('priceComparisonModal').classList.add('active');
        }

        function batchImport() {
            document.getElementById('batchImportModal').classList.add('active');
        }

        function costAnalysis() {
            document.getElementById('costAnalysisModal').classList.add('active');
        }

        function demandForecast() {
            document.getElementById('demandForecastModal').classList.add('active');
        }

        function inventoryAlert() {
            document.getElementById('inventoryAlertModal').classList.add('active');
        }

        function reportGeneration() {
            document.getElementById('reportGenerationModal').classList.add('active');
        }

        // 关闭快捷工具modal
        function closeToolModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }

        // 点击modal外部关闭
        document.addEventListener('DOMContentLoaded', function() {
            const modals = ['approveProcurementModal', 'inboundProcessModal'];
            modals.forEach(modalId => {
                const modal = document.getElementById(modalId);
                if (modal) {
                    modal.addEventListener('click', function(e) {
                        if (e.target === this) {
                            closeModal(modalId);
                        }
                    });
                }
            });
        });

        document.getElementById('procurementModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeProcurementModal();
            }
        });
    
        // AI助手功能
        function openCodeAssistant() {
            document.getElementById('codeAssistantModal').classList.add('active');
        }

        function closeCodeAssistant() {
            document.getElementById('codeAssistantModal').classList.remove('active');
        }

        function openPCBLayout() {
            document.getElementById('pcbLayoutModal').classList.add('active');
        }

