                                <div style="font-size: 12px; color: #999; margin-bottom: 4px;">标准价格</div>
                                <div style="font-size: 24px; font-weight: 700; color: #00890b;">¥${priceInfo.standardPrice.toFixed(2)}</div>
                            </div>
                            <div style="padding: 16px; background: #fff3e0; border-radius: 8px;">
                                <div style="font-size: 12px; color: #999; margin-bottom: 4px;">最近采购价</div>
                                <div style="font-size: 24px; font-weight: 700; color: #f57c00;">¥${priceInfo.recentPrice.toFixed(2)}</div>
                            </div>
