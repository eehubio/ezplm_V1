<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EZPLM - 采购管理</title>
    <link rel="stylesheet" href="common-styles.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f4f4f4; color: #3d4647; }
        .top-bar { background: white; height: 80px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); display: flex; align-items: center; justify-content: space-between; padding: 0 40px; position: sticky; top: 0; z-index: 1000; }
        .logo { font-size: 28px; font-weight: 800; color: #00890b; cursor: pointer; }
        .top-nav-links { display: flex; align-items: center; gap: 24px; }
        .top-nav-links a { color: #3d4647; text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s; }
        .top-nav-links a:hover { color: #00890b; }
        .top-bar-right { display: flex; align-items: center; gap: 16px; }
        .btn-primary { background: #00890b; color: white; border: none; padding: 12px 24px; border-radius: 6px; font-size: 14px; font-weight: 600; cursor: pointer; }
        .layout { display: flex; min-height: calc(100vh - 80px); }
        .sidebar { width: 260px; background: white; box-shadow: 2px 0 8px rgba(0,0,0,0.05); padding: 24px 0; }
        .nav-section-title { padding: 8px 24px; font-size: 12px; font-weight: 700; color: #999; text-transform: uppercase; }
        .nav-item { padding: 12px 24px; display: flex; align-items: center; gap: 12px; color: #3d4647; text-decoration: none; transition: all 0.2s; }
        .nav-item:hover { background: rgba(0, 137, 11, 0.05); color: #00890b; }
        .nav-item.active { background: rgba(0, 137, 11, 0.1); color: #00890b; font-weight: 600; border-right: 3px solid #00890b; }
        .main-content { flex: 1; padding: 32px; }
        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
        .stat-card { background: white; border-radius: 8px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .stat-value { font-size: 32px; font-weight: 800; color: #00890b; }
        .table-card { background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        table { width: 100%; border-collapse: collapse; }
        th { background: #f9f9f9; padding: 16px 12px; text-align: left; font-size: 13px; color: #666; font-weight: 700; border-bottom: 2px solid #e0e0e0; }
        td { padding: 16px 12px; font-size: 14px; border-bottom: 1px solid #f0f0f0; }
        .status-badge { padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: 600; }
        .status-draft { background: rgba(149, 165, 166, 0.1); color: #95a5a6; }
        .status-pending { background: rgba(255, 193, 7, 0.1); color: #f39c12; }
        .status-approved { background: rgba(0, 137, 11, 0.1); color: #00890b; }
        .status-received { background: rgba(52, 152, 219, 0.1); color: #3498db; }

        /* Modal样式 */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.active { display: flex; }
        .modal-content {
            background: white;
            border-radius: 12px;
            width: 90%;
            max-width: 700px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            animation: modalSlideIn 0.3s ease-out;
        }
        @keyframes modalSlideIn {
            from { opacity: 0; transform: translateY(-50px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .modal-header {
            padding: 24px 32px;
            border-bottom: 1px solid #e0e0e0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .modal-title { font-size: 20px; font-weight: 700; color: #3d4647; }
        .modal-close {
            background: none;
            border: none;
            font-size: 28px;
            color: #999;
            cursor: pointer;
            line-height: 1;
            transition: color 0.3s;
        }
        .modal-close:hover { color: #3d4647; }
        .modal-body { padding: 32px; }
        .form-group { margin-bottom: 24px; }
        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: #3d4647;
            margin-bottom: 8px;
        }
        .form-label.required::after { content: ' *'; color: #e74c3c; }
        .form-input, .form-select {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e0e0e0;
            border-radius: 6px;
            font-size: 14px;
            transition: border-color 0.3s;
        }
        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: #00890b;
        }
        .form-textarea {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e0e0e0;
            border-radius: 6px;
            font-size: 14px;
            min-height: 80px;
            resize: vertical;
            transition: border-color 0.3s;
        }
        .form-textarea:focus { outline: none; border-color: #00890b; }
        .modal-footer {
            padding: 20px 32px;
            border-top: 1px solid #e0e0e0;
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }
        .btn-cancel {
            background: white;
            color: #3d4647;
            border: 2px solid #e0e0e0;
            padding: 12px 24px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-cancel:hover { border-color: #999; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

        /* 功能模块卡片 */
        .function-modules {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 32px;
        }
        .module-card {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            cursor: pointer;
            transition: all 0.3s;
            border: 2px solid transparent;
        }
        .module-card:hover {
            border-color: #00890b;
            transform: translateY(-4px);
            box-shadow: 0 6px 20px rgba(0,137,11,0.15);
        }
        .module-icon {
            width: 56px;
            height: 56px;
            background: linear-gradient(135deg, #00890b, #00b96b);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin-bottom: 16px;
        }
        .module-title {
            font-size: 16px;
            font-weight: 700;
            color: #3d4647;
            margin-bottom: 8px;
        }
        .module-desc {
            font-size: 13px;
            color: #999;
            line-height: 1.5;
            margin-bottom: 12px;
        }
        .module-badge {
            background: rgba(0, 137, 11, 0.1);
            color: #00890b;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
            display: inline-block;
        }

        /* 供应商匹配通知 */
        .match-notification {
            padding: 16px;
            border-radius: 10px;
            margin-bottom: 12px;
            border: 2px solid #e0e0e0;
            cursor: pointer;
            transition: all 0.3s;
            background: white;
        }
        .match-notification:hover {
            border-color: #00890b;
            background: rgba(0, 137, 11, 0.02);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 137, 11, 0.1);
        }
        .match-notification:last-child {
            margin-bottom: 0;
        }

        /* 快捷工具 */
        .quick-tools {
            background: white;
            border-radius: 12px;
            padding: 20px 24px;
            margin-bottom: 32px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        .tools-title {
            font-size: 16px;
            font-weight: 700;
            color: #3d4647;
            margin-bottom: 16px;
        }
        .tools-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 12px;
        }
        .tool-btn {
            background: #f9f9f9;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            padding: 16px 12px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        .tool-btn:hover {
            background: rgba(0, 137, 11, 0.05);
            border-color: #00890b;
        }
        .tool-icon {
            font-size: 24px;
            margin-bottom: 8px;
        }
        .tool-label {
            font-size: 13px;
            color: #666;
            font-weight: 500;
        }

        /* AI助手按钮 */
        .ai-assistant-btn {
            background: white;
            border: 2px solid #00890b;
            color: #00890b;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .ai-assistant-btn:hover {
            background: #00890b;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0,137,11,0.2);
        }

                /* AI助手模态框 */
        .ai-modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: white;
            z-index: 9999;
        }
        .ai-modal-overlay.active {
            display: block;
        }
        .ai-modal-content {
            width: 100%;
            height: 100%;
            position: relative;
        }
        .ai-modal-close {
            position: fixed;
            top: 20px;
            right: 20px;
            background: #00890b;
            border: none;
            color: white;
            font-size: 28px;
            cursor: pointer;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(0,137,11,0.3);
            z-index: 10000;
            font-weight: 300;
            line-height: 1;
        }
        .ai-modal-close:hover {
            background: #006b09;
            transform: scale(1.1);
            box-shadow: 0 6px 20px rgba(0,137,11,0.4);
        }
        .ai-modal-body {
            width: 100%;
            height: 100%;
        }
    
        /* Responsive Grid Support */
        @media (max-width: 768px) {
            .features-grid,
            .pricing-grid,
            .use-cases-grid,
            .benefits-container,
            .footer-container {
                grid-template-columns: 1fr !important;
            }

            .hero-stats {
                grid-template-columns: 1fr !important;
            }
        }

        @media (max-width: 1024px) and (min-width: 769px) {
            .features-grid {
                grid-template-columns: repeat(2, 1fr) !important;
            }

            .pricing-grid {
                grid-template-columns: repeat(2, 1fr) !important;
            }
        }

    
        /* Responsive Typography */
        @media (max-width: 768px) {
            .hero h1 {
                font-size: 36px !important;
            }

            .section-header h2,
            .benefits-content h2,
            .cta h2 {
                font-size: 32px !important;
            }

            .hero p {
                font-size: 16px !important;
            }

            .section-header p,
            .cta p {
                font-size: 16px !important;
            }

            .nav-container {
                padding: 0 20px !important;
            }

            .hero,
            .features,
            .benefits,
            .pricing,
            .use-cases,
            .cta {
                padding: 60px 20px !important;
            }
        }

        @media (max-width: 480px) {
            .hero h1 {
                font-size: 28px !important;
            }

            .btn {
                padding: 10px 20px !important;
                font-size: 13px !important;
            }

            .hero-actions {
                flex-direction: column !important;
                width: 100%;
            }

            .hero-actions .btn {
                width: 100%;
            }
        }

    </style>
</head>
<body>
            <!-- 顶部导航栏 -->
    <div class="top-bar">
        <div class="logo" onclick="location.href='index.html'">EZPLM</div>
        <div class="top-bar-right">
            <div class="top-nav-links">
                <a href="cloud-search.html">🌐 云端元器件库</a>
                <a href="reference-designs.html">📚 参考设计库</a>
                <a href="ai_coding_embedded.html">🤖 编程助手</a>
                <a href="pcb-editor-styled.html">📐 PCB预布局</a>
            </div>
            <button style="background: none; border: none; cursor: pointer; font-size: 20px; position: relative;" onclick="location.href='notification-center.html'" title="消息">
                🔔
                <span style="position: absolute; top: -4px; right: -4px; background: #ff6b6b; color: white; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 10px;">15</span>
            </button>
            <div style="width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, #00890b 0%, #00b30e 100%); color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; cursor: pointer;" onclick="location.href='profile.html'" title="账号">用</div>
        </div>
    </div>
    </div>

    <div class="layout">
                                <!-- 侧边栏 -->
        <div class="sidebar">
            <div class="nav-section">
                <div class="nav-section-title">工作台</div>
                <a href="dashboard-pro.html" class="nav-item">
                    <span class="nav-icon">📊</span>
                    <span>看板</span>
                </a>
                <a href="approval-center.html" class="nav-item">
                    <span class="nav-icon">✅</span>
                    <span>审批</span>
                    <span style="background: #4dabf7; color: white; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 10px; margin-left: auto;">8</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">项目</div>
                <a href="projects.html" class="nav-item">
                    <span class="nav-icon">📋</span>
                    <span>项目管理</span>
                </a>
                <a href="tasks.html" class="nav-item">
                    <span class="nav-icon">✅</span>
                    <span>任务中心</span>
                </a>
                <a href="collaboration.html" class="nav-item">
                    <span class="nav-icon">👥</span>
                    <span>团队协作</span>
                </a>
                <a href="bom.html" class="nav-item">
                    <span class="nav-icon">📝</span>
                    <span>BOM管理</span>
                </a>
                <a href="engineering-change.html" class="nav-item">
                    <span class="nav-icon">🔄</span>
                    <span>工程变更</span>
                </a>
                <a href="library-resources.html" class="nav-item">
                    <span class="nav-icon">📚</span>
                    <span>文档管理</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">物料</div>
                <a href="materials.html" class="nav-item">
                    <span class="nav-icon">📦</span>
                    <span>物料管理</span>
                </a>
                <a href="inventory.html" class="nav-item">
                    <span class="nav-icon">📊</span>
                    <span>库存管理</span>
                </a>
                <a href="procurement.html" class="nav-item active">
                    <span class="nav-icon">🛒</span>
                    <span>采购管理</span>
                </a>
                <a href="production.html" class="nav-item">
                    <span class="nav-icon">🏭</span>
                    <span>生产管理</span>
                </a>
                <a href="sales.html" class="nav-item">
                    <span class="nav-icon">💰</span>
                    <span>销售管理</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">业务</div>
                <a href="activities.html" class="nav-item">
                    <span class="nav-icon">🎯</span>
                    <span>竞赛/活动</span>
                </a>
                <a href="education.html" class="nav-item">
                    <span class="nav-icon">🎓</span>
                    <span>教学/实验</span>
                </a>
                <a href="outsourcing-hub.html" class="nav-item">
                    <span class="nav-icon">💼</span>
                    <span>外包/毕设</span>
                </a>
                <a href="campus-recruitment.html" class="nav-item">
                    <span class="nav-icon">🎓</span>
                    <span>校园招聘</span>
                </a>
                <a href="component-supply.html" class="nav-item">
                    <span class="nav-icon">🏪</span>
