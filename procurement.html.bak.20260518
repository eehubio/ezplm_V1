                                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">状态</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <input type="checkbox" class="batch-item-check" data-amount="2850" onchange="updateBatchCount()" checked>
                                    </td>
                                    <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
                                        <div style="font-weight: 600; margin-bottom: 4px;">STM32F103C8T6 MCU芯片</div>
