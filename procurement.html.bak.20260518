                </a>
                <a href="board-marketplace.html" class="nav-item">
                    <span class="nav-icon">🛍️</span>
                    <span>板卡商城</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">系统</div>
                <a href="supplier-management.html" class="nav-item">
                    <span class="nav-icon">🏢</span>
                    <span>厂商管理</span>
                </a>
                <a href="category-management.html" class="nav-item">
                    <span class="nav-icon">🏷️</span>
                    <span>分类管理</span>
                </a>
                <a href="numbering-rules.html" class="nav-item">
                    <span class="nav-icon">🔢</span>
                    <span>编号规则</span>
                </a>
                <a href="organization-settings.html" class="nav-item">
                    <span class="nav-icon">🏛️</span>
                    <span>组织管理</span>
                </a>
                <a href="settings.html" class="nav-item">
                    <span class="nav-icon">⚙️</span>
                    <span>系统设置</span>
                </a>
            </div>

        </div>

        <div class="main-content">
            <!-- 工具栏 -->
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; background: white; padding: 20px 24px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                <h2 style="font-size: 24px; font-weight: 700; color: #3d4647; margin: 0;">采购管理</h2>
                <button class="btn-primary" onclick="openProcurementModal()" style="display: flex; align-items: center; gap: 8px;">
                    <span style="font-size: 18px;">+</span>
                    <span>新建采购单</span>
                </button>
            </div>

            <div class="stats-grid">
                <div class="stat-card"><div style="font-size: 14px; color: #666; margin-bottom: 16px;">待审批采购单</div><div class="stat-value">5</div></div>
                <div class="stat-card"><div style="font-size: 14px; color: #666; margin-bottom: 16px;">进行中订单</div><div class="stat-value">12</div></div>
                <div class="stat-card"><div style="font-size: 14px; color: #666; margin-bottom: 16px;">本月采购额</div><div class="stat-value">¥8.5万</div></div>
                <div class="stat-card"><div style="font-size: 14px; color: #666; margin-bottom: 16px;">待收货订单</div><div class="stat-value">8</div></div>
            </div>

            <!-- 供应商物料匹配通知 -->
            <div style="margin-bottom: 24px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                    <h3 style="font-size: 18px; font-weight: 700; color: #3d4647; margin: 0; display: flex; align-items: center; gap: 8px;">
                        <span>🔔</span>
                        <span>供应商物料匹配推送</span>
                        <span style="background: #ff4757; color: white; font-size: 12px; padding: 2px 8px; border-radius: 10px; font-weight: 600;">3 条新消息</span>
                    </h3>
                    <button onclick="clearAllMatches()" style="padding: 8px 16px; background: white; border: 2px solid #e0e0e0; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; color: #666;">
                        清空已读
                    </button>
                </div>

                <div style="background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                    <div id="supplierMatchList">
                        <!-- 匹配通知列表 -->
                        <div class="match-notification" onclick="viewMatchDetail(1)">
                            <div style="display: flex; align-items: start; gap: 16px;">
                                <div style="width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; color: white; font-size: 20px; flex-shrink: 0;">
                                    🏪
                                </div>
                                <div style="flex: 1;">
                                    <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 8px;">
                                        <div>
                                            <h4 style="font-size: 16px; font-weight: 700; color: #3d4647; margin-bottom: 4px;">深圳华强电子提供 STM32F407VGT6</h4>
                                            <p style="font-size: 13px; color: #666; margin: 0;">匹配项目: 智能手环 V2.0 • BOM编号: BOM-2024-0156</p>
                                        </div>
                                        <span style="background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 600; white-space: nowrap;">新匹配</span>
                                    </div>
                                    <div style="display: flex; gap: 24px; margin-bottom: 12px;">
                                        <div style="font-size: 13px;">
                                            <span style="color: #999;">价格:</span>
                                            <span style="color: #00890b; font-weight: 700; margin-left: 4px;">¥32.50/片</span>
                                        </div>
                                        <div style="font-size: 13px;">
                                            <span style="color: #999;">MOQ:</span>
                                            <span style="font-weight: 600; margin-left: 4px;">100片</span>
                                        </div>
                                        <div style="font-size: 13px;">
                                            <span style="color: #999;">库存:</span>
                                            <span style="color: #00890b; font-weight: 600; margin-left: 4px;">5,000片</span>
                                        </div>
                                        <div style="font-size: 13px;">
                                            <span style="color: #999;">交期:</span>
                                            <span style="font-weight: 600; margin-left: 4px;">3-5天</span>
                                        </div>
                                    </div>
                                    <div style="font-size: 12px; color: #999;">
                                        发布时间: 2小时前
                                    </div>
                                </div>
