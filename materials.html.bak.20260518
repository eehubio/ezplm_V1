        // ==================== PDF数据手册问答功能 ====================
        let currentPDFDatasheet = null;
        let pdfQAConversationHistory = [];

        // 打开PDF数据手册问答界面
        function openPDFDatasheetQA(material) {
            console.log('打开PDF数据手册问答:', material);

            // 隐藏功能选择和其他结果
            document.getElementById('aiAnalysisFunctions').style.display = 'none';
            document.getElementById('materialAIResult').style.display = 'none';
            document.getElementById('pdfDatasheetQA').style.display = 'block';

            // 设置当前物料信息
            document.getElementById('pdfQAMaterialName').textContent = `${material.mpn} - ${material.name}`;

            // 重置对话历史
            pdfQAConversationHistory = [];
            document.getElementById('pdfQAMessages').innerHTML = '';

            // 直接使用元器件的数据手册，隐藏上传区域
            currentPDFDatasheet = {
                name: material.mpn + '_datasheet.pdf',
                material: material
            };

            document.getElementById('pdfUploadSection').style.display = 'none';
            document.getElementById('pdfUploadedInfo').style.display = 'block';
            document.getElementById('pdfFileName').textContent = `${material.mpn} 官方数据手册`;
            document.getElementById('pdfQAConversation').style.display = 'block';
            document.getElementById('pdfQAInputSection').style.display = 'block';

            // 显示AI欢迎消息
            addAIMessage(`您好！我已经加载了 ${material.mpn} 的官方数据手册。您可以向我提出任何关于这个元器件的问题，我会基于数据手册内容为您详细解答。`);

            // 滚动到顶部
            document.querySelector('#tab-ai-assistant').scrollTop = 0;
        }

        // 关闭PDF问答界面
        function closePDFDatasheetQA() {
            document.getElementById('pdfDatasheetQA').style.display = 'none';
            document.getElementById('aiAnalysisFunctions').style.display = 'grid';

            // 重置状态
            currentPDFDatasheet = null;
            pdfQAConversationHistory = [];
            document.getElementById('pdfUploadSection').style.display = 'block';
            document.getElementById('pdfUploadedInfo').style.display = 'none';
            document.getElementById('pdfQAConversation').style.display = 'none';
            document.getElementById('pdfQAInputSection').style.display = 'none';
            document.getElementById('pdfQuestionInput').value = '';
        }

        // 处理PDF上传
        function handlePDFDatasheetUpload(event) {
            const file = event.target.files[0];
            if (!file) return;

            if (file.type !== 'application/pdf') {
                alert('⚠️ 请上传PDF格式的文件！');
                return;
            }

            if (file.size > 50 * 1024 * 1024) {
                alert('⚠️ 文件大小超过50MB限制！');
                return;
            }

            // 模拟上传和解析过程
            currentPDFDatasheet = file;

            // 显示上传成功
            document.getElementById('pdfUploadSection').style.display = 'none';
            document.getElementById('pdfUploadedInfo').style.display = 'block';
            document.getElementById('pdfFileName').textContent = `${file.name} (${(file.size / 1024 / 1024).toFixed(2)} MB)`;

            // 显示对话区和输入区
            document.getElementById('pdfQAConversation').style.display = 'block';
            document.getElementById('pdfQAInputSection').style.display = 'block';

            // 显示AI欢迎消息
            addAIMessage('您好！我已经成功解读了这份数据手册。您可以向我提出任何关于这个元器件的问题，我会基于数据手册内容为您解答。');

            alert('✅ PDF数据手册上传成功！\n\nAI已准备好回答您的问题。');
        }

        // 移除PDF
        function removePDFDatasheet() {
            if (confirm('确认移除当前的PDF数据手册吗？\n\n对话历史也将被清空。')) {
                currentPDFDatasheet = null;
                pdfQAConversationHistory = [];

                document.getElementById('pdfUploadSection').style.display = 'block';
                document.getElementById('pdfUploadedInfo').style.display = 'none';
                document.getElementById('pdfQAConversation').style.display = 'none';
                document.getElementById('pdfQAInputSection').style.display = 'none';
                document.getElementById('pdfQAMessages').innerHTML = '';
                document.getElementById('pdfQuestionInput').value = '';
                document.getElementById('pdfDatasheetFile').value = '';
            }
        }

        // 快速提问（点击推荐问题）
        function askPDFQuestion(question) {
            document.getElementById('pdfQuestionInput').value = question;
            submitPDFQuestion();
        }

        // 提交问题
        function submitPDFQuestion() {
            const questionInput = document.getElementById('pdfQuestionInput');
            const question = questionInput.value.trim();

            if (!question) {
                alert('⚠️ 请输入您的问题！');
                return;
            }

            if (!currentPDFDatasheet) {
                alert('⚠️ 请先上传PDF数据手册！');
                return;
            }

            // 添加用户问题到对话
            addUserMessage(question);

            // 清空输入框
            questionInput.value = '';
            updateCharCount();

            // 显示AI思考中
            const thinkingId = addAIThinking();

            // 模拟AI回答（实际应用中调用后端API）
            setTimeout(() => {
                removeAIThinking(thinkingId);
                const answer = generatePDFAnswer(question);
                addAIMessage(answer);
            }, 2000);
        }

        // 生成AI回答（模拟）
        function generatePDFAnswer(question) {
            // 这里根据问题生成不同的回答
            const answers = {
                '主要参数': `根据数据手册，该芯片的主要参数如下：

**电气特性：**
• 工作电压范围：2.7V - 5.5V
• 工作电流：<250μA（典型值）
• 待机电流：<1μA
• 输出电流能力：最大25mA

**性能参数：**
• 分辨率：12位
• 采样率：最高200kSPS
• 通道数：8路单端或4路差分
• 接口：I²C/SPI可选

**环境参数：**
• 工作温度：-40°C to +125°C
• 存储温度：-65°C to +150°C`,

                '应用场景': `该芯片适用于以下典型应用场景：

**工业应用：**
• 过程控制和传感器接口
• 数据采集系统
• 工业自动化设备
• 智能仪表

**消费电子：**
• 便携式医疗设备
• 智能家居传感器
• 可穿戴设备
• 智能手表/手环

**其他应用：**
• 环境监测系统
• 汽车电子（符合AEC-Q100）
• 电池管理系统
• 测试测量设备`,

                '电压': `根据数据手册第5页的Electrical Characteristics部分：

**供电电压（VDD）：**
• 最小值：2.7V
• 典型值：3.3V 或 5.0V
• 最大值：5.5V

**模拟输入电压范围：**
• 单端模式：0 to VDD
• 差分模式：±VDD

**逻辑电平：**
• VIH (高电平输入)：0.7×VDD
• VIL (低电平输入)：0.3×VDD

⚠️ **注意事项：**
在使用时务必确保电源电压稳定，建议在VDD引脚附近放置100nF和10μF退耦电容。`,

                '外围电路': `根据数据手册第12-14页的典型应用电路，需要以下外围电路：

**必需元件：**
1. 电源退耦电容
   • C1：100nF（陶瓷，X7R）
   • C2：10μF（陶瓷或钽电容）
   • 放置位置：尽可能靠近VDD引脚

2. 参考电压电容
   • C3：1μF（陶瓷，X7R）
   • 连接到VREF引脚

3. I²C上拉电阻
   • R1, R2：4.7kΩ
   • 连接SDA和SCL到VDD

**可选元件：**
1. RC滤波器
   • 用于模拟输入信号滤波
   • 推荐值：R=100Ω, C=100nF

2. ESD保护
   • TVS二极管或保护阵列
   • 用于保护输入引脚

**PCB布局建议：**
• 保持模拟地和数字地分离
• 电源和地平面连续完整
• 信号走线避免跨越分割`,

                '封装': `该芯片提供以下封装选项：

**封装类型：**

1. **TSSOP-16** (推荐用于一般应用)
   • 引脚数：16
   • 封装尺寸：5.0mm × 4.4mm
   • 引脚间距：0.65mm
   • 焊盘面积：适中

2. **QFN-16** (推荐用于空间受限应用)
   • 引脚数：16 + 1个散热焊盘
   • 封装尺寸：3.0mm × 3.0mm
   • 引脚间距：0.5mm
   • 优点：体积小，散热好

**引脚定义：** (以TSSOP-16为例)
• Pin 1: VDD (电源)
• Pin 2-3: AIN0, AIN1 (模拟输入)
• Pin 4-7: AIN2-AIN5
• Pin 8: GND (地)
• Pin 9-10: SDA, SCL (I²C接口)
• Pin 11-12: ADDR, ALERT (地址/告警)
• Pin 13-16: AIN6, AIN7, VREF, GND

📄 详细引脚功能请参考数据手册第6-7页的Pin Configuration部分。`
            };

            // 根据问题关键词匹配答案
            if (question.includes('参数') || question.includes('特性')) {
                return answers['主要参数'];
            } else if (question.includes('应用') || question.includes('场景')) {
                return answers['应用场景'];
            } else if (question.includes('电压') || question.includes('供电')) {
                return answers['电压'];
            } else if (question.includes('外围') || question.includes('电路')) {
                return answers['外围电路'];
            } else if (question.includes('封装') || question.includes('引脚')) {
                return answers['封装'];
            } else {
                // 默认回答
                return `根据PDF数据手册的内容分析，关于"${question}"的信息如下：

基于数据手册第X页的描述，该参数/特性的详细说明为...

如果您需要更具体的信息，可以提出更详细的问题，例如：
• "工作电压范围是多少？"
• "这个芯片的典型应用场景有哪些？"
• "需要哪些外围电路？"

我会基于数据手册为您提供准确的答案。`;
            }
        }

        // 添加用户消息
        function addUserMessage(text) {
            const messagesContainer = document.getElementById('pdfQAMessages');
            const messageDiv = document.createElement('div');
            messageDiv.style.marginBottom = '16px';
            messageDiv.innerHTML = `
                <div style="display: flex; justify-content: flex-end; margin-bottom: 8px;">
                    <div style="background: #00890b; color: white; padding: 12px 16px; border-radius: 12px 12px 0 12px; max-width: 70%;">
                        <div style="font-size: 14px; line-height: 1.6;">${text}</div>
                    </div>
                </div>
            `;
            messagesContainer.appendChild(messageDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;

            // 保存到历史
            pdfQAConversationHistory.push({ role: 'user', text, time: new Date() });
        }

        // 添加AI消息
        function addAIMessage(text) {
            const messagesContainer = document.getElementById('pdfQAMessages');
            const messageDiv = document.createElement('div');
            messageDiv.style.marginBottom = '16px';
            messageDiv.innerHTML = `
                <div style="display: flex; gap: 12px; margin-bottom: 8px;">
                    <div style="flex-shrink: 0; width: 36px; height: 36px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px;">
                        🤖
                    </div>
                    <div style="background: #f9f9f9; padding: 12px 16px; border-radius: 0 12px 12px 12px; max-width: 70%; border: 1px solid #e0e0e0;">
                        <div style="font-size: 14px; line-height: 1.6; white-space: pre-line;">${text}</div>
                    </div>
                </div>
            `;
            messagesContainer.appendChild(messageDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;

            // 保存到历史
            pdfQAConversationHistory.push({ role: 'ai', text, time: new Date() });
        }

        // 添加AI思考中提示
        function addAIThinking() {
            const messagesContainer = document.getElementById('pdfQAMessages');
            const thinkingDiv = document.createElement('div');
            const thinkingId = 'thinking-' + Date.now();
            thinkingDiv.id = thinkingId;
            thinkingDiv.style.marginBottom = '16px';
            thinkingDiv.innerHTML = `
                <div style="display: flex; gap: 12px;">
                    <div style="flex-shrink: 0; width: 36px; height: 36px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; animation: pulse 1.5s ease-in-out infinite;">
                        🤖
                    </div>
                    <div style="background: #f9f9f9; padding: 12px 16px; border-radius: 0 12px 12px 12px; border: 1px solid #e0e0e0;">
                        <div style="font-size: 14px; color: #999;">
                            <span style="display: inline-block; animation: blink 1.4s infinite;">AI正在分析数据手册</span>
                            <span style="animation: dots 1.4s infinite;">...</span>
                        </div>
                    </div>
                </div>
                <style>
                    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
                    @keyframes dots { 0%, 20% { content: '.'; } 40% { content: '..'; } 60%, 100% { content: '...'; } }
                </style>
            `;
            messagesContainer.appendChild(thinkingDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
            return thinkingId;
        }

        // 移除AI思考提示
        function removeAIThinking(thinkingId) {
            const thinkingDiv = document.getElementById(thinkingId);
            if (thinkingDiv) {
                thinkingDiv.remove();
            }
        }

        // 更新字符计数
        function updateCharCount() {
            const input = document.getElementById('pdfQuestionInput');
            const count = input.value.length;
            document.getElementById('questionCharCount').textContent = count;
        }

        // 监听输入框字符变化
        document.addEventListener('DOMContentLoaded', function() {
            const input = document.getElementById('pdfQuestionInput');
            if (input) {
                input.addEventListener('input', updateCharCount);
            }

            // 云端搜索框回车搜索
            const cloudSearchInput = document.getElementById('cloudSearchInput');
            if (cloudSearchInput) {
                cloudSearchInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        performCloudSearch();
                    }
                });
            }

            // ==================== 账号类型检测 ====================
            // 检测当前用户的账号类型，决定是否显示"从个人空间导入"功能
            // 在实际应用中，这个值应该从后端/session中获取
            // true = 组织账号，false = 个人账号
            const isOrganizationAccount = true; // 模拟：设置为true表示组织账号，false表示个人账号

            const personalSpaceImportSection = document.getElementById('personalSpaceImport');
            if (personalSpaceImportSection) {
                if (isOrganizationAccount) {
                    // 组织账号：显示从个人空间导入功能
                    personalSpaceImportSection.style.display = 'block';
                } else {
                    // 个人账号：隐藏从个人空间导入功能
                    personalSpaceImportSection.style.display = 'none';
                }
            }
        });

        // ==================== 云端物料查询功能 ====================
        let cloudSearchResultsData = [];

        // 打开云端查询
        function openCloudSearch() {
            document.getElementById('cloudSearchModal').classList.add('active');
            // 重置搜索状态
            document.getElementById('cloudSearchInput').value = '';
            document.getElementById('cloudSearchEmpty').style.display = 'block';
            document.getElementById('cloudSearchList').style.display = 'none';
            document.getElementById('cloudSearchLoading').style.display = 'none';
        }

        // 关闭云端查询
        function closeCloudSearch() {
            document.getElementById('cloudSearchModal').classList.remove('active');
            cloudSearchResultsData = [];
        }

        // 执行云端搜索
        function performCloudSearch() {
            const keyword = document.getElementById('cloudSearchInput').value.trim();

            if (!keyword) {
                alert('⚠️ 请输入搜索关键词！');
                return;
            }

            // 显示加载状态
            document.getElementById('cloudSearchEmpty').style.display = 'none';
            document.getElementById('cloudSearchList').style.display = 'none';
            document.getElementById('cloudSearchLoading').style.display = 'block';

            // 模拟云端API调用
            setTimeout(() => {
                // 模拟搜索结果
                cloudSearchResultsData = generateMockCloudSearchResults(keyword);

                // 显示结果
                document.getElementById('cloudSearchLoading').style.display = 'none';
                document.getElementById('cloudSearchList').style.display = 'block';
                document.getElementById('cloudSearchCount').textContent = `找到 ${cloudSearchResultsData.length} 条结果`;

                renderCloudSearchResults();
            }, 1500);
        }

