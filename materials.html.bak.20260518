        // ==================== 替代件管理功能 ====================

        // 打开添加替代件对话框
        function openAddAlternativeDialog() {
            document.getElementById('addAlternativeModal').classList.add('active');
            document.getElementById('altSearchInput').value = '';
            document.getElementById('altSearchResults').style.display = 'none';
            document.getElementById('altDetailSettings').style.display = 'none';
            document.getElementById('saveAltBtn').disabled = true;
        }

        // 关闭添加替代件对话框
        function closeAddAlternativeModal() {
            document.getElementById('addAlternativeModal').classList.remove('active');
        }

        // 搜索替代件物料
        function searchAlternativeMaterials() {
            const searchTerm = document.getElementById('altSearchInput').value.trim();
            if (!searchTerm) {
                alert('请输入搜索关键词');
                return;
            }

            // 模拟搜索结果
            const results = materialsData.filter(m =>
                m.mpn.toLowerCase().includes(searchTerm.toLowerCase()) ||
                m.manufacturer.toLowerCase().includes(searchTerm.toLowerCase()) ||
                m.name.toLowerCase().includes(searchTerm.toLowerCase())
            );

            const resultList = document.getElementById('altSearchResultList');
            if (results.length === 0) {
                resultList.innerHTML = '<div style="padding: 20px; text-align: center; color: #999;">未找到匹配的物料</div>';
            } else {
                resultList.innerHTML = results.map(m => `
                    <div style="padding: 12px; border-bottom: 1px solid #f0f0f0; cursor: pointer; transition: all 0.2s;"
                         onmouseover="this.style.background='#f9f9f9'"
                         onmouseout="this.style.background='white'"
                         onclick="selectAlternativeMaterial(${m.id})">
                        <div style="font-weight: 600; color: #197bc0; margin-bottom: 4px;">${m.mpn}</div>
                        <div style="font-size: 12px; color: #666;">${m.manufacturer} | ${m.package}</div>
                    </div>
                `).join('');
            }

            document.getElementById('altSearchResults').style.display = 'block';
        }

        // 选择替代件物料
        function selectAlternativeMaterial(materialId) {
            const material = materialsData.find(m => m.id === materialId);
            if (!material) return;

            // 显示详细设置区域
            document.getElementById('altDetailSettings').style.display = 'block';
            document.getElementById('saveAltBtn').disabled = false;

            // 设置默认值
            document.getElementById('altPrice').value = material.suppliers && material.suppliers[0] ? material.suppliers[0].price : '';
            document.getElementById('altStock').value = material.stock || 0;

            // 保存选中的物料ID
            window.selectedAltMaterialId = materialId;
        }

        // 保存替代件
        function saveAlternative() {
            if (!window.selectedAltMaterialId) {
                alert('请先选择一个物料');
                return;
            }

            alert(`替代件添加成功！\n物料ID: ${window.selectedAltMaterialId}\n优先级: ${document.getElementById('altPriority').value}\n价格: ¥${document.getElementById('altPrice').value}`);
            closeAddAlternativeModal();

            // 刷新替代件列表
            if (window.currentDetailMaterialId) {
                loadAlternativesData(window.currentDetailMaterialId);
            }
        }

        // 加载替代件数据
        function loadAlternativesData(materialId) {
            const material = materialsData.find(m => m.id === materialId);
            if (!material || !material.alternatives) return;

            // 更新信息卡片
            document.getElementById('altMainPart').textContent = material.mpn;
            document.getElementById('altCount').textContent = material.alternatives.length + '个';

            // 计算最优价格和总库存
            let bestPrice = Infinity;
            let totalStock = 0;

            material.alternatives.forEach(alt => {
                const altMaterial = materialsData.find(m => m.mpn === alt.mpn);
                if (altMaterial) {
                    if (altMaterial.suppliers && altMaterial.suppliers[0]) {
                        bestPrice = Math.min(bestPrice, altMaterial.suppliers[0].price);
                    }
                    totalStock += altMaterial.stock || 0;
                }
            });

            document.getElementById('altBestPrice').textContent = bestPrice < Infinity ? `¥${bestPrice.toFixed(2)}` : '¥--';
            document.getElementById('altTotalStock').textContent = totalStock > 0 ? `${totalStock}片` : '--';

            // 渲染替代件表格
            const tbody = document.getElementById('alternativeTableBody');
            tbody.innerHTML = material.alternatives.map((alt, index) => {
                const altMaterial = materialsData.find(m => m.mpn === alt.mpn);
                const price = altMaterial && altMaterial.suppliers && altMaterial.suppliers[0] ? altMaterial.suppliers[0].price : 0;
                const stock = altMaterial ? altMaterial.stock : 0;

                // 价格对比
                const mainPrice = material.suppliers && material.suppliers[0] ? material.suppliers[0].price : 0;
                let priceClass = 'price-equal';
                let priceIcon = '➖';
                if (price < mainPrice) {
                    priceClass = 'price-lower';
                    priceIcon = '⬇';
                } else if (price > mainPrice) {
                    priceClass = 'price-higher';
                    priceIcon = '⬆';
                }

                // 库存状态
                let stockClass = 'stock-available';
                let stockIcon = '✅';
                if (stock === 0) {
                    stockClass = 'stock-out';
                    stockIcon = '❌';
                } else if (stock < 100) {
                    stockClass = 'stock-low';
                    stockIcon = '⚠️';
                }

                // 优先级
                const priorityClass = index === 0 ? 'priority-primary' : index === 1 ? 'priority-secondary' : 'priority-tertiary';
                const priorityText = index === 0 ? '主件' : index === 1 ? '备选1' : '备选2';

                return `
                    <tr>
                        <td><input type="checkbox" class="alt-checkbox" data-alt-id="${alt.mpn}"></td>
                        <td><span class="priority-badge ${priorityClass}">${priorityText}</span></td>
                        <td><strong>${alt.mpn}</strong></td>
                        <td>${alt.manufacturer}</td>
                        <td class="price-compare ${priceClass}">
                            <span>${priceIcon}</span>
                            <span>¥${price.toFixed(2)}</span>
                        </td>
                        <td class="stock-status ${stockClass}">
                            <span>${stockIcon}</span>
                            <span>${stock}片</span>
                        </td>
                        <td style="font-size: 12px; color: #666;">通用替代</td>
                        <td>
                            <button class="action-btn" onclick="editAlternative('${alt.mpn}')" title="编辑">✏️</button>
                            <button class="action-btn" onclick="removeAlternative('${alt.mpn}')" title="删除" style="color: #e74c3c;">🗑️</button>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        // 全选/取消全选替代件
        function toggleSelectAllAlts() {
            const selectAll = document.getElementById('selectAllAlts').checked;
            document.querySelectorAll('.alt-checkbox').forEach(cb => {
                cb.checked = selectAll;
            });
            updateAltSelectionCount();
        }

        // 更新替代件选择计数
        function updateAltSelectionCount() {
            const count = document.querySelectorAll('.alt-checkbox:checked').length;
            document.getElementById('selectedAltCount').textContent = count;
            document.getElementById('comparisonBar').classList.toggle('active', count > 0);
        }

        // 清除替代件选择
        function clearAltSelection() {
            document.querySelectorAll('.alt-checkbox').forEach(cb => {
                cb.checked = false;
            });
            document.getElementById('selectAllAlts').checked = false;
            updateAltSelectionCount();
        }

        // 对比替代件（从物料详情modal）
        function compareAlternatives() {
            const selectedCheckboxes = Array.from(document.querySelectorAll('.alt-checkbox:checked'));

            if (selectedCheckboxes.length === 0) {
                alert('请至少选择一个替代件进行对比');
                return;
            }

            // 获取当前查看的物料
            const material = materialsData.find(m => m.id === currentDetailMaterialId);
            if (!material || !material.alternatives) return;

            // 获取选中的替代件
            const selectedAlts = selectedCheckboxes.map(cb => {
                const altId = cb.getAttribute('data-alt-id');
                return material.alternatives.find(alt => alt.mpn === altId);
            }).filter(alt => alt);

            if (selectedAlts.length === 0) {
                alert('未找到选中的替代件数据');
                return;
            }

            // 设置对比数据
            currentCompareAlts = selectedAlts;
            currentCompareOriginalMaterial = material;
            currentCompareDimension = 'all';

            // 更新对比数量
            document.getElementById('compareItemCount').textContent = selectedAlts.length;
            document.getElementById('currentMaterialForCompare').textContent = material.mpn;

            // 分析最佳选择
            let bestIndex = 0;
            let bestScore = 0;
            selectedAlts.forEach((alt, i) => {
                const score = (alt.similarity || 85) * 0.4 +
                             ((material.price - alt.price) / material.price * 100) * 0.3 +
                             (alt.stockStatus === 'available' ? 30 : alt.stockStatus === 'low' ? 15 : 0);
                if (score > bestScore) {
                    bestScore = score;
                    bestIndex = i + 1;
                }
            });
            document.getElementById('bestChoiceIndex').textContent = bestIndex;

            // 渲染对比表格
            renderComparisonTable(material, selectedAlts);

            // 生成AI建议
            const bestAlt = selectedAlts[bestIndex - 1];
            const priceAdvantage = ((material.price - bestAlt.price) / material.price * 100).toFixed(1);
            document.getElementById('aiCompareAdvice').innerHTML = `
                根据综合评分，推荐选择替代件 <strong>#${bestIndex} (${bestAlt.mpn})</strong>，其在以下方面表现优秀：<br>
                • 参数相似度: ${bestAlt.similarity || 85}%<br>
                • 价格优势: ${priceAdvantage > 0 ? '节省' : '增加'} ${Math.abs(priceAdvantage).toFixed(1)}%<br>
                • 库存状态: ${bestAlt.stockStatus === 'available' ? '充足' : bestAlt.stockStatus === 'low' ? '一般' : '紧张'}
            `;

            // 显示对比模态框
            document.getElementById('compareAltsModal').classList.add('active');
        }

        // 编辑替代件
        function editAlternative(mpn) {
            alert(`编辑替代件：${mpn}`);
        }

        // 删除替代件
        function removeAlternative(mpn) {
            if (confirm(`确定要删除替代件 ${mpn} 吗？`)) {
                alert(`替代件 ${mpn} 已删除`);
            }
        }

        // ==================== 元零件组管理功能 ====================

        // 创建元零件组
        function createMetaPart() {
            document.getElementById('metaPartModal').classList.add('active');
            document.getElementById('metaPartName').value = '';
            document.getElementById('metaPartDesc').value = '';
            document.getElementById('metaPartSearchInput').value = '';
            document.getElementById('metaPartCount').textContent = '0';
            document.getElementById('metaPartList').innerHTML = `
                <div style="text-align: center; color: #999; padding: 40px 0;">
                    <div style="font-size: 48px; margin-bottom: 8px;">📦</div>
                    <div>暂无物料，请搜索并添加物料</div>
                </div>
            `;
        }

        // 关闭元零件组对话框
        function closeMetaPartModal() {
            document.getElementById('metaPartModal').classList.remove('active');
        }

        // 搜索元零件组物料
        function searchMetaPartMaterials() {
            const searchTerm = document.getElementById('metaPartSearchInput').value.trim();
            if (!searchTerm) {
                alert('请输入搜索关键词');
                return;
            }

            alert(`搜索物料：${searchTerm}\n\n此功能将显示匹配的物料列表供您添加到元零件组`);
        }

        // 保存元零件组
        function saveMetaPart() {
            const name = document.getElementById('metaPartName').value.trim();
            const desc = document.getElementById('metaPartDesc').value.trim();

            if (!name) {
                alert('请输入元零件组名称');
                return;
            }

            alert(`元零件组创建成功！\n\n组名：${name}\n描述：${desc || '无'}\n\n该功能可以将多个可互换物料归为一组，方便统一管理和智能推荐。`);
            closeMetaPartModal();
        }

        // ==================== 物料管理功能占位符 ====================

        // ==================== 管理替代件功能 ====================
        let currentManagingMaterialId = null;

        // 管理替代件
        function manageAlternatives(materialId) {
            currentManagingMaterialId = materialId;
            const material = materialsData.find(m => m.id === materialId);

            if (!material) {
                alert('未找到该物料信息！');
                return;
            }

            // 填充当前物料信息
            document.getElementById('currentMaterialName').textContent = material.mpn || '未知';
            document.getElementById('currentMaterialMfr').textContent = material.manufacturer || '未知';
            document.getElementById('currentMaterialCategory').textContent = material.category || '未知';
            document.getElementById('currentMaterialPrice').textContent = material.price ? material.price.toFixed(2) : '0.00';

            // 初始化替代件列表
            if (!material.alternatives) {
                material.alternatives = [];
            }

            // 显示替代件数量
            document.getElementById('altTotalCount').textContent = material.alternatives.length;

            // 渲染替代件表格
            renderAlternativesTable(material.alternatives);

            // 显示/隐藏空状态
            if (material.alternatives.length === 0) {
                document.getElementById('emptyAltsState').style.display = 'block';
                document.querySelector('#manageAlternativesModal table').style.display = 'none';
            } else {
                document.getElementById('emptyAltsState').style.display = 'none';
                document.querySelector('#manageAlternativesModal table').style.display = 'table';
            }

            // 重置选择状态 - 使用setTimeout确保DOM已更新
            document.getElementById('selectAllAlts').checked = false;
            setTimeout(() => {
                updateAltSelectionUI();
            }, 0);

            // 打开模态框
            document.getElementById('manageAlternativesModal').classList.add('active');
        }

        // 渲染替代件表格
        function renderAlternativesTable(alternatives) {
            const tbody = document.getElementById('alternativesTableBody');

            if (!alternatives || alternatives.length === 0) {
                tbody.innerHTML = '';
                return;
            }

            tbody.innerHTML = alternatives.map((alt, index) => {
                const priorityMap = {
                    'primary': { text: '主要', color: '#00890b', icon: '⭐' },
                    'secondary': { text: '次要', color: '#ff9800', icon: '⚡' },
                    'tertiary': { text: '备选', color: '#999', icon: '🔸' }
                };

                const priority = priorityMap[alt.priority || 'secondary'];

                const stockStatusMap = {
                    'available': { text: '有货', color: '#00890b' },
                    'low': { text: '低库存', color: '#ff9800' },
                    'out': { text: '缺货', color: '#e74c3c' }
                };

                const stockStatus = stockStatusMap[alt.stockStatus || 'available'];

                return `
                    <tr style="border-bottom: 1px solid #f0f0f0;">
                        <td style="padding: 12px;">
                            <input type="checkbox" class="alt-item-checkbox" data-index="${index}" onchange="updateAltSelectionUI()" style="width: 18px; height: 18px; cursor: pointer;">
                        </td>
                        <td style="padding: 12px;">
                            <div style="font-weight: 600; color: #3d4647;">${alt.mpn || '未知型号'}</div>
                        </td>
                        <td style="padding: 12px;">
                            <div style="color: #666;">${alt.manufacturer || '未知制造商'}</div>
                        </td>
                        <td style="padding: 12px;">
                            <span style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 12px; background: ${priority.color}15; color: ${priority.color}; border-radius: 12px; font-size: 12px; font-weight: 600;">
                                ${priority.icon} ${priority.text}
                            </span>
                        </td>
                        <td style="padding: 12px;">
                            <div style="font-weight: 600; color: #00890b;">¥${(alt.price || 0).toFixed(2)}</div>
                        </td>
                        <td style="padding: 12px;">
                            <span style="display: inline-block; padding: 4px 12px; background: ${stockStatus.color}15; color: ${stockStatus.color}; border-radius: 12px; font-size: 12px; font-weight: 600;">
                                ${stockStatus.text}
                            </span>
                        </td>
                        <td style="padding: 12px;">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <div style="flex: 1; height: 8px; background: #f0f0f0; border-radius: 4px; overflow: hidden;">
                                    <div style="width: ${alt.similarity || 85}%; height: 100%; background: linear-gradient(90deg, #00890b, #00b30e);"></div>
                                </div>
                                <span style="font-size: 12px; font-weight: 600; color: #00890b;">${alt.similarity || 85}%</span>
                            </div>
                        </td>
                        <td style="padding: 12px; text-align: center;">
                            <div style="display: flex; gap: 8px; justify-content: center;">
                                <button onclick="editAlternative(${index})" style="padding: 6px 12px; background: #197bc0; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">
                                    ✏️ 编辑
                                </button>
                                <button onclick="viewAltDetails(${index})" style="padding: 6px 12px; background: #f0f0f0; color: #3d4647; border: 1px solid #d0d0d0; border-radius: 4px; cursor: pointer; font-size: 12px;">
                                    👁️ 详情
                                </button>
                                <button onclick="deleteAlternative(${index})" style="padding: 6px 12px; background: #fee; color: #e74c3c; border: 1px solid #fcc; border-radius: 4px; cursor: pointer; font-size: 12px;">
                                    🗑️
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        // 关闭管理替代件模态框
        function closeManageAlternatives() {
            document.getElementById('manageAlternativesModal').classList.remove('active');
            currentManagingMaterialId = null;
        }

        // 从管理界面打开添加替代件模态框
        function openAddAlternativeModalFromManage() {
            // 打开添加替代件对话框
            openAddAlternativeDialog();
        }

        // 全选/取消全选
        function toggleSelectAllAlts() {
            const selectAll = document.getElementById('selectAllAlts').checked;
            document.querySelectorAll('.alt-item-checkbox').forEach(checkbox => {
                checkbox.checked = selectAll;
            });
            updateAltSelectionUI();
        }

        // 更新选择状态UI
        function updateAltSelectionUI() {
            const checkboxes = document.querySelectorAll('.alt-item-checkbox');
            const checkedCount = Array.from(checkboxes).filter(cb => cb.checked).length;

            // 更新选择信息
            const infoText = checkedCount > 0 ? `已选择 ${checkedCount} 个替代件` : '未选中任何项';
            document.getElementById('selectedAltsInfo').textContent = infoText;

            // 更新按钮状态
            document.getElementById('compareAltsBtn').disabled = checkedCount < 1;
            document.getElementById('deleteAltsBtn').disabled = checkedCount === 0;

            // 更新全选框状态
            document.getElementById('selectAllAlts').checked = checkedCount === checkboxes.length && checkedCount > 0;
        }

        // 对比选中的替代件
        let currentCompareAlts = [];
        let currentCompareOriginalMaterial = null;
        let currentCompareDimension = 'all';

        function compareSelectedAlts() {
            try {
                console.log('compareSelectedAlts() 函数被调用');

                const selected = Array.from(document.querySelectorAll('.alt-item-checkbox:checked'));
                console.log('选中的checkbox数量:', selected.length);

                if (selected.length === 0) {
                    alert('请至少选择一个替代件进行对比！');
                    return;
                }

                const material = materialsData.find(m => m.id === currentManagingMaterialId);
                console.log('当前物料:', material);

                if (!material) {
                    alert('未找到当前物料信息！');
                    return;
                }

                if (!material.alternatives || material.alternatives.length === 0) {
                    alert('当前物料没有替代件！');
                    return;
                }

                const selectedAlts = selected.map(cb => {
                    const index = parseInt(cb.dataset.index);
                    return material.alternatives[index];
                }).filter(alt => alt); // 过滤掉undefined的项

                console.log('选中的替代件:', selectedAlts);

                if (selectedAlts.length === 0) {
                    alert('未找到选中的替代件数据！');
                    return;
                }

                currentCompareAlts = selectedAlts;
                currentCompareOriginalMaterial = material;
                currentCompareDimension = 'all';

                // 更新对比数量
                document.getElementById('compareItemCount').textContent = selectedAlts.length;
                document.getElementById('currentMaterialForCompare').textContent = material.mpn;

                // 分析最佳选择 - 初始化为第一个替代件
                let bestIndex = 1;
                let bestScore = -Infinity;
                selectedAlts.forEach((alt, i) => {
                    const score = (alt.similarity || 85) * 0.4 +
                                 ((material.price - (alt.price || 0)) / (material.price || 1) * 100) * 0.3 +
                                 (alt.stockStatus === 'available' ? 30 : alt.stockStatus === 'low' ? 15 : 0);
                    console.log(`替代件 #${i + 1} (${alt.mpn}) 得分: ${score.toFixed(2)}`);
                    if (score > bestScore) {
                        bestScore = score;
                        bestIndex = i + 1;
                    }
                });
                console.log(`最佳选择: #${bestIndex}, 得分: ${bestScore.toFixed(2)}`);
                document.getElementById('bestChoiceIndex').textContent = bestIndex;

                // 渲染对比表格
                console.log('开始渲染对比表格');
                renderComparisonTable(material, selectedAlts);

                // 生成AI建议
                const bestAlt = selectedAlts[bestIndex - 1];
                console.log('最佳替代件:', bestAlt);

                if (!bestAlt) {
                    console.error('未找到最佳替代件！bestIndex:', bestIndex, 'selectedAlts.length:', selectedAlts.length);
                    alert('对比数据异常，请重试！');
                    return;
                }

                const priceAdvantage = ((material.price - (bestAlt.price || 0)) / (material.price || 1) * 100).toFixed(1);
                document.getElementById('aiCompareAdvice').innerHTML = `
                    根据综合评分，推荐选择替代件 <strong>#${bestIndex} (${bestAlt.mpn})</strong>，其在以下方面表现优秀：<br>
                    • 参数相似度: ${bestAlt.similarity || 85}%<br>
                    • 价格优势: ${priceAdvantage > 0 ? '节省' : '增加'} ${Math.abs(priceAdvantage).toFixed(1)}%<br>
                    • 库存状态: ${bestAlt.stockStatus === 'available' ? '充足' : bestAlt.stockStatus === 'low' ? '一般' : '紧张'}
                `;

                // 显示对比模态框
                console.log('打开对比模态框');
                document.getElementById('compareAltsModal').classList.add('active');

            } catch (error) {
                console.error('对比替代件时发生错误:', error);
                alert(`对比功能出错: ${error.message}\n\n请查看浏览器控制台获取详细信息`);
            }
        }

        // 渲染对比表格
        function renderComparisonTable(material, alternatives) {
            const table = document.getElementById('compareTable');
            const tbody = document.getElementById('compareTableBody');

            // 生成表头（添加替代件列）
            const thead = table.querySelector('thead tr');
            // 清除除了前两列之外的列
            while (thead.children.length > 2) {
                thead.removeChild(thead.lastChild);
            }

            alternatives.forEach((alt, i) => {
                const th = document.createElement('th');
                th.style.padding = '16px';
                th.style.textAlign = 'center';
                th.style.fontWeight = '600';
                th.style.background = '#f0f8ff';
                th.innerHTML = `
                    <div style="color: #197bc0; font-size: 16px; margin-bottom: 4px;">替代件 #${i + 1}</div>
                    <div style="font-size: 12px; font-weight: 400; color: #666;">${alt.mpn}</div>
                `;
                thead.appendChild(th);
            });

            // 生成对比行
            const comparisonRows = [
                {
                    label: '制造商',
                    getValue: (item) => item.manufacturer,
                    dimension: 'all'
                },
                {
                    label: '单价',
                    getValue: (item) => `¥${(item.price || 0).toFixed(2)}`,
                    getBest: (items) => {
                        let minPrice = Math.min(...items.map(i => i.price || 0));
                        return items.map(i => (i.price || 0) === minPrice);
                    },
                    dimension: 'price'
                },
                {
                    label: '价格差异',
                    getValue: (item, original) => {
                        const diff = ((item.price - original.price) / original.price * 100);
                        return `${diff > 0 ? '+' : ''}${diff.toFixed(1)}%`;
                    },
                    getColor: (item, original) => {
                        const diff = item.price - original.price;
                        return diff < 0 ? '#00890b' : diff > 0 ? '#e74c3c' : '#666';
                    },
                    dimension: 'price'
                },
                {
                    label: '库存状态',
                    getValue: (item) => {
                        const map = { 'available': '✅ 有货', 'low': '⚠️ 低库存', 'out': '❌ 缺货' };
                        return map[item.stockStatus] || '未知';
                    },
                    getBest: (items) => items.map(i => i.stockStatus === 'available'),
                    dimension: 'stock'
                },
                {
                    label: '库存数量',
                    getValue: (item) => (item.stock || 0).toLocaleString() + ' 件',
                    getBest: (items) => {
                        let maxStock = Math.max(...items.map(i => i.stock || 0));
                        return items.map(i => (i.stock || 0) === maxStock);
                    },
                    dimension: 'stock'
                },
                {
                    label: '参数相似度',
                    getValue: (item) => `${item.similarity || 85}%`,
                    getBest: (items) => {
                        let maxSim = Math.max(...items.map(i => i.similarity || 85));
                        return items.map(i => (i.similarity || 85) === maxSim);
                    },
                    dimension: 'params'
                },
                {
                    label: '优先级',
                    getValue: (item) => {
                        const map = { 'primary': '⭐ 主要', 'secondary': '⚡ 次要', 'tertiary': '🔸 备选' };
                        return map[item.priority] || '次要';
                    },
                    dimension: 'all'
                }
            ];

            tbody.innerHTML = comparisonRows.filter(row => {
                if (currentCompareDimension === 'all') return true;
                return row.dimension === currentCompareDimension || row.dimension === 'all';
            }).map(row => {
                const originalValue = row.getValue(material, material);
                const altValues = alternatives.map(alt => ({
                    value: row.getValue(alt, material),
                    color: row.getColor ? row.getColor(alt, material) : '#3d4647'
                }));

                const bestFlags = row.getBest ? row.getBest([material, ...alternatives]) : [];

                return `
                    <tr style="border-bottom: 1px solid #f0f0f0;">
                        <td style="padding: 16px; font-weight: 600; background: #fafafa;">${row.label}</td>
                        <td style="padding: 16px; text-align: center; background: #f9fff9; ${bestFlags[0] ? 'font-weight: 700; color: #00890b;' : ''}">
                            ${originalValue}
                            ${bestFlags[0] ? ' 🏆' : ''}
                        </td>
                        ${altValues.map((av, i) => `
                            <td style="padding: 16px; text-align: center; color: ${av.color}; ${bestFlags[i + 1] ? 'font-weight: 700; background: #f0f8ff;' : ''}">
                                ${av.value}
                                ${bestFlags[i + 1] ? ' 🏆' : ''}
                            </td>
                        `).join('')}
                    </tr>
                `;
            }).join('');
        }

        // 切换对比维度
        function switchCompareDimension(dimension) {
            currentCompareDimension = dimension;

            // 更新按钮状态
            document.querySelectorAll('.compare-dimension-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            document.querySelector(`[data-dimension="${dimension}"]`).classList.add('active');

            // 重新渲染表格
            renderComparisonTable(currentCompareOriginalMaterial, currentCompareAlts);
        }

        // 关闭对比模态框
        function closeCompareAlts() {
            document.getElementById('compareAltsModal').classList.remove('active');
            currentCompareAlts = [];
            currentCompareOriginalMaterial = null;
        }

        // 导出对比报告
        function exportCompareReport() {
            alert('📤 导出对比报告\n\n将生成包含以下内容的Excel报告:\n• 详细对比表格\n• 参数分析图表\n• AI推荐建议\n• 价格趋势分析\n\n报告将保存到下载文件夹。');
        }

        // 对比modal点击背景关闭
        document.getElementById('compareAltsModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeCompareAlts();
            }
        });

        // 删除选中的替代件
        function deleteSelectedAlts() {
            const selected = Array.from(document.querySelectorAll('.alt-item-checkbox:checked'));
            if (selected.length === 0) {
                alert('请选择要删除的替代件！');
                return;
            }

            if (!confirm(`确定要删除选中的 ${selected.length} 个替代件吗？`)) {
                return;
            }

            const material = materialsData.find(m => m.id === currentManagingMaterialId);

            // 获取要删除的索引（从大到小排序，避免删除时索引错乱）
            const indices = selected.map(cb => parseInt(cb.dataset.index)).sort((a, b) => b - a);

            // 删除替代件
            indices.forEach(index => {
                material.alternatives.splice(index, 1);
            });

            // 刷新显示
            manageAlternatives(currentManagingMaterialId);

            alert(`✅ 已成功删除 ${selected.length} 个替代件！`);
        }

        // 编辑替代件
        let currentEditingAltIndex = null;

        function editAlternative(index) {
            const material = materialsData.find(m => m.id === currentManagingMaterialId);
            const alt = material.alternatives[index];

            currentEditingAltIndex = index;

            // 填充表单
            document.getElementById('editAltMPN').value = alt.mpn || '';
            document.getElementById('editAltManufacturer').value = alt.manufacturer || '';
            document.getElementById('editAltPriority').value = alt.priority || 'secondary';
            document.getElementById('editAltPrice').value = alt.price || '';
            document.getElementById('editAltStock').value = alt.stock || '';
            document.getElementById('editAltStockStatus').value = alt.stockStatus || 'available';
            document.getElementById('editAltSimilarity').value = alt.similarity || 85;
            document.getElementById('editSimilarityValue').textContent = alt.similarity || 85;
            document.getElementById('editAltScenario').value = alt.scenario || '';

            // 显示模态框
            document.getElementById('editAlternativeModal').classList.add('active');
        }

        // 保存编辑的替代件
        function saveEditAlternative() {
            const mpn = document.getElementById('editAltMPN').value.trim();
            const manufacturer = document.getElementById('editAltManufacturer').value.trim();

            if (!mpn || !manufacturer) {
                alert('请填写型号和制造商！');
                return;
            }

            const material = materialsData.find(m => m.id === currentManagingMaterialId);
            const alt = material.alternatives[currentEditingAltIndex];

            // 更新替代件信息
            alt.mpn = mpn;
            alt.manufacturer = manufacturer;
            alt.priority = document.getElementById('editAltPriority').value;
            alt.price = parseFloat(document.getElementById('editAltPrice').value) || 0;
            alt.stock = parseInt(document.getElementById('editAltStock').value) || 0;
            alt.stockStatus = document.getElementById('editAltStockStatus').value;
            alt.similarity = parseInt(document.getElementById('editAltSimilarity').value) || 85;
            alt.scenario = document.getElementById('editAltScenario').value.trim();

            // 关闭模态框
            closeEditAlternative();

            // 刷新显示
            manageAlternatives(currentManagingMaterialId);

            alert('✅ 替代件信息已更新！');
        }

        // 关闭编辑替代件模态框
        function closeEditAlternative() {
            document.getElementById('editAlternativeModal').classList.remove('active');
            currentEditingAltIndex = null;
        }

        // 编辑替代件modal点击背景关闭
        document.getElementById('editAlternativeModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeEditAlternative();
            }
        });

        // 查看替代件详情
        let currentViewingAltIndex = null;

        function viewAltDetails(index) {
            const material = materialsData.find(m => m.id === currentManagingMaterialId);
            const alt = material.alternatives[index];

            currentViewingAltIndex = index;

            // 填充头部信息
            document.getElementById('viewAltMPN').textContent = alt.mpn || '未知型号';
            document.getElementById('viewAltManufacturer').textContent = alt.manufacturer || '未知制造商';
            document.getElementById('viewAltSimilarity').textContent = alt.similarity || 85;

            // 填充基本信息
            document.getElementById('viewAltMPNDetail').textContent = alt.mpn || '-';
            document.getElementById('viewAltManufacturerDetail').textContent = alt.manufacturer || '-';

            const priorityMap = {
                'primary': '⭐ 主要替代件',
                'secondary': '⚡ 次要替代件',
                'tertiary': '🔸 备选替代件'
            };
            document.getElementById('viewAltPriority').textContent = priorityMap[alt.priority] || '次要替代件';
            document.getElementById('viewAltPrice').textContent = `¥${(alt.price || 0).toFixed(2)}`;
            document.getElementById('viewAltStock').textContent = `${(alt.stock || 0).toLocaleString()} 件`;

            const statusMap = {
                'available': '✅ 有货',
                'low': '⚠️ 低库存',
                'out': '❌ 缺货'
            };
            document.getElementById('viewAltStockStatus').textContent = statusMap[alt.stockStatus] || '未知';

            // 应用场景
            if (alt.scenario) {
                document.getElementById('viewAltScenarioSection').style.display = 'block';
                document.getElementById('viewAltScenario').textContent = alt.scenario;
            } else {
                document.getElementById('viewAltScenarioSection').style.display = 'none';
            }

            // 对比原物料
            const priceDiff = alt.price - material.price;
            const priceDiffPercent = ((priceDiff / material.price) * 100).toFixed(1);
            const priceComparison = priceDiff < 0 ?
                `💰 价格更低，节省 <strong style="color: #00890b;">¥${Math.abs(priceDiff).toFixed(2)} (${Math.abs(priceDiffPercent)}%)</strong>` :
                priceDiff > 0 ?
                `💸 价格更高，增加 <strong style="color: #e74c3c;">¥${priceDiff.toFixed(2)} (+${priceDiffPercent}%)</strong>` :
                `💵 价格相同`;

            const stockComparison = alt.stockStatus === 'available' ?
                '📦 库存充足，供货稳定' :
                alt.stockStatus === 'low' ?
                '⚠️ 库存较低，需关注补货' :
                '❌ 当前缺货，谨慎选用';

            document.getElementById('viewAltComparison').innerHTML = `
                ${priceComparison}<br>
                ${stockComparison}<br>
                🔄 参数相似度: <strong>${alt.similarity || 85}%</strong>
            `;

            // 匹配分析
            document.getElementById('viewParamMatch').textContent = alt.similarity || 85;

            const priceAdvantage = priceDiff < 0 ? Math.abs(priceDiffPercent) : 0;
            document.getElementById('viewPriceAdvantage').textContent = priceAdvantage.toFixed(0);

            const stockLevelMap = {
                'available': '高',
                'low': '中',
                'out': '低'
            };
            document.getElementById('viewStockLevel').textContent = stockLevelMap[alt.stockStatus] || '未知';

            // 显示模态框
            document.getElementById('viewAltDetailsModal').classList.add('active');
        }

        // 从详情页面编辑替代件
        function editAlternativeFromView() {
            closeViewAltDetails();
            editAlternative(currentViewingAltIndex);
        }

        // 关闭查看替代件详情模态框
        function closeViewAltDetails() {
            document.getElementById('viewAltDetailsModal').classList.remove('active');
            currentViewingAltIndex = null;
        }

        // 查看替代件详情modal点击背景关闭
        document.getElementById('viewAltDetailsModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeViewAltDetails();
            }
        });

        // 删除单个替代件
        function deleteAlternative(index) {
            const material = materialsData.find(m => m.id === currentManagingMaterialId);
            const alt = material.alternatives[index];

            if (!confirm(`确定要删除替代件 "${alt.mpn}" 吗？`)) {
                return;
            }

            material.alternatives.splice(index, 1);
            manageAlternatives(currentManagingMaterialId);

            alert(`✅ 替代件 "${alt.mpn}" 已删除！`);
        }

        // AI智能推荐替代件
        function aiRecommendAlternatives() {
            const material = materialsData.find(m => m.id === currentManagingMaterialId);

            // 打开AI推荐模态框
            document.getElementById('aiRecommendAltsModal').classList.add('active');
            document.getElementById('aiAnalysisProgress').style.display = 'block';
            document.getElementById('aiRecommendResults').style.display = 'none';

            // 模拟AI分析过程
            const progressSteps = [
                { text: '正在搜索数据库...', progress: 20 },
                { text: '分析参数相似度...', progress: 40 },
                { text: '评估价格竞争力...', progress: 60 },
                { text: '检查库存可用性...', progress: 80 },
                { text: '生成推荐方案...', progress: 100 }
            ];

            let currentStep = 0;

            function updateProgress() {
                if (currentStep < progressSteps.length) {
                    const step = progressSteps[currentStep];
                    document.getElementById('aiProgressText').textContent = step.text;
                    document.getElementById('aiProgressBar').style.width = step.progress + '%';
                    currentStep++;
                    setTimeout(updateProgress, 600);
                } else {
                    // 分析完成，显示推荐结果
                    showAIRecommendResults(material);
                }
            }

            updateProgress();
        }

        // 显示AI推荐结果
        function showAIRecommendResults(material) {
            document.getElementById('aiAnalysisProgress').style.display = 'none';
            document.getElementById('aiRecommendResults').style.display = 'block';

            // 模拟推荐数据
            const recommendedAlts = [
                { mpn: 'STM32F407ZGT6', manufacturer: 'STMicroelectronics', price: 42.50, stock: 500, similarity: 95, reason: '封装更大但功能完全兼容，价格更优' },
                { mpn: 'STM32F405RGT6', manufacturer: 'STMicroelectronics', price: 38.00, stock: 300, similarity: 90, reason: 'Flash容量相同，部分外设略少，成本更低' },
                { mpn: 'GD32F407VGT6', manufacturer: 'GigaDevice', price: 25.00, stock: 1000, similarity: 88, reason: '国产替代方案，性价比高，供货稳定' },
                { mpn: 'AT32F407VGT7', manufacturer: 'ArteryTek', price: 28.00, stock: 800, similarity: 87, reason: '国产替代，性能接近，价格优势明显' },
                { mpn: 'STM32F427VGT6', manufacturer: 'STMicroelectronics', price: 55.00, stock: 200, similarity: 92, reason: '性能更强，适合升级方案' }
            ];

            document.getElementById('aiRecommendCount').textContent = recommendedAlts.length;

            // 渲染推荐列表
            const listHTML = recommendedAlts.map((alt, index) => `
                <div style="border: 2px solid #e0e0e0; border-radius: 8px; padding: 16px; margin-bottom: 12px; transition: all 0.2s; cursor: pointer;"
                     onmouseover="this.style.borderColor='#197bc0'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.1)'"
                     onmouseout="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none'">
                    <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 12px;">
                        <div style="flex: 1;">
                            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                                <input type="checkbox" class="ai-recommend-checkbox" data-index="${index}" style="width: 18px; height: 18px; cursor: pointer;">
                                <div style="font-size: 18px; font-weight: 700; color: #3d4647;">${alt.mpn}</div>
                                <span style="padding: 4px 12px; background: #00890b15; color: #00890b; border-radius: 12px; font-size: 12px; font-weight: 600;">
                                    ${alt.similarity}% 匹配
                                </span>
                            </div>
                            <div style="color: #666; margin-bottom: 8px;">${alt.manufacturer}</div>
                            <div style="display: flex; gap: 20px; font-size: 14px;">
                                <div><strong>单价:</strong> <span style="color: #00890b; font-weight: 700;">¥${alt.price.toFixed(2)}</span></div>
                                <div><strong>库存:</strong> ${alt.stock} 件</div>
                                <div><strong>节省:</strong> <span style="color: #00890b;">¥${(material.price - alt.price).toFixed(2)}</span></div>
                            </div>
                        </div>
                    </div>
                    <div style="background: #f9f9f9; padding: 12px; border-radius: 6px; border-left: 3px solid #197bc0;">
                        <div style="font-size: 12px; color: #999; margin-bottom: 4px;">💡 推荐理由</div>
                        <div style="font-size: 13px; color: #666;">${alt.reason}</div>
                    </div>
                </div>
            `).join('');

            document.getElementById('aiRecommendList').innerHTML = listHTML;

            // 存储推荐数据
            window.aiRecommendedAlternatives = recommendedAlts;
        }

        // 关闭AI推荐模态框
        function closeAIRecommendAlts() {
            document.getElementById('aiRecommendAltsModal').classList.remove('active');
        }

        // 添加所有AI推荐的替代件
        function addAllAIRecommended() {
            if (!window.aiRecommendedAlternatives) return;

            const material = materialsData.find(m => m.id === currentManagingMaterialId);
            if (!material.alternatives) {
                material.alternatives = [];
            }

            window.aiRecommendedAlternatives.forEach(alt => {
                material.alternatives.push({
                    mpn: alt.mpn,
                    manufacturer: alt.manufacturer,
                    price: alt.price,
                    stock: alt.stock,
                    stockStatus: alt.stock > 100 ? 'available' : alt.stock > 0 ? 'low' : 'out',
                    priority: 'secondary',
                    similarity: alt.similarity
                });
            });

            alert(`✅ 已添加 ${window.aiRecommendedAlternatives.length} 个AI推荐的替代件！`);
            closeAIRecommendAlts();
            manageAlternatives(currentManagingMaterialId);
        }

        // 添加选中的AI推荐替代件
        function addSelectedAIRecommended() {
            const selected = Array.from(document.querySelectorAll('.ai-recommend-checkbox:checked'));
            if (selected.length === 0) {
                alert('请至少选择一个替代件！');
                return;
            }

            const material = materialsData.find(m => m.id === currentManagingMaterialId);
            if (!material.alternatives) {
                material.alternatives = [];
            }

            selected.forEach(cb => {
                const index = parseInt(cb.dataset.index);
                const alt = window.aiRecommendedAlternatives[index];
                material.alternatives.push({
                    mpn: alt.mpn,
                    manufacturer: alt.manufacturer,
                    price: alt.price,
                    stock: alt.stock,
                    stockStatus: alt.stock > 100 ? 'available' : alt.stock > 0 ? 'low' : 'out',
                    priority: 'secondary',
                    similarity: alt.similarity
                });
            });

            alert(`✅ 已添加 ${selected.length} 个选中的替代件！`);
            closeAIRecommendAlts();
            manageAlternatives(currentManagingMaterialId);
        }

        // 导出AI推荐报告
        function exportAIRecommendReport() {
            alert(`📤 导出AI推荐报告\n\n报告将包含：\n• AI推荐的所有替代件\n• 详细的对比分析\n• 价格优势说明\n• 采购建议\n\n报告格式: Excel/PDF`);
        }

        // 导出替代件报告
        function exportAlternativesReport() {
            const material = materialsData.find(m => m.id === currentManagingMaterialId);

            alert(`📤 导出替代件报告\n\n物料: ${material.mpn}\n替代件数量: ${material.alternatives.length}\n\n报告将包含：\n• 替代件详细信息\n• 价格对比分析\n• 库存状态统计\n• 使用建议\n\n报告格式: Excel/PDF`);
        }

        // 对比替代件详情
        function compareAlternatives(materialId) {
            alert(`对比替代件：物料 ${materialId}\n\n此功能将提供：\n• 价格全方位对比\n• 库存状态对比\n• 交期对比\n• 参数相似度分析`);
        }

        // 监听替代件复选框变化
        document.addEventListener('change', function(e) {
            if (e.target.classList.contains('alt-checkbox')) {
                updateAltSelectionCount();
            }
        });

        // ==================== 设计文件显示功能 ====================

        // 切换设计文件类型
        function switchDesignFileType(type) {
            // 更新按钮状态
            document.querySelectorAll('.design-file-type-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            document.querySelector(`[data-type="${type}"]`).classList.add('active');

            // 切换显示内容
            document.querySelectorAll('.design-file-view').forEach(view => {
                view.classList.remove('active');
            });

            const viewMap = {
                'schematic': 'schematic-view',
                'footprint': 'footprint-view',
                '3d-model': '3d-model-view',
                'documents': 'documents-view'
            };

            const viewId = viewMap[type];
            if (viewId) {
                document.getElementById(viewId).classList.add('active');
            }
        }

        // 下载设计文件
        function downloadDesignFile(type) {
            const fileMap = {
                'schematic': '原理图符号文件 (STM32F407VGT6.lib)',
                'footprint': 'PCB封装文件 (LQFP-64.kicad_mod)',
                '3d': '3D模型文件 (STM32F407VGT6.step)'
            };

            alert(`📥 下载${fileMap[type] || '设计文件'}\n\n文件将保存到下载文件夹。\n\n提示: 实际使用时将触发文件下载。`);
        }

        // 复制到剪贴板
        function copyToClipboard(type) {
            alert(`📋 已复制${type === 'schematic' ? '原理图符号' : '内容'}到剪贴板！\n\n您可以直接粘贴到KiCad、Altium Designer等EDA工具中。`);
        }

        // 旋转PCB封装视图
        let footprintRotation = 0;
        function rotateFootprint() {
            footprintRotation += 90;
            if (footprintRotation >= 360) footprintRotation = 0;

            const canvas = document.getElementById('footprint-canvas');
            const svg = canvas.querySelector('svg');
            if (svg) {
                svg.style.transform = `rotate(${footprintRotation}deg)`;
                svg.style.transition = 'transform 0.5s ease';
            }
        }

        // 重置3D视图
        function reset3DView() {
            alert('🔄 3D视图已重置\n\n实际使用时将重置相机位置和缩放级别。');
        }

        // ==================== 设计文件上传管理功能 ====================

        // 设计文件数据存储（模拟）
        let designFiles = {
            schematic: [],
            footprint: [],
            '3d-model': [],
            documents: []
        };

        let selectedFiles = [];
        let currentUploadType = '';

        // 文件类型配置
        const fileTypeConfig = {
            'schematic': {
                title: '上传原理图符号文件',
                formats: '.lib, .kicad_sym, .SchLib, .edf, .bxl',
                icon: '📐'
            },
            'footprint': {
                title: '上传PCB封装文件',
                formats: '.kicad_mod, .PcbLib, .pretty, .mod, .brd',
                icon: '🔲'
            },
            '3d-model': {
                title: '上传3D模型文件',
                formats: '.step, .stp, .wrl, .obj, .stl, .3ds, .iges',
                icon: '🎲'
            },
            'documents': {
                title: '上传技术文档',
                formats: '.pdf, .doc, .docx, .xls, .xlsx, .txt, .md',
                icon: '📄'
            }
        };

        // 打开上传文件对话框
        function openUploadFileDialog(type) {
            currentUploadType = type;
            const config = fileTypeConfig[type];

            document.getElementById('uploadFileTitle').textContent = config.title;
            document.getElementById('uploadFileFormats').textContent = config.formats;
            document.getElementById('uploadFileType').value = type;
            document.getElementById('fileDescription').value = '';
            document.getElementById('fileVersion').value = '';
            document.getElementById('fileInput').value = '';
            selectedFiles = [];
            updateSelectedFilesList();

            document.getElementById('uploadFileModal').classList.add('active');
        }

        // 关闭上传文件对话框
        function closeUploadFileDialog() {
            document.getElementById('uploadFileModal').classList.remove('active');
            selectedFiles = [];
            currentUploadType = '';
        }

        // 处理文件选择
        function handleFileSelect(event) {
            const files = Array.from(event.target.files);
            selectedFiles = files;
            updateSelectedFilesList();

            // 启用/禁用上传按钮
            document.getElementById('uploadBtn').disabled = selectedFiles.length === 0;
        }

        // 更新选中文件列表
        function updateSelectedFilesList() {
            const container = document.getElementById('selectedFilesList');

            if (selectedFiles.length === 0) {
                container.innerHTML = '';
                return;
            }

            container.innerHTML = selectedFiles.map((file, index) => `
                <div class="selected-file-item">
                    <div style="display: flex; align-items: center; gap: 12px; flex: 1;">
                        <div style="font-size: 24px;">${fileTypeConfig[currentUploadType].icon}</div>
                        <div style="flex: 1; min-width: 0;">
                            <div style="font-size: 14px; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                ${file.name}
                            </div>
                            <div style="font-size: 12px; color: #999;">${formatFileSize(file.size)}</div>
                        </div>
                    </div>
                    <button onclick="removeSelectedFile(${index})" style="padding: 6px 12px; background: #fee; border: 1px solid #fcc; color: #e74c3c; border-radius: 4px; cursor: pointer; font-size: 12px;">
                        移除
                    </button>
                </div>
            `).join('');
        }

        // 移除选中的文件
        function removeSelectedFile(index) {
            selectedFiles.splice(index, 1);
            updateSelectedFilesList();
            document.getElementById('uploadBtn').disabled = selectedFiles.length === 0;
        }

        // 上传文件
        function uploadFiles() {
            if (selectedFiles.length === 0) {
                alert('请选择要上传的文件！');
                return;
            }

            const description = document.getElementById('fileDescription').value.trim();
            const version = document.getElementById('fileVersion').value.trim();

            // 模拟上传过程
            selectedFiles.forEach(file => {
                const fileData = {
                    id: Date.now() + Math.random(),
                    name: file.name,
                    size: file.size,
                    description: description,
                    version: version || 'v1.0',
                    uploadDate: new Date().toISOString(),
                    type: currentUploadType
                };

                if (!designFiles[currentUploadType]) {
                    designFiles[currentUploadType] = [];
                }
                designFiles[currentUploadType].push(fileData);
            });

            alert(`✅ 成功上传 ${selectedFiles.length} 个文件！`);

            closeUploadFileDialog();
            renderFileList(currentUploadType);
        }

        // 渲染文件列表
        function renderFileList(type) {
            const containerId = {
                'schematic': 'schematicFileList',
                'footprint': 'footprintFileList',
                '3d-model': 'model3DFileList',
                'documents': 'documentsFileList'
            }[type];

            const container = document.getElementById(containerId);
            if (!container) {
                console.warn(`容器元素 ${containerId} 不存在，跳过渲染`);
                return;
            }

            const files = designFiles[type] || [];

            if (files.length === 0) {
                container.innerHTML = `
                    <div class="empty-files-state">
                        <div style="font-size: 48px; margin-bottom: 16px;">${fileTypeConfig[type].icon}</div>
                        <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">暂无上传的设计文件</div>
                        <div style="font-size: 14px;">点击上方"上传"按钮添加文件</div>
                    </div>
                `;
                return;
            }

            container.innerHTML = files.map((file, index) => `
                <div class="design-file-item">
                    <div class="file-icon">${fileTypeConfig[type].icon}</div>
                    <div class="file-info">
                        <div class="file-name">${file.name}</div>
                        <div class="file-meta">
                            <span>📊 ${formatFileSize(file.size)}</span>
                            <span>🏷️ ${file.version}</span>
                            <span>📅 ${formatDate(file.uploadDate)}</span>
                        </div>
                        ${file.description ? `<div style="font-size: 12px; color: #666; margin-top: 4px;">${file.description}</div>` : ''}
                    </div>
                    <div class="file-actions">
                        <button class="file-action-btn" onclick="previewFile('${type}', ${index})">
                            👁️ 预览
                        </button>
                        <button class="file-action-btn" onclick="downloadFile('${type}', ${index})">
                            ⬇️ 下载
                        </button>
                        <button class="file-action-btn" onclick="editFileInfo('${type}', ${index})">
                            ✏️ 编辑
                        </button>
                        <button class="file-action-btn delete" onclick="deleteFile('${type}', ${index})">
                            🗑️ 删除
                        </button>
                    </div>
                </div>
            `).join('');
        }

        // 预览文件
        function previewFile(type, index) {
            const file = designFiles[type][index];
            alert(`👁️ 预览文件\n\n文件名: ${file.name}\n文件大小: ${formatFileSize(file.size)}\n版本: ${file.version}\n\n实际使用时将打开文件预览界面。`);
        }

        // 下载文件
        function downloadFile(type, index) {
            const file = designFiles[type][index];
            alert(`⬇️ 下载文件\n\n${file.name}\n\n文件将保存到下载文件夹。`);
        }

        // 编辑文件信息
        function editFileInfo(type, index) {
            const file = designFiles[type][index];
            const newDescription = prompt('请输入文件描述:', file.description || '');
            const newVersion = prompt('请输入版本号:', file.version || 'v1.0');

            if (newDescription !== null) {
                file.description = newDescription.trim();
            }
            if (newVersion !== null) {
                file.version = newVersion.trim() || 'v1.0';
            }

            renderFileList(type);
            alert('✅ 文件信息已更新！');
        }

        // 删除文件
        function deleteFile(type, index) {
            const file = designFiles[type][index];

            if (!confirm(`确定要删除文件 "${file.name}" 吗？\n\n此操作不可恢复！`)) {
                return;
            }

            designFiles[type].splice(index, 1);
            renderFileList(type);
            alert('✅ 文件已删除！');
        }

        // 格式化文件大小
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const sizes = ['B', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        // 格式化日期
        function formatDate(dateString) {
            const date = new Date(dateString);
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        // 初始化文件列表（当物料详情modal打开时）
        function initDesignFileLists(materialId) {
            try {
                // 模拟加载该物料的设计文件
                renderFileList('schematic');
                renderFileList('footprint');
                renderFileList('3d-model');
                renderFileList('documents');
            } catch (error) {
                console.error('初始化设计文件列表失败:', error);
                // 不阻止modal的打开
            }
        }

        // ========== 编号规则管理功能 ==========

        // 打开编号规则管理模态框
        function openNumberingRuleManager() {
            document.getElementById('numberingRuleModal').classList.add('active');
            renderNumberingRulesList();
            updateNumberingPreview();
        }

        // 关闭编号规则管理模态框
        function closeNumberingRuleModal() {
            document.getElementById('numberingRuleModal').classList.remove('active');
        }

        // 渲染编号规则列表
        function renderNumberingRulesList() {
            const container = document.getElementById('numberingRulesList');
            const ruleKeys = Object.keys(numberingRules);

            container.innerHTML = ruleKeys.map((key, index) => {
                const rule = numberingRules[key];
                return `
                    <div style="background: white; border: 2px solid #e0e0e0; border-radius: 8px; padding: 16px; margin-bottom: 12px;">
                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                            <div style="flex: 1;">
                                <div style="font-size: 14px; font-weight: 600; color: #3d4647; margin-bottom: 4px;">
                                    ${rule.description}
                                </div>
                                <div style="font-size: 12px; color: #999;">
                                    分类代码: ${rule.code}
                                </div>
                            </div>
                            <button class="btn-icon" onclick="editNumberingRule('${key}')" title="编辑规则">
                                ✏️
                            </button>
                        </div>
                        <div style="display: flex; gap: 12px; align-items: center;">
                            <div style="flex: 1;">
                                <label style="display: block; font-size: 12px; font-weight: 600; color: #666; margin-bottom: 4px;">编号模板</label>
                                <input type="text"
                                       id="template-${key}"
                                       value="${rule.template}"
                                       onchange="updateRuleTemplate('${key}', this.value)"
                                       style="width: 100%; padding: 8px 12px; border: 1px solid #e0e0e0; border-radius: 6px; font-size: 13px; font-family: 'Monaco', 'Courier New', monospace;">
                            </div>
                            <div style="width: 120px;">
                                <label style="display: block; font-size: 12px; font-weight: 600; color: #666; margin-bottom: 4px;">当前序号</label>
                                <input type="number"
                                       id="counter-${key}"
                                       value="${rule.counter}"
                                       min="1"
                                       onchange="updateRuleCounter('${key}', this.value)"
                                       style="width: 100%; padding: 8px 12px; border: 1px solid #e0e0e0; border-radius: 6px; font-size: 13px;">
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        // 更新规则模板
        function updateRuleTemplate(key, template) {
            numberingRules[key].template = template;
            updateNumberingPreview();
        }

        // 更新规则计数器
        function updateRuleCounter(key, counter) {
            numberingRules[key].counter = parseInt(counter) || 1;
            updateNumberingPreview();
        }

        // 更新编号预览
        function updateNumberingPreview() {
            const container = document.getElementById('numberingPreview');
            const currentYear = new Date().getFullYear();
            const ruleKeys = Object.keys(numberingRules);

            container.innerHTML = ruleKeys.map(key => {
                const rule = numberingRules[key];
                const preview = generateMaterialNumber(key, { package: '0805' }); // 示例封装

                return `
                    <div style="display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f0f0f0;">
                        <span style="font-weight: 600; color: #3d4647;">${rule.description}:</span>
                        <span style="font-family: 'Monaco', 'Courier New', monospace; color: #00890b; font-weight: 600;">${preview}</span>
                    </div>
                `;
            }).join('');
        }

        // 生成物料编号
        function generateMaterialNumber(categoryKey, customData = {}) {
            const rule = numberingRules[categoryKey];
            if (!rule) return '';

            const currentYear = new Date().getFullYear();
            let number = rule.template;

            // 替换变量
            number = number.replace('{分类代码}', rule.code);
            number = number.replace('{年份}', currentYear);
            number = number.replace('{序号}', String(rule.counter).padStart(4, '0'));

            // 处理自定义变量（如封装）
            if (rule.customVars && rule.customVars.length > 0) {
                rule.customVars.forEach(varName => {
                    const value = customData[varName] || varName;
                    number = number.replace(`{${varName}}`, value);
                });
            }

            return number;
        }

        // 保存编号规则
        function saveNumberingRules() {
            // 在实际应用中，这里应该将规则保存到后端
            console.log('Saving numbering rules:', numberingRules);

            alert('✅ 编号规则已保存！\n\n这些规则将在创建新物料时自动应用。');
            closeNumberingRuleModal();
        }

        // 添加新规则（预留功能）
        function addNumberingRule() {
            const newKey = prompt('请输入新分类的标识符（例如：diode）：');
            if (!newKey) return;

            if (numberingRules[newKey]) {
                alert('该分类已存在！');
                return;
            }

            const description = prompt('请输入分类描述（例如：二极管）：');
            if (!description) return;

            const code = prompt('请输入分类代码（例如：DIO）：');
            if (!code) return;

            numberingRules[newKey] = {
                code: code.toUpperCase(),
                template: `${code.toUpperCase()}-{年份}-{序号}`,
                counter: 1,
                description: description
            };

            renderNumberingRulesList();
            updateNumberingPreview();
        }

        // 编辑规则（预留功能）
        function editNumberingRule(key) {
            alert('编辑规则功能：\n您可以直接修改下方的模板和序号。\n\n支持的变量：\n• {分类代码}\n• {年份}\n• {序号}\n• {封装}（仅限特定分类）');
        }

        // 在物料分类改变时自动填充编号
        function autoFillMaterialNumber() {
            const categorySelect = document.getElementById('matCategory');
            const internalNumberInput = document.getElementById('internalNumber');
            const packageInput = document.getElementById('package');

            if (!categorySelect || !internalNumberInput) return;

            const category = categorySelect.value;
            if (!category || !numberingRules[category]) {
                return;
            }

            // 只在新建物料时自动填充（编辑时不自动填充）
            if (editingMaterialId) {
                return;
            }

            // 获取封装信息（用于电阻、电容等）
            const packageValue = packageInput ? packageInput.value : '';

            // 生成编号
            const generatedNumber = generateMaterialNumber(category, {
                '封装': packageValue || '0805'
            });

            // 填充到输入框
            internalNumberInput.value = generatedNumber;

            // 显示提示
            internalNumberInput.style.borderColor = '#00890b';
            setTimeout(() => {
                internalNumberInput.style.borderColor = '';
            }, 2000);
        }

        // 上传modal点击背景关闭
        document.getElementById('uploadFileModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeUploadFileDialog();
            }
        });

        // 键盘快捷键 (⌘/Ctrl + K for search)
        document.addEventListener('keydown', function(e) {
            if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                e.preventDefault();
                document.getElementById('filterMPN').focus();
            }
        });

        // 点击模态框背景关闭
        document.getElementById('manageAlternativesModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeManageAlternatives();
            }
        });

        // 初始化页面
        renderCurrentView();
    </script>
</body>
</html>
