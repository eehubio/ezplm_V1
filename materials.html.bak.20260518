        function openPersonalSpaceImport() {
            document.getElementById('personalSpaceImportModal').classList.add('active');

            // 重置状态
            selectedPersonalMaterials.clear();
            document.getElementById('personalSpaceSearchInput').value = '';
            document.getElementById('personalSpaceCategoryFilter').value = '';
            document.getElementById('selectAllPersonalMaterials').checked = false;
            document.getElementById('confirmImportBtn').disabled = true;
            updatePersonalSpaceSelectionCount();

            // 显示加载状态
            document.getElementById('personalSpaceLoading').style.display = 'block';
            document.getElementById('personalSpaceMaterialItems').style.display = 'none';
            document.getElementById('personalSpaceEmpty').style.display = 'none';

            // 模拟加载个人空间物料数据
            setTimeout(() => {
                loadPersonalSpaceMaterials();
            }, 1000);
        }

