        // 渲染个人空间物料列表
        function renderPersonalSpaceMaterials() {
            const searchKeyword = document.getElementById('personalSpaceSearchInput').value.toLowerCase();
            const categoryFilter = document.getElementById('personalSpaceCategoryFilter').value;

            // 过滤物料
            let filteredMaterials = personalSpaceMaterialsData.filter(item => {
                const matchSearch = !searchKeyword ||
                    item.name.toLowerCase().includes(searchKeyword) ||
                    item.mpn.toLowerCase().includes(searchKeyword) ||
                    item.manufacturer.toLowerCase().includes(searchKeyword) ||
                    item.internalNumber.toLowerCase().includes(searchKeyword);

                const matchCategory = !categoryFilter || item.category === categoryFilter;

                return matchSearch && matchCategory;
            });

            const container = document.getElementById('personalSpaceMaterialItems');
            document.getElementById('personalSpaceTotalCount').textContent = `共 ${filteredMaterials.length} 项物料`;

            if (filteredMaterials.length === 0) {
                container.innerHTML = `
                    <div style="text-align: center; padding: 60px 20px; color: #999;">
                        <div style="font-size: 64px; margin-bottom: 16px;">🔍</div>
                        <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">没有找到匹配的物料</div>
                        <div style="font-size: 13px;">尝试调整搜索关键词或筛选条件</div>
                    </div>
                `;
                return;
            }

            container.innerHTML = filteredMaterials.map(item => `
                <div class="personal-material-item" data-material-id="${item.id}" style="padding: 16px 20px; border-bottom: 1px solid #f0f0f0; display: flex; gap: 16px; align-items: center; transition: all 0.2s; cursor: pointer;"
                     onmouseover="this.style.background='#f8f9fa'"
                     onmouseout="this.style.background='white'">
                    <!-- 复选框 -->
                    <div>
                        <input type="checkbox" class="personal-material-checkbox"
                               data-material-id="${item.id}"
                               ${selectedPersonalMaterials.has(item.id) ? 'checked' : ''}
                               onchange="togglePersonalMaterialSelection('${item.id}')"
                               style="width: 18px; height: 18px; cursor: pointer;"
                               onclick="event.stopPropagation()">
                    </div>

                    <!-- 物料图标 -->
                    <div style="width: 60px; height: 60px; flex-shrink: 0; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 28px; color: white;">
                        📦
                    </div>

                    <!-- 物料信息 -->
                    <div style="flex: 1; min-width: 0;" onclick="togglePersonalMaterialSelection('${item.id}')">
                        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 6px;">
                            <h4 style="font-size: 15px; font-weight: 700; color: #3d4647; margin: 0;">${item.name}</h4>
                            <span style="background: #e3f2fd; color: #1976d2; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600;">${item.categoryName}</span>
                        </div>
                        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; font-size: 13px; color: #666; margin-bottom: 6px;">
                            <div><strong>型号：</strong>${item.mpn}</div>
                            <div><strong>制造商：</strong>${item.manufacturer}</div>
                            <div><strong>封装：</strong>${item.package}</div>
                        </div>
                        <div style="font-size: 12px; color: #999;">
                            <strong>内部编号：</strong>${item.internalNumber} &nbsp;|&nbsp;
                            <strong>库存：</strong>${item.stock} &nbsp;|&nbsp;
                            <strong>单价：</strong>¥${item.price.toFixed(2)}
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // 筛选个人空间物料
        function filterPersonalSpaceMaterials() {
            renderPersonalSpaceMaterials();
        }

        // 切换单个物料选择
        function togglePersonalMaterialSelection(materialId) {
            if (selectedPersonalMaterials.has(materialId)) {
                selectedPersonalMaterials.delete(materialId);
            } else {
                selectedPersonalMaterials.add(materialId);
            }

            // 更新复选框状态
            const checkbox = document.querySelector(`.personal-material-checkbox[data-material-id="${materialId}"]`);
            if (checkbox) {
                checkbox.checked = selectedPersonalMaterials.has(materialId);
            }

            updatePersonalSpaceSelectionCount();
        }

        // 全选/取消全选
        function toggleSelectAllPersonalMaterials() {
            const selectAllCheckbox = document.getElementById('selectAllPersonalMaterials');
            const checkboxes = document.querySelectorAll('.personal-material-checkbox');

            if (selectAllCheckbox.checked) {
                // 全选
                checkboxes.forEach(cb => {
                    const materialId = cb.getAttribute('data-material-id');
                    selectedPersonalMaterials.add(materialId);
                    cb.checked = true;
                });
            } else {
                // 取消全选
                selectedPersonalMaterials.clear();
                checkboxes.forEach(cb => {
                    cb.checked = false;
                });
            }

            updatePersonalSpaceSelectionCount();
        }

        // 更新选择数量
        function updatePersonalSpaceSelectionCount() {
            const count = selectedPersonalMaterials.size;
            document.getElementById('personalSpaceSelectedCount').textContent = `已选择 ${count} 项`;
            document.getElementById('confirmImportBtn').disabled = count === 0;

            // 更新全选checkbox状态
            const allCheckboxes = document.querySelectorAll('.personal-material-checkbox');
            const selectAllCheckbox = document.getElementById('selectAllPersonalMaterials');
            selectAllCheckbox.checked = allCheckboxes.length > 0 && count === allCheckboxes.length;
        }

        // 确认导入
        function confirmPersonalSpaceImport() {
            if (selectedPersonalMaterials.size === 0) {
                alert('⚠️ 请至少选择一个物料！');
                return;
            }

            // 获取选中的物料
            const selectedMaterials = personalSpaceMaterialsData.filter(item =>
                selectedPersonalMaterials.has(item.id)
            );

            // 确认导入
            if (confirm(`确认导入选中的 ${selectedMaterials.length} 个物料到组织账号吗？\n\n导入后将保留物料的所有信息（除库存外）。`)) {
                // 模拟导入过程
                const importBtn = document.getElementById('confirmImportBtn');
                importBtn.disabled = true;
                importBtn.innerHTML = '<span>⏳</span> 导入中...';

                setTimeout(() => {
                    // 导入成功
                    alert(`✅ 成功导入 ${selectedMaterials.length} 个物料！\n\n物料已添加到组织账号的物料库中。`);

                    // 关闭模态框
                    closePersonalSpaceImport();

                    // 刷新物料列表（这里应该调用实际的刷新函数）
                    // loadMaterials();
                }, 1500);
            }
        }

