        // 渲染云端搜索结果
        function renderCloudSearchResults() {
            const container = document.getElementById('cloudSearchItems');

            if (cloudSearchResultsData.length === 0) {
                container.innerHTML = `
                    <div style="text-align: center; padding: 60px 20px; color: #999;">
                        <div style="font-size: 48px; margin-bottom: 16px;">😕</div>
                        <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">未找到匹配的元器件</div>
                        <div style="font-size: 13px;">请尝试其他关键词或修改搜索条件</div>
                    </div>
                `;
                return;
            }

            container.innerHTML = cloudSearchResultsData.map(item => `
                <div style="background: white; border: 1px solid #e0e0e0; border-radius: 12px; padding: 20px; margin-bottom: 12px; transition: all 0.3s; cursor: pointer;" onmouseover="this.style.borderColor='#667eea'; this.style.boxShadow='0 4px 12px rgba(102,126,234,0.15)'" onmouseout="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none'" onclick="selectCloudItem('${item.id}')">
                    <div style="display: flex; gap: 20px;">
                        <!-- 图片 -->
                        <div style="flex-shrink: 0;">
                            <div style="width: 80px; height: 80px; background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 8px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                                <img src="${item.image}" alt="${item.mpn}" style="max-width: 100%; max-height: 100%; object-fit: contain;" onerror="this.style.display='none'; this.nextElementSibling.style.display='block'">
                                <div style="display: none; font-size: 32px;">📦</div>
                            </div>
                        </div>

                        <!-- 信息 -->
                        <div style="flex: 1; min-width: 0;">
                            <div style="display: flex; align-items: start; justify-content: space-between; margin-bottom: 8px;">
                                <div style="flex: 1;">
                                    <h4 style="font-size: 16px; font-weight: 700; color: #3d4647; margin-bottom: 4px;">${item.mpn}</h4>
                                    <div style="font-size: 14px; color: #666; margin-bottom: 6px;">${item.name}</div>
                                </div>
                                <div style="text-align: right;">
                                    <div style="font-size: 18px; font-weight: 700; color: #00890b; margin-bottom: 4px;">${item.price}</div>
                                    <div style="font-size: 12px; color: #00890b; background: #e8f5e9; padding: 2px 8px; border-radius: 4px;">${item.stock}</div>
                                </div>
                            </div>

                            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin-bottom: 12px; font-size: 13px;">
                                <div style="color: #666;"><strong>制造商：</strong>${item.manufacturer}</div>
                                <div style="color: #666;"><strong>封装：</strong>${item.package}</div>
                                <div style="color: #666;"><strong>工作电压：</strong>${item.voltage}</div>
                                <div style="color: #666;"><strong>工作温度：</strong>${item.temp}</div>
                            </div>

                            <div style="font-size: 13px; color: #666; line-height: 1.5; margin-bottom: 12px;">
                                ${item.description}
                            </div>

                            <div style="display: flex; gap: 8px;">
                                <span style="background: #e3f2fd; color: #1976d2; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600;">${item.category}</span>
                                <a href="${item.datasheet}" target="_blank" style="background: #fff3e0; color: #f57c00; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; text-decoration: none;" onclick="event.stopPropagation()">📄 数据手册</a>
                            </div>
                        </div>

                        <!-- 选择按钮 -->
                        <div style="flex-shrink: 0; display: flex; align-items: center;">
                            <button onclick="event.stopPropagation(); selectCloudItem('${item.id}')" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; padding: 10px 20px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.3s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                                ✓ 选择
                            </button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // 选择云端物料
        function selectCloudItem(itemId) {
            const item = cloudSearchResultsData.find(i => i.id === itemId);
            if (!item) return;

            // 填充表单数据
            document.getElementById('mpn').value = item.mpn;
            document.getElementById('matName').value = item.name;
            document.getElementById('manufacturer').value = item.manufacturer;
            document.getElementById('package').value = item.package;
            document.getElementById('specs').value = item.description;
            document.getElementById('websiteUrl').value = item.datasheet;

            // 根据分类设置物料分类
            const categoryMap = {
                '微控制器 (MCU)': 'mcu',
                '集成电路 (IC)': 'ic',
                '模数转换器 (ADC)': 'ic',
                '无线通信模块': 'sensor',
            };
            const category = categoryMap[item.category] || 'other';
            document.getElementById('matCategory').value = category;

            // 关闭云端查询modal
            closeCloudSearch();

            // 提示用户
            alert(`✅ 已自动填充物料信息！\n\n型号：${item.mpn}\n名称：${item.name}\n\n请补充"内部编号"后保存。`);

            // 滚动到内部编号输入框
            document.getElementById('internalNumber').focus();
            document.getElementById('internalNumber').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        // ==================== 个人空间导入功能 ====================
        let personalSpaceMaterialsData = [];
        let selectedPersonalMaterials = new Set();

