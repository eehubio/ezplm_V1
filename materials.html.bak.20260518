        // 物料编号规则配置
        let numberingRules = {
            'ic': {
                code: 'IC',
                template: 'IC-{年份}-{序号}',
                counter: 1,
                description: '集成电路 (IC)'
            },
            'mcu': {
                code: 'MCU',
                template: 'MCU-{年份}-{序号}',
                counter: 1,
                description: '微控制器 (MCU)'
            },
            'r': {
                code: 'RES',
                template: 'RES-{封装}-{序号}',
                counter: 1,
                description: '电阻 (Resistor)',
                customVars: ['封装']
            },
            'c': {
                code: 'CAP',
                template: 'CAP-{封装}-{序号}',
                counter: 1,
                description: '电容 (Capacitor)',
                customVars: ['封装']
            },
            'con': {
                code: 'CON',
                template: 'CON-{年份}-{序号}',
                counter: 1,
                description: '连接器 (Connector)'
            },
            'sensor': {
                code: 'SEN',
                template: 'SEN-{年份}-{序号}',
                counter: 1,
                description: '传感器 (Sensor)'
            },
            'led': {
                code: 'LED',
                template: 'LED-{年份}-{序号}',
                counter: 1,
                description: 'LED'
            },
            'other': {
                code: 'OTH',
                template: 'OTH-{年份}-{序号}',
                counter: 1,
                description: '其他'
            }
        };

        let currentPage = 1;
        let itemsPerPage = 10;
        let filteredData = [...materialsData];
        let selectedItems = new Set();
        let sortColumn = null;
        let sortDirection = 'asc';
        let editingMaterialId = null;
        let uploadedFiles = {
            image: null,
            datasheet: null,
            schematic: null,
            footprint: null,
            model3d: null
        };

        // 渲染表格
        function renderTable() {
            const tbody = document.getElementById('tableBody');
            const start = (currentPage - 1) * itemsPerPage;
            const end = start + itemsPerPage;
            const pageData = filteredData.slice(start, end);

            tbody.innerHTML = pageData.map(item => `
                <tr>
                    <td class="checkbox-cell">
                        <input type="checkbox" class="row-checkbox" data-id="${item.id}"
                            ${selectedItems.has(item.id) ? 'checked' : ''}
                            onchange="toggleRowSelection(${item.id})">
                    </td>
                    <td class="image-cell">
                        <div class="material-image">
                            ${item.image ? `<img src="${item.image}" alt="Product">` : '📦'}
                        </div>
                    </td>
                    <td>${item.internalNumber}</td>
                    <td><span class="material-number" onclick="viewMaterialDetail(${item.id})">${item.mpn}</span></td>
                    <td>${item.specs}</td>
                    <td style="font-weight: 600; color: #00890b;">
                        ${item.currentPrice ? `¥${item.currentPrice.toFixed(2)}` : '-'}
                        ${item.priceUpdateTime ? `<div style="font-size: 11px; color: #999; font-weight: 400;">${item.priceUpdateTime.split(' ')[0]}</div>` : ''}
                    </td>
                    <td style="text-align: center;">
                        ${item.specSheetUrl || item.files?.datasheet ? `
                            <button class="action-btn" title="查看规格书" onclick="viewSpecSheet('${item.specSheetUrl || item.files.datasheet}', '${item.mpn}')" style="background: #e3f2fd; color: #1976d2;">
                                📄
                            </button>
                        ` : `<span style="color: #ccc; font-size: 12px;">-</span>`}
                    </td>
                    <td>${item.stock.toLocaleString()}</td>
                    <td>${item.manufacturer}</td>
                    <td>${item.package}</td>
                    <td>${item.category}</td>
                    <td>
                        ${item.alternatives && item.alternatives.length > 0 ? `
                            <span class="alternatives-badge" onclick="manageAlternatives(${item.id})" title="点击管理替代件">
                                🔄 <span class="alternatives-count">${item.alternatives.length}</span>
                            </span>
                        ` : `<span style="color: #ccc; font-size: 12px;">-</span>`}
                    </td>
                    <td>
                        <span class="status-badge status-${item.status}">
                            ${item.status === 'active' ? '活跃' : item.status === 'inactive' ? '停用' : '待审核'}
                        </span>
                    </td>
                    <td>
                        <div class="action-btns">
                            <button class="action-btn" title="编辑" onclick="editMaterial(${item.id})">✏️</button>
                            <button class="action-btn" title="复制" onclick="copyMaterial(${item.id})">📋</button>
                            <button class="action-btn" title="删除" onclick="deleteMaterial(${item.id})">🗑️</button>
                        </div>
                    </td>
                </tr>
            `).join('');

            updatePagination();
            updateSelectionInfo();
        }

        // 渲染卡片视图
        function renderCards() {
            const container = document.getElementById('cardView');
            const start = (currentPage - 1) * itemsPerPage;
            const end = start + itemsPerPage;
            const pageData = filteredData.slice(start, end);

            container.innerHTML = pageData.map(item => {
                const statusText = item.status === 'active' ? '活跃' : item.status === 'inactive' ? '停用' : '待审核';
                const statusClass = `badge-${item.status}`;
                const stockClass = item.stock < 100 ? 'low' : '';

                return `
                    <div class="material-card">
                        <input type="checkbox" class="material-card-checkbox row-checkbox" data-id="${item.id}"
                            ${selectedItems.has(item.id) ? 'checked' : ''}
                            onchange="toggleRowSelection(${item.id}); event.stopPropagation();">
                        <div class="material-card-image" onclick="viewMaterialDetail(${item.id})">
                            ${item.image ? `<img src="${item.image}" alt="${item.mpn}">` : '<div class="no-image">📦</div>'}
                        </div>
                        <div class="material-card-body">
                            <div class="material-card-mpn" onclick="viewMaterialDetail(${item.id})">${item.mpn}</div>
                            <div class="material-card-name">${item.name || item.specs}</div>
                            <div class="material-card-info">
                                <div class="material-card-row">
                                    <span class="material-card-label">内部编号:</span>
                                    <span class="material-card-value">${item.internalNumber}</span>
                                </div>
                                <div class="material-card-row">
                                    <span class="material-card-label">制造商:</span>
                                    <span class="material-card-value">${item.manufacturer}</span>
                                </div>
                                <div class="material-card-row">
                                    <span class="material-card-label">封装:</span>
                                    <span class="material-card-value">${item.package}</span>
                                </div>
                                <div class="material-card-row">
                                    <span class="material-card-label">库存:</span>
                                    <span class="material-card-stock ${stockClass}">${item.stock.toLocaleString()}</span>
                                </div>
                                <div class="material-card-row">
                                    <span class="material-card-label">分类:</span>
                                    <span class="material-card-value">${item.category}</span>
                                </div>
                                <div class="material-card-row">
                                    <span class="material-card-label">状态:</span>
                                    <span class="material-card-badge ${statusClass}">${statusText}</span>
                                </div>
                            </div>
                            <div class="material-card-footer">
                                <button class="card-btn-edit" onclick="editMaterial(${item.id}); event.stopPropagation();">编辑</button>
                                <button class="card-btn-copy" onclick="copyMaterial(${item.id}); event.stopPropagation();">复制</button>
                                <button class="card-btn-delete" onclick="deleteMaterial(${item.id}); event.stopPropagation();">删除</button>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            updatePagination();
            updateSelectionInfo();
        }

        // 当前视图模式
        let currentView = 'table';

        // 渲染当前视图
        function renderCurrentView() {
            if (currentView === 'table') {
                renderTable();
            } else {
                renderCards();
            }
        }

        // 切换视图
        function switchView(view) {
            currentView = view;

            // 更新按钮状态
            document.getElementById('tableViewBtn').classList.toggle('active', view === 'table');
            document.getElementById('cardViewBtn').classList.toggle('active', view === 'card');

            // 显示/隐藏视图
            document.getElementById('tableView').style.display = view === 'table' ? 'block' : 'none';
            document.getElementById('cardView').style.display = view === 'card' ? 'grid' : 'none';

            // 渲染对应视图
            renderCurrentView();
        }

        // 更新分页信息
        function updatePagination() {
            const total = filteredData.length;
            const start = (currentPage - 1) * itemsPerPage + 1;
            const end = Math.min(currentPage * itemsPerPage, total);

            document.getElementById('rangeStart').textContent = start;
            document.getElementById('rangeEnd').textContent = end;
            document.getElementById('totalItems').textContent = total;
        }

        // 切换全选
        function toggleSelectAll() {
            const selectAll = document.getElementById('selectAll');
            const checkboxes = document.querySelectorAll('.row-checkbox');

            if (selectAll.checked) {
                checkboxes.forEach(cb => {
                    cb.checked = true;
                    selectedItems.add(parseInt(cb.dataset.id));
                });
            } else {
                checkboxes.forEach(cb => {
                    cb.checked = false;
                });
                selectedItems.clear();
            }
            updateSelectionInfo();
        }

        // 切换行选择
        function toggleRowSelection(id) {
            if (selectedItems.has(id)) {
                selectedItems.delete(id);
            } else {
                selectedItems.add(id);
            }
            updateSelectionInfo();
        }

        // 更新选择信息
        function updateSelectionInfo() {
            const count = selectedItems.size;
            const info = document.getElementById('selectionInfo');
            const deleteBtn = document.getElementById('bulkDeleteBtn');

            if (count > 0) {
                info.classList.add('active');
                deleteBtn.style.display = 'flex';
                document.getElementById('selectedCount').textContent = count;
            } else {
                info.classList.remove('active');
                deleteBtn.style.display = 'none';
            }
        }

        // 清除选择
        function clearSelection() {
            selectedItems.clear();
            document.getElementById('selectAll').checked = false;
            document.querySelectorAll('.row-checkbox').forEach(cb => cb.checked = false);
            updateSelectionInfo();
        }

        // 排序
        function sortTable(column) {
            if (sortColumn === column) {
                sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                sortColumn = column;
                sortDirection = 'asc';
            }

            filteredData.sort((a, b) => {
                let valA = a[column];
                let valB = b[column];

                if (typeof valA === 'string') {
                    valA = valA.toLowerCase();
                    valB = valB.toLowerCase();
                }

                if (sortDirection === 'asc') {
                    return valA > valB ? 1 : -1;
                } else {
                    return valA < valB ? 1 : -1;
                }
            });

            // 更新排序图标
            document.querySelectorAll('.sortable').forEach(th => th.classList.remove('sorted'));
            event.target.closest('th').classList.add('sorted');

            renderCurrentView();
        }

        // 筛选
        function applyFilters() {
            const internalNumber = document.getElementById('filterInternalNumber').value.toLowerCase();
            const mpn = document.getElementById('filterMPN').value.toLowerCase();
            const manufacturer = document.getElementById('filterManufacturer').value.toLowerCase();
            const packageType = document.getElementById('filterPackage').value.toLowerCase();
            const category = document.getElementById('filterCategory').value;
            const sourceProject = document.getElementById('filterSourceProject').value.toLowerCase();
            const status = document.getElementById('filterStatus').value;
            const lowStockOnly = document.getElementById('lowStockToggle').classList.contains('active');

            filteredData = materialsData.filter(item => {
                const matchInternalNumber = !internalNumber || item.internalNumber.toLowerCase().includes(internalNumber);
                const matchMPN = !mpn || item.mpn.toLowerCase().includes(mpn);
                const matchManufacturer = !manufacturer || item.manufacturer.toLowerCase().includes(manufacturer);
                const matchPackage = !packageType || item.package.toLowerCase().includes(packageType);
                const matchCategory = !category || item.category === category;
                const matchSourceProject = !sourceProject || item.sourceProject.toLowerCase().includes(sourceProject);
                const matchStatus = !status || item.status === status;
                const matchLowStock = !lowStockOnly || item.stock < 1000;

                return matchInternalNumber && matchMPN && matchManufacturer && matchPackage &&
                       matchCategory && matchSourceProject && matchStatus && matchLowStock;
            });

            currentPage = 1;
            renderCurrentView();
        }

        // 重置筛选
        function resetFilters() {
            document.getElementById('filterInternalNumber').value = '';
            document.getElementById('filterMPN').value = '';
            document.getElementById('filterManufacturer').value = '';
            document.getElementById('filterPackage').value = '';
            document.getElementById('filterCategory').value = '';
            document.getElementById('filterSourceProject').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('lowStockToggle').classList.remove('active');

            filteredData = [...materialsData];
            currentPage = 1;
            renderCurrentView();
        }

        // 切换库存预警
        function toggleLowStock() {
            document.getElementById('lowStockToggle').classList.toggle('active');
        }

        // 分页控制
        function goToPage(page) {
            currentPage = page;
            renderCurrentView();
        }

        function nextPage() {
            const totalPages = Math.ceil(filteredData.length / itemsPerPage);
            if (currentPage < totalPages) {
                currentPage++;
                renderCurrentView();
            }
        }

        function previousPage() {
            if (currentPage > 1) {
                currentPage--;
                renderCurrentView();
            }
        }

        function goToLastPage() {
            currentPage = Math.ceil(filteredData.length / itemsPerPage);
            renderCurrentView();
        }

        // 图片上传处理
        function handleImageUpload(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    uploadedFiles.image = e.target.result;
                    const preview = document.getElementById('imagePreview');
                    preview.innerHTML = `<img src="${e.target.result}" alt="Preview">`;
                };
                reader.readAsDataURL(file);
            }
        }

        // 文件上传处理
        function handleFileUpload(event, fileType) {
            const file = event.target.files[0];
            if (file) {
                uploadedFiles[fileType] = file;
                const nameElement = document.getElementById(fileType + 'Name');
                const areaElement = document.getElementById(fileType + 'Area');
                nameElement.textContent = file.name;
                areaElement.classList.add('has-file');
            }
        }

        // 当前详情物料ID
        let currentDetailMaterialId = null;

        // 物料操作
        function viewMaterialDetail(id) {
            console.log('viewMaterialDetail 被调用, ID:', id);

            const material = materialsData.find(m => m.id === id);
            if (!material) {
                console.error('未找到物料, ID:', id);
                return;
            }

            currentDetailMaterialId = id;

            // 填充顶部标识区域
            document.getElementById('detailHeaderMPN').textContent = material.mpn;
            document.getElementById('detailHeaderName').textContent = material.name;
            document.getElementById('detailHeaderManufacturer').textContent = material.manufacturer;
            document.getElementById('detailHeaderPackage').textContent = material.package;
            document.getElementById('detailHeaderCategory').textContent = material.category;
            document.getElementById('detailHeaderStock').textContent = material.stock.toLocaleString();
            document.getElementById('detailHeaderInternalNumber').textContent = material.internalNumber;

            // 顶部状态标签
            const headerStatusEl = document.getElementById('detailHeaderStatus');
            headerStatusEl.textContent = material.status === 'active' ? '活跃' :
                                         material.status === 'inactive' ? '停用' : '待审核';
            headerStatusEl.className = 'status-badge status-' + material.status;

            // 顶部产品图片
            const headerImageEl = document.getElementById('detailHeaderImage');
            const headerPlaceholderEl = document.getElementById('detailHeaderImagePlaceholder');
            if (material.image) {
                headerImageEl.src = material.image;
                headerImageEl.style.display = 'block';
                headerPlaceholderEl.style.display = 'none';
            } else {
                headerImageEl.style.display = 'none';
                headerPlaceholderEl.style.display = 'flex';
            }

            // 填充基本信息TAB
            document.getElementById('detailInternalNumber').textContent = material.internalNumber;
            document.getElementById('detailName').textContent = material.name;
            document.getElementById('detailMPN').textContent = material.mpn;
            document.getElementById('detailManufacturer').textContent = material.manufacturer;
            document.getElementById('detailPackage').textContent = material.package;
            document.getElementById('detailCategory').textContent = material.category;
            document.getElementById('detailStock').textContent = material.stock.toLocaleString();
            document.getElementById('detailStatus').textContent =
                material.status === 'active' ? '活跃' :
                material.status === 'inactive' ? '停用' : '待审核';
            document.getElementById('detailSpecs').textContent = material.specs;

            // 官网链接
            const websiteEl = document.getElementById('detailWebsite');
            if (material.websiteUrl) {
                websiteEl.textContent = material.websiteUrl;
                websiteEl.href = material.websiteUrl;
            } else {
                websiteEl.textContent = '-';
                websiteEl.href = '#';
            }

            // 产品图片
            const imageEl = document.getElementById('detailImage');
            const placeholderEl = document.getElementById('detailImagePlaceholder');
            if (material.image) {
                imageEl.src = material.image;
                imageEl.style.display = 'block';
                placeholderEl.style.display = 'none';
            } else {
                imageEl.style.display = 'none';
                placeholderEl.style.display = 'flex';
            }

            // 初始化参数
            if (!material.parameters) {
                material.parameters = [];
            }
            renderParameters();

            // 初始化替代料
            if (!material.alternatives) {
                material.alternatives = [];
            }

            // 加载替代件管理数据
            loadAlternativesData(id);

            // 渲染文件列表
            renderFileList(material);

            // 渲染参考设计
            renderReferences(material);

            // 渲染关联项目
            renderRelatedProjects(material);

            // 渲染供应商
            renderSuppliers(material);

            // 渲染贸易商货源
            renderTraderSuppliers(material);

            // 初始化设计文件列表
            initDesignFileLists(id);

            // 重置TAB到第一个（基本信息）
            document.querySelectorAll('.detail-tab').forEach(tab => tab.classList.remove('active'));
            document.querySelectorAll('#detailModal .tab-content').forEach(content => content.classList.remove('active'));
            document.querySelector('.detail-tab').classList.add('active'); // 第一个TAB
            document.getElementById('tab-basic').classList.add('active'); // 第一个TAB内容

            // 显示模态框
            document.getElementById('detailModal').classList.add('active');
        }

        // 渲染参考设计
        function renderReferences(material) {
            const container = document.getElementById('referenceList');
            container.innerHTML = '';

            if (material.references && material.references.length > 0) {
                material.references.forEach(ref => {
                    const card = document.createElement('div');
                    card.className = 'reference-card';
                    card.innerHTML = `
                        <div class="reference-image">📘</div>
                        <div class="reference-content">
                            <div class="reference-title">${ref.title}</div>
                            <div class="reference-desc">${ref.description}</div>
                            <a href="${ref.url}" target="_blank" class="reference-link">查看详情 →</a>
                        </div>
                    `;
                    container.appendChild(card);
                });
            } else {
                container.innerHTML = '<div style="text-align: center; color: #999; padding: 20px;">暂无参考设计</div>';
            }
        }

        // 渲染关联项目
        function renderRelatedProjects(material) {
            const container = document.getElementById('projectList');
            container.innerHTML = '';

            if (material.relatedProjects && material.relatedProjects.length > 0) {
                material.relatedProjects.forEach(proj => {
                    const card = document.createElement('div');
                    card.className = 'project-card';
                    card.onclick = () => alert(`查看项目：${proj.name}\nBOM: ${proj.bom}`);
                    card.innerHTML = `
                        <div class="project-name">${proj.name}</div>
                        <div class="project-meta">
                            <span>📅 ${proj.date}</span>
                            <span style="margin-left: 12px;">📋 ${proj.bom}</span>
                        </div>
                    `;
                    container.appendChild(card);
                });
            } else {
                container.innerHTML = '<div style="text-align: center; color: #999; padding: 20px; grid-column: 1 / -1;">暂无关联项目</div>';
            }
        }

        // 渲染供应商列表
        function renderSuppliers(material) {
            const container = document.getElementById('supplierList');
            container.innerHTML = '';

            if (material.suppliers && material.suppliers.length > 0) {
                material.suppliers.forEach(supplier => {
                    const div = document.createElement('div');
                    div.className = 'supplier-item';
                    div.innerHTML = `
                        <div>
                            <span class="supplier-name" onclick="showDistributorDetail('${supplier.name}')">${supplier.name}</span>
                            ${supplier.authorized ? '<span class="supplier-badge">✓ 授权</span>' : ''}
                            <div style="font-size: 12px; color: #999; margin-top: 4px;">${supplier.type}</div>
                        </div>
                        <div class="stock-info">库存: ${supplier.stock.toLocaleString()}</div>
                        <div class="price-info">¥${supplier.price.toFixed(2)}</div>
                        <div style="text-align: center;">
                            <button class="btn-icon" style="padding: 6px 12px;" onclick="alert('跳转到 ${supplier.name}')">
                                购买
                            </button>
                        </div>
                    `;
                    container.appendChild(div);
                });
            } else {
                container.innerHTML = '<div style="text-align: center; color: #999; padding: 20px;">暂无供应商信息</div>';
            }
        }

        // 渲染贸易商货源信息（来自元器件供货页面）
        function renderTraderSuppliers(material) {
            const container = document.getElementById('traderSupplierList');
            container.innerHTML = '';

            // 模拟贸易商货源数据（实际应从元器件供货页面获取）
            const traderSuppliers = [
                {
                    name: '深圳市华强北电子商行',
                    type: '贸易商',
                    contact: '张经理',
                    phone: '138****8888',
                    stock: 5000,
                    price: material.price * 0.85,
                    moq: 100,
                    reliability: 'medium',
                    verified: false
                },
                {
                    name: '上海鑫盛电子元件有限公司',
                    type: '代理商',
                    contact: '李总',
                    phone: '139****6666',
                    stock: 3200,
                    price: material.price * 0.92,
                    moq: 50,
                    reliability: 'high',
                    verified: true
                },
                {
                    name: '北京科技芯片贸易中心',
                    type: '贸易商',
                    contact: '王先生',
                    phone: '136****7777',
                    stock: 1500,
                    price: material.price * 0.78,
                    moq: 200,
                    reliability: 'low',
                    verified: false
                }
            ];

            if (traderSuppliers.length > 0) {
                traderSuppliers.forEach(trader => {
                    const div = document.createElement('div');
                    div.className = 'supplier-item';

                    // 可靠性指示器
                    let reliabilityBadge = '';
                    if (trader.reliability === 'high') {
                        reliabilityBadge = '<span class="supplier-badge" style="background: #28a745;">★★★</span>';
                    } else if (trader.reliability === 'medium') {
                        reliabilityBadge = '<span class="supplier-badge" style="background: #ffc107; color: #333;">★★☆</span>';
                    } else {
                        reliabilityBadge = '<span class="supplier-badge" style="background: #dc3545;">★☆☆</span>';
                    }

                    div.innerHTML = `
                        <div>
                            <span class="supplier-name">${trader.name}</span>
                            ${trader.verified ? '<span class="supplier-badge" style="background: #17a2b8;">已核实</span>' : '<span class="supplier-badge" style="background: #6c757d;">未核实</span>'}
                            ${reliabilityBadge}
                            <div style="font-size: 12px; color: #999; margin-top: 4px;">
                                ${trader.type} · ${trader.contact} · ${trader.phone}
                            </div>
                        </div>
                        <div class="stock-info">
                            库存: ${trader.stock.toLocaleString()}<br>
                            <span style="font-size: 11px; color: #999;">MOQ: ${trader.moq}</span>
                        </div>
                        <div class="price-info">¥${trader.price.toFixed(2)}</div>
                        <div style="text-align: center;">
                            <button class="btn-icon" style="padding: 6px 12px;" onclick="viewTraderDetails('${trader.name}')">
                                查看
                            </button>
                        </div>
                    `;
                    container.appendChild(div);
                });
            } else {
                container.innerHTML = '<div style="text-align: center; color: #999; padding: 20px;">暂无贸易商货源</div>';
            }
        }

        // 查看贸易商详情
        function viewTraderDetails(name) {
            alert(`📋 贸易商详情\n\n贸易商: ${name}\n\n此功能将显示该贸易商的详细信息，包括:\n• 历史交易记录\n• 信誉评分\n• 联系方式\n• 供货能力\n• 用户评价\n\n点击"联系供应商"可直接发起询价。`);
        }

        // 分销商详细信息数据库
        const distributorInfo = {
            'Digikey': {
                name: 'Digikey Electronics',
                logo: '🏪',
                type: '全球授权分销商',
                authorized: '100+ 厂商授权',
                year: '1972年',
                rating: '4.8/5.0 ⭐',
                website: 'https://www.digikey.cn',
                phone: '+86 400-920-1199',
