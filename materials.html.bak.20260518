        function generateSelectionComparisonResult(material) {
            return `<h4 style="font-size: 18px; font-weight: 700; margin-bottom: 20px;">⚖️ 选型对比分析</h4><div style="background: #f0f8ff; padding: 16px; border-radius: 8px; margin-bottom: 20px;"><div style="text-align: center; color: #197bc0; font-weight: 600;">多维度对比${material.mpn}与其他候选方案</div></div><div style="overflow-x: auto;"><table style="width: 100%; border-collapse: collapse; background: white;"><thead><tr style="background: #f5f5f5;"><th style="padding: 12px; text-align: left; border: 1px solid #e0e0e0;">参数</th><th style="padding: 12px; text-align: center; border: 1px solid #e0e0e0; background: #e8f5e9;">${material.mpn}<br><span style="font-size: 11px; color: #00890b;">✓ 推荐</span></th><th style="padding: 12px; text-align: center; border: 1px solid #e0e0e0;">STM32F103C8T6</th><th style="padding: 12px; text-align: center; border: 1px solid #e0e0e0;">GD32F103C8T6</th></tr></thead><tbody><tr><td style="padding: 10px; border: 1px solid #e0e0e0;">性能得分</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center; font-weight: 600; color: #00890b;">95/100</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center;">88/100</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center;">86/100</td></tr><tr><td style="padding: 10px; border: 1px solid #e0e0e0;">功耗表现</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center; font-weight: 600; color: #00890b;">优秀</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center;">良好</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center;">良好</td></tr><tr><td style="padding: 10px; border: 1px solid #e0e0e0;">价格(100+)</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center;">¥26.80</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center; font-weight: 600; color: #00890b;">¥23.50</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center; font-weight: 600; color: #00890b;">¥17.40</td></tr><tr><td style="padding: 10px; border: 1px solid #e0e0e0;">供应稳定性</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center; font-weight: 600; color: #00890b;">优秀</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center; font-weight: 600; color: #00890b;">优秀</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center;">良好</td></tr><tr><td style="padding: 10px; border: 1px solid #e0e0e0;">开发生态</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center; font-weight: 600; color: #00890b;">完善</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center; font-weight: 600; color: #00890b;">完善</td><td style="padding: 10px; border: 1px solid #e0e0e0; text-align: center;">一般</td></tr></tbody></table></div>`;
        }

        function generateSpecInterpretationResult(material) {
            return `<h4 style="font-size: 18px; font-weight: 700; margin-bottom: 20px;">📖 技术规格解读</h4><div style="background: white; border: 1px solid #e0e0e0; border-radius: 12px; padding: 20px; margin-bottom: 20px;"><h5 style="font-size: 15px; font-weight: 600; margin-bottom: 16px;">🔍 关键参数详解</h5><div style="display: grid; gap: 16px;"><div style="border-left: 4px solid #197bc0; padding: 16px; background: #f9f9f9; border-radius: 6px;"><div style="font-weight: 600; margin-bottom: 8px;">工作电压：1.8V - 3.6V</div><div style="font-size: 13px; color: #666; line-height: 1.6;"><strong>含义：</strong>芯片能够稳定工作的电源电压范围。<br><strong>测试条件：</strong>25°C环境温度，典型应用负载。<br><strong>使用建议：</strong>实际应用中建议使用3.0V或3.3V标准电压，避免在极限值附近工作。</div></div><div style="border-left: 4px solid #00890b; padding: 16px; background: #f9f9f9; border-radius: 6px;"><div style="font-weight: 600; margin-bottom: 8px;">待机电流：0.5μA (典型值)</div><div style="font-size: 13px; color: #666; line-height: 1.6;"><strong>含义：</strong>芯片进入LPM4.5超低功耗模式时的功耗。<br><strong>测试条件：</strong>VCC=3V, 25°C, 所有外设关闭, RTC保持运行。<br><strong>重要说明：</strong>实际功耗会受温度、电压、外设配置影响，可能在0.3-1.0μA之间变化。</div></div></div></div>`;
