                                    • 生成中文解读报告<br>
                                    • 智能问答交互
                                </div>
                            </div>
                        </div>

                        <!-- AI分析结果区域 -->
                        <div id="materialAIResult" style="display: none;">
                            <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 12px; margin-bottom: 24px;">
                                <div style="display: flex; align-items: center; justify-content: space-between;">
                                    <div>
                                        <div style="font-size: 14px; opacity: 0.9; margin-bottom: 4px;">当前分析</div>
                                        <h4 id="currentAIFunctionTitle" style="font-size: 18px; font-weight: 700; margin: 0;">-</h4>
                                    </div>
                                    <button onclick="clearMaterialAIResult()" style="background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); color: white; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px; font-weight: 600;">
                                        返回功能选择
                                    </button>
                                </div>
