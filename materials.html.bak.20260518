        function updateMaterialAIHistory() {
            const container = document.getElementById('materialAIHistoryList');
            container.innerHTML = materialAIAnalysisHistory.slice(0, 5).map(record => `
                <div style="background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 16px; cursor: pointer; transition: all 0.2s;"
                     onmouseover="this.style.borderColor='#197bc0'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.1)';"
                     onmouseout="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none';"
                     onclick="selectAIFunction('${record.type}')">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <div style="font-weight: 600; color: #3d4647; margin-bottom: 4px;">${aiFunctionNames[record.type]}</div>
                            <div style="font-size: 12px; color: #999;">${record.materialMPN} • ${record.time}</div>
                        </div>
