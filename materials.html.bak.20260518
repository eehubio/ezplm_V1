            },
            'Mouser': {
                name: 'Mouser Electronics',
                logo: '🏪',
                type: '全球授权分销商',
                authorized: '800+ 厂商授权',
                year: '1964年',
                rating: '4.7/5.0 ⭐',
                website: 'https://www.mouser.cn',
                phone: '+86 400-830-1766',
                description: 'Mouser Electronics是全球授权的半导体和电子元器件分销商，专注于快速引入新产品和新技术。提供超过500万种产品，支持全球配送。'
            },
            '立创商城': {
                name: '立创商城',
                logo: '🏪',
                type: '国内现货供应商',
                authorized: '部分厂商授权',
                year: '2011年',
                rating: '4.6/5.0 ⭐',
                website: 'https://www.szlcsc.com',
                phone: '0755-83690011',
                description: '立创商城是国内领先的电子元器件现货供应平台，主打小批量快速采购。现货库存丰富，支持次日达配送。整合PCB打样、SMT贴片等一站式服务。'
            },
            'Arrow': {
                name: 'Arrow Electronics',
                logo: '🏪',
                type: '全球授权分销商',
                authorized: '150+ 厂商授权',
                year: '1935年',
                rating: '4.5/5.0 ⭐',
                website: 'https://www.arrow.com',
                phone: '+86 21-2067-9888',
                description: 'Arrow Electronics是全球五大电子元器件分销商之一，拥有超过85年历史。提供工程设计服务、供应链解决方案和全球物流支持。'
            }
        };

        // 显示分销商详情
        function showDistributorDetail(name) {
            const dist = distributorInfo[name];
            if (!dist) {
                alert('暂无该分销商详细信息');
                return;
            }

            document.getElementById('distName').textContent = dist.name;
            document.getElementById('distLogo').textContent = dist.logo;
            document.getElementById('distType').textContent = dist.type;
            document.getElementById('distAuth').textContent = dist.authorized;
            document.getElementById('distYear').textContent = dist.year;
            document.getElementById('distRating').textContent = dist.rating;
            document.getElementById('distWebsite').textContent = dist.website;
            document.getElementById('distWebsite').href = dist.website;
            document.getElementById('distPhone').textContent = dist.phone;
            document.getElementById('distDesc').textContent = dist.description;

            // 显示授权徽章
            const badge = document.getElementById('distBadge');
            if (dist.authorized.includes('100+') || dist.authorized.includes('800+') || dist.authorized.includes('150+')) {
                badge.innerHTML = '<span class="supplier-badge" style="display: inline-block;">✓ 官方授权分销商</span>';
            } else {
                badge.innerHTML = '';
            }

            document.getElementById('distributorModal').classList.add('active');
        }

        // 关闭分销商模态框
        function closeDistributorModal() {
            document.getElementById('distributorModal').classList.remove('active');
        }

        // 渲染参数表格
        function renderParameters() {
            const material = materialsData.find(m => m.id === currentDetailMaterialId);
            if (!material) return;

            const tbody = document.getElementById('paramTableBody');
            tbody.innerHTML = '';

            material.parameters.forEach((param, index) => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td><input type="text" value="${param.name}" onchange="updateParameter(${index}, 'name', this.value)"></td>
                    <td><input type="text" value="${param.value}" onchange="updateParameter(${index}, 'value', this.value)"></td>
                    <td style="text-align: center;">
                        <button class="btn-remove" onclick="removeParameter(${index})">删除</button>
                    </td>
                `;
                tbody.appendChild(row);
            });

            if (material.parameters.length === 0) {
                tbody.innerHTML = '<tr><td colspan="3" style="text-align: center; color: #999;">暂无参数，点击下方按钮添加</td></tr>';
            }
        }

        // 添加参数
        function addParameter() {
            const material = materialsData.find(m => m.id === currentDetailMaterialId);
            if (!material) return;

            if (material.parameters.length >= 10) {
                alert('最多只能添加10个参数！');
                return;
            }

            material.parameters.push({ name: '', value: '' });
            renderParameters();
        }

        // 更新参数
        function updateParameter(index, field, value) {
            const material = materialsData.find(m => m.id === currentDetailMaterialId);
            if (!material) return;

            material.parameters[index][field] = value;
        }

        // 删除参数
        function removeParameter(index) {
            const material = materialsData.find(m => m.id === currentDetailMaterialId);
            if (!material) return;

            material.parameters.splice(index, 1);
            renderParameters();
        }

        // 选中的替代料索引
        let selectedAlternatives = new Set();

        // 渲染替代料列表
        function renderAlternatives() {
            // 使用 loadAlternativesData 来渲染替代件表格
            if (currentDetailMaterialId) {
                loadAlternativesData(currentDetailMaterialId);
            }
        }

        // 切换替代料选择
        function toggleAltSelection(index) {
            if (selectedAlternatives.has(index)) {
                selectedAlternatives.delete(index);
            } else {
                selectedAlternatives.add(index);
            }
            renderAlternatives();
        }

        // 更新选择栏
        function updateAltSelectionBar() {
            const bar = document.getElementById('comparisonBar');
            const count = selectedAlternatives.size;

            if (count > 0) {
                bar.classList.add('active');
                document.getElementById('selectedAltCount').textContent = count;
            } else {
                bar.classList.remove('active');
            }
        }

        // 清除选择
        function clearAltSelection() {
            selectedAlternatives.clear();
            renderAlternatives();
        }

        // AI对比替代料
        function compareAlternatives() {
            if (selectedAlternatives.size === 0) {
                alert('请至少选择一个替代料进行对比！');
                return;
            }

            const material = materialsData.find(m => m.id === currentDetailMaterialId);
            if (!material) return;

            // 准备对比数据
            const materials = [material];
            selectedAlternatives.forEach(index => {
                const alt = material.alternatives[index];
                // 模拟查找替代料的完整数据
                const altMaterial = {
                    mpn: alt.mpn,
                    manufacturer: alt.manufacturer,
                    parameters: [
                        { name: '工作电压', value: '1.8V - 3.6V' },
                        { name: '核心架构', value: '16-bit RISC' },
                        { name: '主频', value: alt.mpn.includes('STM32') ? '72MHz' : '25MHz' },
                        { name: 'Flash容量', value: alt.mpn.includes('STM32') ? '64KB' : '128KB' }
                    ]
                };
                materials.push(altMaterial);
            });

            // 生成AI分析
            generateAIAnalysis(materials);

            // 生成对比表格
            renderComparisonTable(materials);

            // 显示对比模态框
            document.getElementById('comparisonModal').classList.add('active');
        }

        // 生成AI分析
        function generateAIAnalysis(materials) {
            const container = document.getElementById('aiAnalysis');

            let analysis = `✅ <strong>综合分析：</strong><br>`;
            analysis += `基于对 ${materials.length} 个物料的参数对比，主要差异在以下几个方面：<br><br>`;

            if (materials.length > 1) {
                analysis += `• <strong>性能对比：</strong>${materials[0].mpn} 作为原始物料，具有 ${materials[0].parameters.find(p => p.name === 'Flash容量')?.value || '-'} 的Flash容量。`;
                if (materials[1].mpn.includes('STM32')) {
                    analysis += `而 ${materials[1].mpn} 虽然Flash较小，但主频更高，适合需要更快处理速度的应用。<br>`;
                } else {
                    analysis += `${materials[1].mpn} 参数相近，可作为直接替代。<br>`;
                }

                analysis += `<br>• <strong>推荐建议：</strong>`;
                analysis += `如果您的应用对存储容量要求较高，建议使用 ${materials[0].mpn}。`;
                analysis += `如果更看重处理速度，${materials.find(m => m.mpn.includes('STM32'))?.mpn || materials[1].mpn} 可能是更好的选择。<br>`;

                analysis += `<br>• <strong>兼容性：</strong>这些器件的引脚封装和工作电压范围相似，在硬件设计上可以相互替代，但需要注意软件代码的移植工作。`;
            }

            container.innerHTML = analysis;
        }

        // 渲染对比表格
        function renderComparisonTable(materials) {
            const header = document.getElementById('comparisonHeader');
            const body = document.getElementById('comparisonBody');

            // 清空
            header.innerHTML = '<th style="min-width: 120px;">参数</th>';
            body.innerHTML = '';

            // 添加物料列头
            materials.forEach(mat => {
                const th = document.createElement('th');
                th.style.minWidth = '150px';
                th.innerHTML = `<strong>${mat.mpn}</strong><br><small style="color: #999;">${mat.manufacturer}</small>`;
                header.appendChild(th);
            });

            // 收集所有参数名
            const allParams = new Set();
            materials.forEach(mat => {
                if (mat.parameters) {
                    mat.parameters.forEach(p => allParams.add(p.name));
                }
            });

            // 生成参数行
            allParams.forEach(paramName => {
                const tr = document.createElement('tr');
                const th = document.createElement('th');
                th.textContent = paramName;
                th.style.background = '#f9f9f9';
                tr.appendChild(th);

                materials.forEach(mat => {
                    const td = document.createElement('td');
                    const param = mat.parameters?.find(p => p.name === paramName);
                    td.textContent = param ? param.value : '-';
                    tr.appendChild(td);
                });

                body.appendChild(tr);
            });
        }

        // 关闭对比模态框
        function closeComparisonModal() {
            document.getElementById('comparisonModal').classList.remove('active');
        }

        // 添加替代料
        function addAlternative() {
            const mpn = prompt('请输入替代料型号:');
            if (!mpn) return;

            const manufacturer = prompt('请输入替代料制造商:');
            if (!manufacturer) return;

            const material = materialsData.find(m => m.id === currentDetailMaterialId);
            if (!material) return;

            material.alternatives.push({ mpn, manufacturer });
            renderAlternatives();
        }

        // 删除替代料
        function removeAlternative(index) {
            const material = materialsData.find(m => m.id === currentDetailMaterialId);
            if (!material) return;

            material.alternatives.splice(index, 1);
            renderAlternatives();
        }

        // 渲染文件列表
        function renderFileList(material) {
            const container = document.getElementById('fileList');
            container.innerHTML = '';

            const files = [
                { type: 'datasheet', name: 'PDF数据手册', icon: '📄' },
                { type: 'schematic', name: '原理图符号', icon: '🔌' },
                { type: 'footprint', name: 'PCB封装', icon: '📐' },
                { type: 'model3d', name: '3D模型', icon: '🎲' }
            ];

            files.forEach(fileInfo => {
                if (material.files && material.files[fileInfo.type]) {
                    const div = document.createElement('div');
                    div.style.cssText = 'padding: 12px; background: #f9f9f9; border-radius: 6px; border: 1px solid #e0e0e0;';
                    div.innerHTML = `
                        <div style="display: flex; align-items: center; justify-content: space-between;">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span style="font-size: 24px;">${fileInfo.icon}</span>
                                <div>
                                    <div style="font-size: 13px; font-weight: 600;">${fileInfo.name}</div>
                                    <div style="font-size: 11px; color: #666;">${material.files[fileInfo.type].name || '已上传'}</div>
                                </div>
                            </div>
                            <button class="file-download-btn" onclick="downloadFile('${fileInfo.type}')">
                                <span>📥</span> 下载
                            </button>
                        </div>
                    `;
                    container.appendChild(div);
                }
            });

            if (container.children.length === 0) {
                container.innerHTML = '<div style="text-align: center; color: #999; padding: 20px; grid-column: 1 / -1;">暂无上传的设计文件</div>';
            }
        }

        // 下载文件
        function downloadFile(type) {
            alert(`下载 ${type} 文件功能。\n\n实际应用中，这里会触发文件下载。`);
        }

        // 保存详情修改
        function saveDetailChanges() {
            const material = materialsData.find(m => m.id === currentDetailMaterialId);
            if (!material) return;

            // 数据已经在编辑时实时更新了
            alert('物料详情已保存！');
            closeDetailModal();
            renderCurrentView();
        }

        // 关闭详情模态框
        function closeDetailModal() {
            document.getElementById('detailModal').classList.remove('active');
            currentDetailMaterialId = null;
        }

        // 切换详情页TAB
        function switchDetailTab(event, tabId) {
            // 移除所有TAB的active类
            const tabs = document.querySelectorAll('.detail-tab');
            tabs.forEach(tab => tab.classList.remove('active'));

            // 添加当前TAB的active类
            event.currentTarget.classList.add('active');

            // 隐藏所有TAB内容
            const tabContents = document.querySelectorAll('#detailModal .tab-content');
            tabContents.forEach(content => content.classList.remove('active'));

            // 显示选中的TAB内容
            document.getElementById(tabId).classList.add('active');

            // 如果切换到用途查询标签页，渲染数据
            if (tabId === 'tab-where-used' && currentDetailMaterialId) {
                const material = materialsData.find(m => m.id === currentDetailMaterialId);
                if (material) {
                    renderWhereUsedData(material.internalNumber);
                }
            }
        }

        // 渲染用途查询数据
        function renderWhereUsedData(materialCode) {
            const whereUsed = materialWhereUsed[materialCode] || [];

            // 更新统计数据
            const bomCount = whereUsed.length;
            const totalQty = whereUsed.reduce((sum, item) => sum + item.quantity, 0);
            const lastDate = whereUsed.length > 0 ? whereUsed[0].lastModified : '-';

            document.getElementById('whereUsedBomCount').textContent = bomCount;
            document.getElementById('whereUsedTotalQty').textContent = totalQty;
            document.getElementById('whereUsedLastDate').textContent = lastDate;

            // 渲染BOM列表
            const bomListHtml = whereUsed.length === 0 ? `
                <div style="padding: 60px 20px; text-align: center; color: #999;">
                    <div style="font-size: 64px; margin-bottom: 16px;">📭</div>
                    <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">暂无使用记录</div>
                    <div style="font-size: 14px;">该物料尚未在任何BOM中使用</div>
                </div>
            ` : whereUsed.map(item => {
                const statusColors = {
                    'active': { bg: '#e8f5e9', text: '#00890b', label: '进行中' },
                    'archived': { bg: '#f5f5f5', text: '#999', label: '已归档' }
                };
                const statusStyle = statusColors[item.status] || statusColors['active'];

                return `
                    <div style="padding: 20px 24px; border-bottom: 1px solid #e0e0e0; transition: background 0.3s;"
                         onmouseover="this.style.background='#f9f9f9'"
                         onmouseout="this.style.background='white'">
                        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 12px;">
                            <div style="flex: 1;">
                                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                                    <a href="bom-detail.html?code=${item.bomCode}"
                                       onclick="goToBomDetail('${item.bomCode}'); return false;"
                                       style="font-size: 16px; font-weight: 700; color: #197bc0; text-decoration: none; cursor: pointer;"
                                       onmouseover="this.style.textDecoration='underline'"
                                       onmouseout="this.style.textDecoration='none'">
                                        ${item.bomName}
                                    </a>
                                    <span style="background: ${statusStyle.bg}; color: ${statusStyle.text}; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 600;">
                                        ${statusStyle.label}
                                    </span>
                                </div>
                                <div style="font-size: 13px; color: #666; margin-bottom: 4px;">
                                    📁 项目：${item.projectName} | BOM编号：${item.bomCode}
                                </div>
                                <div style="font-size: 13px; color: #999;">
                                    🕒 最后修改：${item.lastModified}
                                </div>
                            </div>
                            <div style="text-align: right; min-width: 120px;">
                                <div style="font-size: 24px; font-weight: 700; color: #00890b; margin-bottom: 4px;">
                                    ${item.quantity} ${item.unit}
                                </div>
                                <div style="font-size: 12px; color: #666;">
                                    位号：${item.designator}
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            document.getElementById('whereUsedBomList').innerHTML = bomListHtml;
        }

        // 跳转到BOM详情页
        function goToBomDetail(bomCode) {
            if (confirm(`🔗 即将跳转到BOM详情页\n\nBOM编号: ${bomCode}\n\n是否继续？`)) {
                window.location.href = `bom-detail.html?code=${encodeURIComponent(bomCode)}`;
            }
        }

        function editMaterial(id) {
            const material = materialsData.find(m => m.id === id);
            if (!material) return;

            editingMaterialId = id;
            document.getElementById('modalTitle').textContent = '✏️ 编辑物料';
            document.getElementById('editMaterialId').value = id;

            // 填充表单
            document.getElementById('internalNumber').value = material.internalNumber;
            document.getElementById('matName').value = material.name;
            document.getElementById('matCategory').value = material.category === 'MCU' ? 'mcu' :
                                                           material.category === '电阻' ? 'r' :
                                                           material.category === '电容' ? 'c' : 'other';
            document.getElementById('manufacturer').value = material.manufacturer;
            document.getElementById('mpn').value = material.mpn;
            document.getElementById('package').value = material.package;
            document.getElementById('websiteUrl').value = material.websiteUrl || '';
            document.getElementById('specs').value = material.specs;
            document.getElementById('remarks').value = '';

            // 显示图片
            if (material.image) {
                uploadedFiles.image = material.image;
                document.getElementById('imagePreview').innerHTML = `<img src="${material.image}" alt="Preview">`;
            }

            // 编辑模式下隐藏云端查询和个人空间导入功能
            document.getElementById('cloudSearchImport').style.display = 'none';
            document.getElementById('personalSpaceImport').style.display = 'none';

            document.getElementById('materialModal').classList.add('active');
        }

        function copyMaterial(id) {
            const material = materialsData.find(m => m.id === id);
            if (!material) return;

            const newMaterial = {
                ...material,
                id: materialsData.length + 1,
                internalNumber: material.internalNumber + '-COPY',
                status: 'pending'
            };

            materialsData.push(newMaterial);
            applyFilters();
            alert('物料已复制！');
        }

        // 查看规格书
        function viewSpecSheet(url, mpn) {
            if (!url) {
                alert('暂无规格书！');
                return;
            }

            // 创建模态框显示规格书
            const modal = document.createElement('div');
            modal.className = 'modal-overlay active';
            modal.innerHTML = `
                <div class="modal-content" style="max-width: 900px; height: 90vh;">
                    <div class="modal-header">
                        <div class="modal-title">📄 ${mpn} - 规格书</div>
                        <button class="modal-close" onclick="this.closest('.modal-overlay').remove()">×</button>
                    </div>
                    <div class="modal-body" style="padding: 0; height: calc(100% - 120px);">
                        <iframe src="${url}" style="width: 100%; height: 100%; border: none;" frameborder="0"></iframe>
                    </div>
                    <div class="modal-footer">
                        <button class="btn-secondary" onclick="window.open('${url}', '_blank')">在新窗口打开</button>
                        <button class="btn-secondary" onclick="this.closest('.modal-overlay').remove()">关闭</button>
                    </div>
                </div>
            `;
            document.body.appendChild(modal);

            // 点击外部关闭
            modal.addEventListener('click', function(e) {
                if (e.target === modal) {
                    modal.remove();
                }
            });
        }

        function deleteMaterial(id) {
            if (confirm('确定要删除这条物料记录吗？')) {
                const index = materialsData.findIndex(item => item.id === id);
                if (index > -1) {
                    materialsData.splice(index, 1);
                    applyFilters();
                    alert('删除成功！');
                }
            }
        }

        function bulkDelete() {
            if (selectedItems.size === 0) return;

            if (confirm(`确定要删除选中的 ${selectedItems.size} 条记录吗？`)) {
                selectedItems.forEach(id => {
                    const index = materialsData.findIndex(item => item.id === id);
                    if (index > -1) {
                        materialsData.splice(index, 1);
                    }
                });
                selectedItems.clear();
                applyFilters();
                alert('批量删除成功！');
            }
        }

        // 导入导出
        function exportMaterials() {
            // 生成CSV数据
            const headers = ['内部编号', '物料名称', '原厂型号', '制造商', '封装', '分类', '规格描述', '库存', '状态', '来源项目', '官网链接'];
            let csv = headers.join(',') + '\n';

            filteredData.forEach(item => {
                const row = [
                    item.internalNumber,
                    `"${item.name}"`,
                    item.mpn,
                    item.manufacturer,
                    item.package,
                    item.category,
                    `"${item.specs}"`,
                    item.stock,
                    item.status === 'active' ? '活跃' : item.status === 'inactive' ? '停用' : '待审核',
                    item.sourceProject,
                    item.websiteUrl || ''
                ];
                csv += row.join(',') + '\n';
            });

            // 创建下载链接
            const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            link.setAttribute('href', url);
            link.setAttribute('download', `物料列表_${new Date().toLocaleDateString()}.csv`);
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);

            alert('导出成功！文件已下载。');
        }

        function openImportDialog() {
            document.getElementById('importModal').classList.add('active');
        }

        function closeImportModal() {
            document.getElementById('importModal').classList.remove('active');
            document.getElementById('importFile').value = '';
            document.getElementById('importFileName').textContent = '';
            document.getElementById('importFileArea').classList.remove('has-file');
        }

        function handleImportFileSelect(event) {
            const file = event.target.files[0];
            if (file) {
                document.getElementById('importFileName').textContent = file.name;
                document.getElementById('importFileArea').classList.add('has-file');
            }
        }

        function downloadTemplate() {
            const headers = ['内部编号*', '物料名称*', '原厂型号', '制造商*', '封装', '分类*', '规格描述', '库存', '状态', '来源项目', '官网链接'];
            const example = ['MT-IC-2024-0001', 'TI MCU - MSP430F5529', 'MSP430F5529IPNR', 'Texas Instruments', 'LQFP-80', 'MCU', '16-bit RISC, 25MHz, 128KB Flash', '1200', 'active', '智能仪表项目', 'https://www.ti.com'];

            let csv = headers.join(',') + '\n';
            csv += example.join(',') + '\n';

            const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            link.setAttribute('href', url);
            link.setAttribute('download', '物料导入模板.csv');
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);

            alert('模板已下载！请按照模板格式填写数据后导入。');
        }

        function submitImport() {
            const fileInput = document.getElementById('importFile');
            if (!fileInput.files.length) {
                alert('请先选择要导入的文件！');
                return;
            }

            // 这里应该有实际的文件解析和导入逻辑
            // 简化演示：模拟导入成功
            alert('导入成功！已导入 5 条物料数据。\n\n注意：实际应用中需要解析Excel/CSV文件并验证数据。');
            closeImportModal();
            renderCurrentView();
        }

        // 新建物料
        function openNewMaterialDialog() {
            try {
                console.log('Opening new material dialog...');

                editingMaterialId = null;

                // 设置标题
                const modalTitle = document.getElementById('modalTitle');
                if (modalTitle) modalTitle.textContent = '📦 新建物料';

                // 重置隐藏字段
                const editId = document.getElementById('editMaterialId');
                if (editId) editId.value = '';

                // 重置表单
                const form = document.getElementById('materialForm');
                if (form) form.reset();

                // 重置图片预览
                uploadedFiles = {
                    image: null,
                    datasheet: null,
                    schematic: null,
                    footprint: null,
                    model3d: null
                };

                const imagePreview = document.getElementById('imagePreview');
                if (imagePreview) {
                    imagePreview.innerHTML = `
                        <div class="image-placeholder">
                            <div class="image-placeholder-icon">📷</div>
                            <div>点击上传产品图片</div>
                            <div style="font-size: 12px; color: #999; margin-top: 4px;">支持 JPG, PNG 格式</div>
                        </div>
                    `;
                }

                // 重置文件上传区域
                ['datasheet', 'schematic', 'footprint', 'model3d'].forEach(type => {
                    const nameElement = document.getElementById(type + 'Name');
                    const areaElement = document.getElementById(type + 'Area');
                    if (nameElement) nameElement.textContent = '';
                    if (areaElement) areaElement.classList.remove('has-file');
                });

                // 新建模式下显示云端查询和个人空间导入功能
                const cloudSearchImport = document.getElementById('cloudSearchImport');
                const personalSpaceImport = document.getElementById('personalSpaceImport');
                if (cloudSearchImport) cloudSearchImport.style.display = 'block';
                if (personalSpaceImport) personalSpaceImport.style.display = 'block';

                // 添加自动填充编号的事件监听器
                const categorySelect = document.getElementById('matCategory');
                const packageInput = document.getElementById('package');

                if (categorySelect) {
                    // 移除之前的监听器（如果有）
                    categorySelect.removeEventListener('change', autoFillMaterialNumber);
                    // 添加新的监听器
                    categorySelect.addEventListener('change', autoFillMaterialNumber);
                }

                if (packageInput) {
                    // 移除之前的监听器（如果有）
                    packageInput.removeEventListener('blur', autoFillMaterialNumber);
                    // 添加新的监听器
                    packageInput.addEventListener('blur', autoFillMaterialNumber);
                }

                // 显示模态框
                const modal = document.getElementById('materialModal');
                if (modal) {
                    console.log('Adding active class to modal');
                    modal.classList.add('active');
                    console.log('Modal should now be visible');
                } else {
                    console.error('Modal element not found!');
                }
            } catch (error) {
                console.error('Error opening material dialog:', error);
                alert('打开添加物料对话框时出错：' + error.message);
            }
        }

        function closeMaterialModal() {
            document.getElementById('materialModal').classList.remove('active');
            editingMaterialId = null;
        }

        function submitMaterial() {
            const internalNumber = document.getElementById('internalNumber').value;
            const name = document.getElementById('matName').value;
            const category = document.getElementById('matCategory').value;
            const manufacturer = document.getElementById('manufacturer').value;
            const mpn = document.getElementById('mpn').value;
            const packageType = document.getElementById('package').value;
            const websiteUrl = document.getElementById('websiteUrl').value;
            const specs = document.getElementById('specs').value;

            if (!internalNumber || !name || !category || !manufacturer) {
                alert('请填写所有必填项！');
                return;
            }

            const categoryNames = {
                'ic': '集成电路 (IC)',
                'mcu': 'MCU',
                'r': '电阻',
                'c': '电容',
                'con': '连接器',
                'sensor': '传感器',
                'led': 'LED',
                'other': '其他'
            };

            if (editingMaterialId) {
                // 编辑模式
                const index = materialsData.findIndex(m => m.id === editingMaterialId);
                if (index > -1) {
                    materialsData[index] = {
                        ...materialsData[index],
                        internalNumber,
                        name,
                        mpn: mpn || 'N/A',
                        manufacturer,
                        package: packageType || 'N/A',
                        category: categoryNames[category],
                        websiteUrl,
                        specs: specs || 'N/A',
                        image: uploadedFiles.image || materialsData[index].image,
                        files: uploadedFiles
                    };
                    alert('物料更新成功！');
                }
            } else {
                // 新建模式
                const newMaterial = {
                    id: materialsData.length + 1,
                    internalNumber,
                    mpn: mpn || 'N/A',
                    name,
                    specs: specs || 'N/A',
                    stock: 0,
                    manufacturer,
                    package: packageType || 'N/A',
                    category: categoryNames[category],
                    status: 'pending',
                    sourceProject: '手动创建',
                    websiteUrl,
                    image: uploadedFiles.image,
                    files: uploadedFiles
                };

                materialsData.push(newMaterial);

                // 递增该分类的计数器
                if (numberingRules[category]) {
                    numberingRules[category].counter++;
                }

                alert(`物料创建成功！\n\n内部编号: ${internalNumber}\n名称: ${name}\n分类: ${categoryNames[category]}\n制造商: ${manufacturer}`);
            }

            closeMaterialModal();
            applyFilters();
        }

        // ==================== 物料AI助手功能 ====================
        let materialAIAnalysisHistory = [];
        let currentMaterialAIFunction = null;

        const aiFunctionNames = {
            'parameter-extraction': '参数智能提取',
            'alternative-recommendation': '替代料智能推荐',
            'application-analysis': '应用场景分析',
            'circuit-design': '电路设计建议',
            'reliability-assessment': '可靠性评估',
            'cost-analysis': '成本优化分析',
            'selection-comparison': '选型对比分析',
            'spec-interpretation': '技术规格解读',
            'supply-chain': '供应链分析',
            'pdf-datasheet-analysis': 'PDF数据手册智能解读'
        };

        function selectAIFunction(functionType) {
            const material = materialsData.find(m => m.id === currentDetailMaterialId);
            if (!material) return;

            currentMaterialAIFunction = functionType;

            // PDF数据手册解读使用问答模式
            if (functionType === 'pdf-datasheet-analysis') {
                openPDFDatasheetQA(material);
                return;
            }

            // 其他功能显示加载状态
            document.getElementById('aiAnalysisFunctions').style.display = 'none';
            document.getElementById('materialAIResult').style.display = 'block';
            document.getElementById('currentAIFunctionTitle').textContent = aiFunctionNames[functionType];

            const resultContent = document.getElementById('materialAIResultContent');
            resultContent.innerHTML = `
                <div style="text-align: center; padding: 60px 40px;">
                    <div style="font-size: 64px; margin-bottom: 24px; animation: pulse 1.5s ease-in-out infinite;">🤖</div>
                    <div style="font-size: 18px; font-weight: 600; color: #3d4647; margin-bottom: 12px;">AI正在分析...</div>
                    <div style="font-size: 14px; color: #999; margin-bottom: 24px;">
                        正在为 ${material.mpn} 执行${aiFunctionNames[functionType]}
                    </div>
                    <div style="width: 300px; height: 6px; background: #f0f0f0; border-radius: 3px; margin: 0 auto; overflow: hidden;">
                        <div style="width: 70%; height: 100%; background: linear-gradient(90deg, #197bc0, #00890b); border-radius: 3px; animation: loading 2s ease-in-out infinite;"></div>
                    </div>
                    <style>
                        @keyframes pulse {
                            0%, 100% { transform: scale(1); }
                            50% { transform: scale(1.1); }
                        }
                        @keyframes loading {
                            0% { transform: translateX(-100%); }
                            100% { transform: translateX(400%); }
                        }
                    </style>
                </div>
            `;

            // 滚动到顶部
            document.querySelector('#tab-ai-assistant').scrollTop = 0;

            // 模拟AI分析（实际应用中调用后端API）
            setTimeout(() => {
                let analysisHTML = '';

                switch (functionType) {
                    case 'parameter-extraction':
                        analysisHTML = generateParameterExtractionResult(material);
                        break;
                    case 'alternative-recommendation':
                        analysisHTML = generateAlternativeRecommendationResult(material);
                        break;
                    case 'application-analysis':
                        analysisHTML = generateApplicationAnalysisResult(material);
                        break;
                    case 'circuit-design':
                        analysisHTML = generateCircuitDesignResult(material);
                        break;
                    case 'cost-analysis':
                        analysisHTML = generateCostAnalysisResult(material);
                        break;
                    case 'selection-comparison':
                        analysisHTML = generateSelectionComparisonResult(material);
                        break;
                    case 'spec-interpretation':
                        analysisHTML = generateSpecInterpretationResult(material);
                        break;
                    case 'supply-chain':
                        analysisHTML = generateSupplyChainAnalysisResult(material);
                        break;
                    case 'pdf-datasheet-analysis':
                        analysisHTML = generatePDFDatasheetAnalysisResult(material);
                        break;
                }

                resultContent.innerHTML = analysisHTML;

                // 保存到历史
                materialAIAnalysisHistory.unshift({
                    id: Date.now(),
                    type: functionType,
                    materialId: material.id,
                    materialMPN: material.mpn,
                    time: new Date().toLocaleString('zh-CN')
                });

                // 显示历史记录
                if (materialAIAnalysisHistory.length > 0) {
                    document.getElementById('materialAIHistory').style.display = 'block';
                    updateMaterialAIHistory();
                }
            }, 2500);
        }

        function generateParameterExtractionResult(material) {
            return `
                <h4 style="font-size: 18px; font-weight: 700; margin-bottom: 20px;">📊 参数智能提取结果</h4>

                <div style="background: #e8f5e9; border-left: 4px solid #00890b; padding: 16px; border-radius: 8px; margin-bottom: 24px;">
                    <div style="font-weight: 600; color: #00890b; margin-bottom: 8px;">✅ 成功提取 ${material.parameters ? material.parameters.length : 6} 个关键参数</div>
                    <div style="font-size: 13px; color: #666;">
                        AI已自动从数据手册中识别并提取了${material.mpn}的技术参数，包括电气特性、机械特性和环境参数。
                    </div>
                </div>

                <div style="background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 20px; margin-bottom: 20px;">
                    <h5 style="font-size: 15px; font-weight: 600; margin-bottom: 16px;">提取的参数列表</h5>
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: #f5f5f5;">
                                <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">参数名称</th>
                                <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">参数值</th>
                                <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">置信度</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${(material.parameters || [
                                { name: '工作电压', value: '1.8V - 3.6V' },
                                { name: '核心架构', value: '16-bit RISC' },
                                { name: '主频', value: '25MHz' },
                                { name: 'Flash容量', value: '128KB' },
                                { name: 'RAM容量', value: '8KB' },
                                { name: '工作温度', value: '-40°C ~ 85°C' }
                            ]).map(param => `
                                <tr>
                                    <td style="padding: 10px; border-bottom: 1px solid #f0f0f0;">${param.name}</td>
                                    <td style="padding: 10px; border-bottom: 1px solid #f0f0f0; font-weight: 600; color: #00890b;">${param.value}</td>
                                    <td style="padding: 10px; border-bottom: 1px solid #f0f0f0;">
                                        <span style="background: #e8f5e9; color: #00890b; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 600;">98%</span>
                                    </td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>

                <div style="background: #fff8e1; border-left: 4px solid #f57c00; padding: 16px; border-radius: 8px;">
                    <div style="font-weight: 600; color: #e65100; margin-bottom: 8px;">💡 AI建议</div>
                    <ul style="font-size: 13px; color: #666; line-height: 1.8; margin: 0; padding-left: 20px;">
                        <li>建议手动审核并确认所有提取的参数值</li>
                        <li>可以点击"保存"按钮将这些参数添加到物料库</li>
                        <li>部分参数可能有多个测试条件，建议查看完整数据手册</li>
                    </ul>
                </div>
            `;
        }

        function generateAlternativeRecommendationResult(material) {
            const alternatives = [
                { mpn: 'MSP430F5528IPNR', manufacturer: 'Texas Instruments', similarity: 95, cost: '+5%', availability: '良好' },
                { mpn: 'STM32F103C8T6', manufacturer: 'STMicroelectronics', similarity: 78, cost: '-12%', availability: '优秀' },
                { mpn: 'GD32F103C8T6', manufacturer: 'GigaDevice', similarity: 76, cost: '-35%', availability: '优秀' }
            ];

            return `
                <h4 style="font-size: 18px; font-weight: 700; margin-bottom: 20px;">🔄 替代料智能推荐</h4>

                <div style="background: #f0f8ff; border-left: 4px solid #197bc0; padding: 16px; border-radius: 8px; margin-bottom: 24px;">
                    <div style="font-weight: 600; color: #197bc0; margin-bottom: 8px;">AI为您推荐 ${alternatives.length} 个替代方案</div>
                    <div style="font-size: 13px; color: #666;">
                        基于参数相似度、成本效益和供应链可靠性，以下是${material.mpn}的最佳替代料。
                    </div>
                </div>

                ${alternatives.map((alt, index) => `
                    <div style="background: white; border: ${index === 0 ? '2px solid #00890b' : '1px solid #e0e0e0'}; border-radius: 12px; padding: 20px; margin-bottom: 16px; position: relative;">
                        ${index === 0 ? '<div style="position: absolute; top: -12px; right: 20px; background: #00890b; color: white; padding: 6px 16px; border-radius: 16px; font-size: 12px; font-weight: 600;">推荐</div>' : ''}
                        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 16px;">
                            <div>
                                <h5 style="font-size: 16px; font-weight: 700; margin: 0 0 4px 0;">${alt.mpn}</h5>
                                <div style="font-size: 13px; color: #7f8c8d;">${alt.manufacturer}</div>
                            </div>
                            <div style="text-align: right;">
                                <div style="font-size: 24px; font-weight: 700; color: #00890b;">${alt.similarity}%</div>
                                <div style="font-size: 11px; color: #999;">相似度</div>
                            </div>
                        </div>

                        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; padding: 12px; background: #f9f9f9; border-radius: 6px;">
                            <div>
                                <div style="font-size: 11px; color: #999; margin-bottom: 4px;">成本差异</div>
                                <div style="font-size: 14px; font-weight: 600; color: ${alt.cost.startsWith('-') ? '#00890b' : '#f57c00'};">${alt.cost}</div>
                            </div>
                            <div>
                                <div style="font-size: 11px; color: #999; margin-bottom: 4px;">供应情况</div>
                                <div style="font-size: 14px; font-weight: 600; color: #197bc0;">${alt.availability}</div>
                            </div>
                            <div>
                                <div style="font-size: 11px; color: #999; margin-bottom: 4px;">推荐指数</div>
                                <div style="font-size: 14px; font-weight: 600;">★★★★${index === 0 ? '★' : '☆'}</div>
                            </div>
                        </div>

                        <button onclick="alert('查看${alt.mpn}详细对比')" style="margin-top: 12px; width: 100%; padding: 10px; background: #f0f8ff; border: 1px solid #197bc0; color: #197bc0; border-radius: 6px; cursor: pointer; font-weight: 600;">
                            查看详细对比 →
                        </button>
                    </div>
                `).join('')}
            `;
        }

        function generateApplicationAnalysisResult(material) {
            return `
                <h4 style="font-size: 18px; font-weight: 700; margin-bottom: 20px;">💡 应用场景分析</h4>

                <div style="background: white; border: 1px solid #e0e0e0; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                    <h5 style="font-size: 15px; font-weight: 600; margin-bottom: 16px;">🎯 典型应用场景</h5>
                    <div style="display: grid; gap: 12px;">
                        <div style="padding: 12px; background: #f0f8ff; border-left: 4px solid #197bc0; border-radius: 4px;">
                            <div style="font-weight: 600; margin-bottom: 4px;">智能仪表</div>
                            <div style="font-size: 13px; color: #666;">适用于电表、水表、燃气表等低功耗计量设备</div>
                        </div>
                        <div style="padding: 12px; background: #f0f8ff; border-left: 4px solid #197bc0; border-radius: 4px;">
                            <div style="font-weight: 600; margin-bottom: 4px;">便携式医疗设备</div>
                            <div style="font-size: 13px; color: #666;">血糖仪、血压计等需要超低功耗的医疗设备</div>
                        </div>
                        <div style="padding: 12px; background: #f0f8ff; border-left: 4px solid #197bc0; border-radius: 4px;">
                            <div style="font-weight: 600; margin-bottom: 4px;">传感器节点</div>
                            <div style="font-size: 13px; color: #666;">无线传感器网络节点，环境监测设备</div>
                        </div>
                    </div>
                </div>

                <div style="background: white; border: 1px solid #e0e0e0; border-radius: 12px; padding: 20px;">
                    <h5 style="font-size: 15px; font-weight: 600; margin-bottom: 16px;">⚙️ 外围电路建议</h5>
                    <ul style="font-size: 13px; color: #3d4647; line-height: 2; margin: 0; padding-left: 20px;">
                        <li>使用0.1μF和10μF电容对VDD引脚进行退耦</li>
                        <li>32.768kHz晶振配置12.5pF负载电容</li>
                        <li>复位引脚接10kΩ上拉电阻</li>
                        <li>调试接口预留JTAG或SBW接口</li>
                        <li>电源部分建议使用LDO稳压器获得更低噪声</li>
                    </ul>
                </div>
            `;
        }

        function generateCircuitDesignResult(material) {
            return `
                <h4 style="font-size: 18px; font-weight: 700; margin-bottom: 20px;">🔌 电路设计建议</h4>

                <div style="background: #e8f5e9; border-left: 4px solid #00890b; padding: 16px; border-radius: 8px; margin-bottom: 20px;">
                    <div style="font-weight: 600; color: #00890b; margin-bottom: 8px;">✅ AI已分析${material.mpn}的设计要点</div>
                    <div style="font-size: 13px; color: #666;">
                        基于厂商应用手册和最佳实践，提供以下电路设计和PCB布局建议。
                    </div>
                </div>

                <div style="background: white; border: 1px solid #e0e0e0; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                    <h5 style="font-size: 15px; font-weight: 600; margin-bottom: 16px;">🎨 PCB布局要点</h5>
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
                        <div style="padding: 16px; background: #f9f9f9; border-radius: 8px;">
                            <div style="font-weight: 600; margin-bottom: 8px;">⚡ 电源部分</div>
                            <ul style="font-size: 12px; color: #666; margin: 0; padding-left: 16px; line-height: 1.8;">
                                <li>VDD和VSS引脚尽量靠近</li>
                                <li>退耦电容距离引脚<5mm</li>
                                <li>电源平面使用20mil以上走线</li>
                            </ul>
                        </div>
                        <div style="padding: 16px; background: #f9f9f9; border-radius: 8px;">
                            <div style="font-weight: 600; margin-bottom: 8px;">🕐 时钟部分</div>
                            <ul style="font-size: 12px; color: #666; margin: 0; padding-left: 16px; line-height: 1.8;">
                                <li>晶振紧靠MCU放置</li>
                                <li>负载电容走线保持对称</li>
                                <li>晶振下方铺地平面</li>
                            </ul>
                        </div>
                        <div style="padding: 16px; background: #f9f9f9; border-radius: 8px;">
                            <div style="font-weight: 600; margin-bottom: 8px;">📡 高速信号</div>
                            <ul style="font-size: 12px; color: #666; margin: 0; padding-left: 16px; line-height: 1.8;">
                                <li>SPI/I2C走线尽量短</li>
                                <li>避免走线直角转弯</li>
                                <li>远离晶振等敏感电路</li>
                            </ul>
                        </div>
                        <div style="padding: 16px; background: #f9f9f9; border-radius: 8px;">
                            <div style="font-weight: 600; margin-bottom: 8px;">🌡️ 热设计</div>
                            <ul style="font-size: 12px; color: #666; margin: 0; padding-left: 16px; line-height: 1.8;">
                                <li>散热焊盘连接到地平面</li>
                                <li>避免大面积铜箔重叠</li>
                                <li>预留温度监测点</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div style="background: #fff8e1; border-left: 4px solid #f57c00; padding: 16px; border-radius: 8px;">
                    <div style="font-weight: 600; color: #e65100; margin-bottom: 8px;">⚠️ 设计注意事项</div>
                    <ul style="font-size: 13px; color: #666; line-height: 1.8; margin: 0; padding-left: 20px;">
                        <li>未使用的GPIO应配置为输入+上拉/下拉，避免浮空</li>
                        <li>模拟和数字地建议在单点连接</li>
                        <li>所有外部中断引脚建议增加RC滤波防抖</li>
                    </ul>
                </div>
            `;
        }

        function generateReliabilityAssessmentResult(material) {
            return `
                <h4 style="font-size: 18px; font-weight: 700; margin-bottom: 20px;">🛡️ 可靠性评估</h4>

                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
                    <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 12px; text-align: center;">
                        <div style="font-size: 32px; font-weight: 700; margin-bottom: 8px;">A+</div>
                        <div style="font-size: 13px; opacity: 0.9;">综合评级</div>
                    </div>
                    <div style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; padding: 20px; border-radius: 12px; text-align: center;">
                        <div style="font-size: 32px; font-weight: 700; margin-bottom: 8px;">10年</div>
                        <div style="font-size: 13px; opacity: 0.9;">预期寿命</div>
                    </div>
                    <div style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; padding: 20px; border-radius: 12px; text-align: center;">
                        <div style="font-size: 32px; font-weight: 700; margin-bottom: 8px;">50 FIT</div>
                        <div style="font-size: 13px; opacity: 0.9;">故障率</div>
                    </div>
                </div>

                <div style="background: white; border: 1px solid #e0e0e0; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                    <h5 style="font-size: 15px; font-weight: 600; margin-bottom: 16px;">📊 降额分析</h5>
                    <div style="display: grid; gap: 12px;">
                        <div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                                <span style="font-size: 13px; font-weight: 600;">工作电压降额</span>
                                <span style="font-size: 13px; color: #00890b; font-weight: 600;">85%</span>
                            </div>
                            <div style="height: 8px; background: #f0f0f0; border-radius: 4px; overflow: hidden;">
                                <div style="width: 85%; height: 100%; background: linear-gradient(90deg, #00890b, #4caf50);"></div>
                            </div>
                            <div style="font-size: 11px; color: #999; margin-top: 4px;">建议工作在最大电压的70-80%范围内</div>
                        </div>
                        <div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                                <span style="font-size: 13px; font-weight: 600;">温度降额</span>
                                <span style="font-size: 13px; color: #00890b; font-weight: 600;">75%</span>
                            </div>
