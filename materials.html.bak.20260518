                            <div style="background: linear-gradient(135deg, #00890b 0%, #007309 100%); color: white; padding: 20px; border-radius: 12px; margin-bottom: 24px;">
                                <div style="display: flex; align-items: center; justify-content: space-between;">
                                    <div>
                                        <div style="font-size: 14px; opacity: 0.9; margin-bottom: 4px;">📄 PDF数据手册智能解读</div>
                                        <h4 id="pdfQAMaterialName" style="font-size: 18px; font-weight: 700; margin: 0;">-</h4>
                                    </div>
                                    <button onclick="closePDFDatasheetQA()" style="background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); color: white; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px; font-weight: 600;">
                                        返回功能选择
                                    </button>
                                </div>
                            </div>

                            <!-- 上传数据手册区域 -->
                            <div id="pdfUploadSection" style="background: #f9f9f9; border: 2px dashed #e0e0e0; border-radius: 12px; padding: 32px; text-align: center; margin-bottom: 24px;">
                                <div style="font-size: 56px; margin-bottom: 16px;">📄</div>
                                <h4 style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">上传PDF数据手册</h4>
                                <p style="font-size: 13px; color: #666; margin-bottom: 20px;">支持上传元器件的PDF数据手册，AI将智能解读并回答您的问题</p>
                                <input type="file" id="pdfDatasheetFile" accept=".pdf" style="display: none;" onchange="handlePDFDatasheetUpload(event)">
                                <button onclick="document.getElementById('pdfDatasheetFile').click()" style="background: #00890b; color: white; border: none; padding: 12px 32px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.3s;" onmouseover="this.style.background='#007309'" onmouseout="this.style.background='#00890b'">
                                    📤 选择PDF文件
                                </button>
                                <div style="margin-top: 16px; font-size: 12px; color: #999;">
                                    支持格式：PDF（最大50MB）
                                </div>
                            </div>

                            <!-- 已上传的PDF信息 -->
                            <div id="pdfUploadedInfo" style="display: none; background: #e8f5e9; border: 1px solid #00890b; border-radius: 12px; padding: 16px; margin-bottom: 24px;">
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div style="font-size: 32px;">✅</div>
                                    <div style="flex: 1;">
                                        <div style="font-weight: 600; color: #00890b; margin-bottom: 4px;">数据手册已上传</div>
                                        <div id="pdfFileName" style="font-size: 13px; color: #666;">-</div>
                                    </div>
                                    <button onclick="removePDFDatasheet()" style="background: white; border: 1px solid #e0e0e0; color: #666; padding: 6px 12px; border-radius: 6px; font-size: 12px; cursor: pointer;">
                                        ✕ 移除
                                    </button>
                                </div>
                            </div>

                            <!-- 对话历史 -->
                            <div id="pdfQAConversation" style="background: white; border: 1px solid #e0e0e0; border-radius: 12px; padding: 20px; margin-bottom: 20px; max-height: 500px; overflow-y: auto; display: none;">
                                <h4 style="font-size: 14px; font-weight: 600; margin-bottom: 16px; color: #666;">💬 对话历史</h4>
                                <div id="pdfQAMessages">
                                    <!-- 对话消息将动态添加 -->
                                </div>
                            </div>

                            <!-- 提问输入框 -->
                            <div id="pdfQAInputSection" style="display: none;">
                                <div style="background: #f9f9f9; border: 2px solid #e0e0e0; border-radius: 12px; padding: 20px;">
                                    <h4 style="font-size: 14px; font-weight: 600; margin-bottom: 12px;">❓ 提出您的问题</h4>

                                    <!-- 推荐问题 -->
                                    <div style="margin-bottom: 16px;">
                                        <div style="font-size: 12px; color: #666; margin-bottom: 8px;">💡 推荐问题：</div>
                                        <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                                            <button class="suggested-question-btn" onclick="askPDFQuestion('这个芯片的主要参数是什么？')">主要参数是什么？</button>
                                            <button class="suggested-question-btn" onclick="askPDFQuestion('这个芯片的典型应用场景有哪些？')">典型应用场景？</button>
                                            <button class="suggested-question-btn" onclick="askPDFQuestion('工作电压范围是多少？')">工作电压范围？</button>
                                            <button class="suggested-question-btn" onclick="askPDFQuestion('需要哪些外围电路？')">需要哪些外围电路？</button>
                                            <button class="suggested-question-btn" onclick="askPDFQuestion('封装类型和引脚定义？')">封装和引脚定义？</button>
                                        </div>
                                    </div>

                                    <textarea id="pdfQuestionInput" placeholder="请输入您关于该数据手册的问题...&#10;例如：这个芯片的工作温度范围是多少？" style="width: 100%; min-height: 100px; padding: 12px; border: 1px solid #e0e0e0; border-radius: 8px; font-size: 14px; resize: vertical; font-family: inherit; margin-bottom: 12px;" onfocus="this.style.borderColor='#00890b'" onblur="this.style.borderColor='#e0e0e0'"></textarea>

                                    <div style="display: flex; justify-content: space-between; align-items: center;">
                                        <div style="font-size: 12px; color: #999;">
                                            <span id="questionCharCount">0</span>/500 字符
                                        </div>
                                        <button onclick="submitPDFQuestion()" style="background: #00890b; color: white; border: none; padding: 10px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.3s;" onmouseover="this.style.background='#007309'" onmouseout="this.style.background='#00890b'">
                                            🚀 提交问题
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- AI分析历史 -->
                        <div id="materialAIHistory" style="display: none;">
                            <h4 style="font-size: 16px; font-weight: 700; margin-bottom: 16px; color: #3d4647;">
                                📚 分析历史
                            </h4>
                            <div id="materialAIHistoryList" style="display: grid; gap: 12px;">
                                <!-- 历史记录将动态生成 -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeDetailModal()">关闭</button>
                <button class="btn-primary" onclick="saveDetailChanges()">保存修改</button>
            </div>
        </div>
    </div>

    <!-- AI对比模态框 -->
    <div class="modal-overlay" id="comparisonModal">
        <div class="modal-content" style="max-width: 1440px;">
            <div class="modal-header">
                <h3 class="modal-title">🤖 AI智能对比分析</h3>
                <button class="modal-close" onclick="closeComparisonModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div style="background: #f0f8ff; padding: 16px; border-radius: 6px; margin-bottom: 20px;">
                    <div style="font-size: 14px; font-weight: 600; margin-bottom: 8px; color: #197bc0;">🤖 AI分析结果</div>
                    <div id="aiAnalysis" style="font-size: 13px; color: #666; line-height: 1.8;"></div>
                </div>
                <h4 style="font-size: 16px; font-weight: 700; margin-bottom: 12px;">参数对比</h4>
                <div style="overflow-x: auto;">
                    <table class="param-table" id="comparisonTable">
                        <thead>
                            <tr id="comparisonHeader">
                                <th style="min-width: 120px;">参数</th>
                                <!-- 物料列将动态生成 -->
                            </tr>
                        </thead>
                        <tbody id="comparisonBody">
                            <!-- 对比数据将动态生成 -->
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeComparisonModal()">关闭</button>
            </div>
        </div>
    </div>

    <!-- 管理替代件模态框 -->
    <div class="modal-overlay" id="manageAlternativesModal">
        <div class="modal-content" style="max-width: 1440px;">
            <div class="modal-header">
                <h3 class="modal-title">🔄 管理替代件</h3>
                <button class="modal-close" onclick="closeManageAlternatives()">&times;</button>
            </div>
            <div class="modal-body">
                <!-- 物料信息卡片 -->
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 8px; margin-bottom: 24px;">
                    <div style="display: flex; justify-content: space-between; align-items: start;">
                        <div style="flex: 1;">
                            <div style="font-size: 12px; opacity: 0.9; margin-bottom: 4px;">当前物料</div>
                            <div style="font-size: 20px; font-weight: 700; margin-bottom: 8px;" id="currentMaterialName">STM32F407VGT6</div>
                            <div style="display: flex; gap: 16px; font-size: 13px; opacity: 0.95;">
                                <div>📦 制造商: <span id="currentMaterialMfr">STMicroelectronics</span></div>
                                <div>📋 分类: <span id="currentMaterialCategory">微控制器</span></div>
                                <div>💰 单价: ¥<span id="currentMaterialPrice">45.00</span></div>
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-size: 32px; font-weight: 700;" id="altTotalCount">3</div>
                            <div style="font-size: 12px; opacity: 0.9;">个替代件</div>
                        </div>
                    </div>
                </div>

                <!-- 操作按钮栏 -->
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <div style="display: flex; gap: 12px;">
                        <button class="btn-primary" onclick="openAddAlternativeModalFromManage()">
                            <span style="font-size: 16px;">+</span> 添加替代件
                        </button>
                        <button class="btn-secondary" onclick="aiRecommendAlternatives()" style="display: flex; align-items: center; gap: 6px;">
                            <span>🤖</span>
                            <span>AI智能推荐</span>
                        </button>
                        <button class="btn-secondary" onclick="compareSelectedAlts()" id="compareAltsBtn" disabled>
                            <span>📊</span>
                            <span>对比选中项</span>
                        </button>
                    </div>
                    <div style="display: flex; gap: 12px; align-items: center;">
                        <span id="selectedAltsInfo" style="font-size: 13px; color: #666;">未选中任何项</span>
                        <button class="btn-secondary" onclick="deleteSelectedAlts()" id="deleteAltsBtn" disabled style="color: #e74c3c;">
                            <span>🗑️</span>
                            <span>删除选中</span>
                        </button>
                    </div>
                </div>

                <!-- 替代件列表 -->
                <div style="background: white; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: #f9f9f9; border-bottom: 2px solid #e0e0e0;">
                                <th style="padding: 12px; text-align: left; width: 40px;">
                                    <input type="checkbox" id="selectAllAlts" onchange="toggleSelectAllAlts()" style="width: 18px; height: 18px; cursor: pointer;">
                                </th>
                                <th style="padding: 12px; text-align: left; font-weight: 600;">物料型号</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600;">制造商</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600;">优先级</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600;">单价</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600;">库存状态</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600;">相似度</th>
                                <th style="padding: 12px; text-align: center; font-weight: 600; width: 200px;">操作</th>
                            </tr>
                        </thead>
                        <tbody id="alternativesTableBody">
                            <!-- 替代件行将动态生成 -->
                        </tbody>
                    </table>
                </div>

                <!-- 空状态提示 -->
                <div id="emptyAltsState" style="display: none; text-align: center; padding: 60px 20px;">
                    <div style="font-size: 64px; margin-bottom: 16px;">📦</div>
                    <div style="font-size: 18px; font-weight: 600; color: #3d4647; margin-bottom: 8px;">暂无替代件</div>
                    <div style="font-size: 14px; color: #999; margin-bottom: 24px;">点击"添加替代件"或使用"AI智能推荐"来添加可替换物料</div>
                    <button class="btn-primary" onclick="openAddAlternativeModalFromManage()">
                        <span>+</span> 添加第一个替代件
                    </button>
                </div>

                <!-- 提示信息 -->
                <div style="background: #f0f8ff; border-left: 4px solid #197bc0; padding: 16px; border-radius: 6px; margin-top: 20px;">
                    <div style="font-weight: 600; margin-bottom: 8px; color: #197bc0;">💡 替代件使用说明</div>
                    <ul style="margin-left: 20px; color: #666; font-size: 13px; line-height: 1.8;">
                        <li>主要替代件：功能完全相同，优先推荐使用</li>
                        <li>次要替代件：功能基本相同，部分参数有差异</li>
                        <li>备选替代件：可在特定场景下使用，需评估风险</li>
                        <li>系统会根据库存状态和价格自动推荐最优替代方案</li>
                    </ul>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeManageAlternatives()">关闭</button>
                <button class="btn-primary" onclick="exportAlternativesReport()">📤 导出报告</button>
            </div>
        </div>
    </div>

    <!-- 添加替代件模态框 -->
    <div class="modal-overlay" id="addAlternativeModal">
        <div class="modal-content" style="max-width: 800px;">
            <div class="modal-header">
                <h3 class="modal-title">🔄 添加替代件</h3>
                <button class="modal-close" onclick="closeAddAlternativeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <!-- 搜索区域 -->
                <div class="form-group">
                    <label class="form-label">搜索物料</label>
                    <div class="alt-search-box">
                        <input type="text" class="alt-search-input" id="altSearchInput" placeholder="输入型号、制造商或关键词搜索...">
                        <button class="btn-primary" onclick="searchAlternativeMaterials()">
                            🔍 搜索
                        </button>
                    </div>
                </div>

                <!-- 搜索结果列表 -->
                <div class="form-group" id="altSearchResults" style="display: none;">
                    <label class="form-label">搜索结果</label>
                    <div id="altSearchResultList" style="max-height: 300px; overflow-y: auto; border: 1px solid #e0e0e0; border-radius: 6px;">
                        <!-- 搜索结果将动态生成 -->
                    </div>
                </div>

                <!-- 替代件详细设置 -->
                <div id="altDetailSettings" style="display: none;">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">优先级</label>
                            <select class="form-select" id="altPriority">
                                <option value="primary">主要替代件</option>
                                <option value="secondary">次要替代件</option>
                                <option value="tertiary">备选替代件</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">价格 (¥)</label>
                            <input type="number" class="form-input" id="altPrice" placeholder="输入价格" step="0.01">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">库存数量</label>
                            <input type="number" class="form-input" id="altStock" placeholder="输入库存数量">
                        </div>
                        <div class="form-group">
                            <label class="form-label">库存状态</label>
                            <select class="form-select" id="altStockStatus">
                                <option value="available">有货</option>
                                <option value="low">低库存</option>
                                <option value="out">缺货</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">应用场景说明</label>
                        <textarea class="form-textarea" id="altScenario" placeholder="描述该替代件的应用场景和注意事项..."></textarea>
                    </div>

                    <div class="help-tip">
                        <span class="help-tip-icon">💡</span>
                        <span>提示：主要替代件将优先推荐；价格和库存信息将用于智能对比分析。</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeAddAlternativeModal()">取消</button>
                <button class="btn-primary" onclick="saveAlternative()" id="saveAltBtn" disabled>添加替代件</button>
            </div>
        </div>
    </div>

    <!-- AI智能推荐替代件模态框 -->
    <div class="modal-overlay" id="aiRecommendAltsModal">
        <div class="modal-content" style="max-width: 1000px;">
            <div class="modal-header">
                <h3 class="modal-title">🤖 AI智能推荐替代件</h3>
                <button class="modal-close" onclick="closeAIRecommendAlts()">&times;</button>
            </div>
            <div class="modal-body">
                <!-- AI分析进度 -->
                <div id="aiAnalysisProgress" style="display: none;">
                    <div style="text-align: center; padding: 60px 20px;">
                        <div style="font-size: 64px; margin-bottom: 16px;">🤖</div>
                        <div style="font-size: 18px; font-weight: 600; color: #3d4647; margin-bottom: 12px;">AI正在分析替代件...</div>
                        <div style="font-size: 14px; color: #999; margin-bottom: 24px;">
                            <div id="aiProgressText">正在搜索数据库...</div>
                        </div>
                        <div style="max-width: 400px; margin: 0 auto; height: 8px; background: #f0f0f0; border-radius: 4px; overflow: hidden;">
                            <div id="aiProgressBar" style="width: 0%; height: 100%; background: linear-gradient(90deg, #00890b, #00b30e); transition: width 0.3s;"></div>
                        </div>
                    </div>
                </div>

                <!-- AI推荐结果 -->
                <div id="aiRecommendResults" style="display: none;">
                    <!-- 分析摘要 -->
                    <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 8px; margin-bottom: 24px;">
                        <div style="font-size: 14px; opacity: 0.9; margin-bottom: 8px;">分析完成</div>
                        <div style="font-size: 24px; font-weight: 700; margin-bottom: 16px;">为您找到 <span id="aiRecommendCount">5</span> 个优质替代件</div>
                        <div style="display: flex; gap: 24px; font-size: 13px; opacity: 0.95;">
                            <div>📊 分析了 <span id="aiAnalyzedCount">500+</span> 个物料</div>
                            <div>⚡ 相似度评分 <span id="aiSimilarityScore">85%+</span></div>
                            <div>💰 价格优势明显</div>
                        </div>
                    </div>

                    <!-- 推荐理由 -->
                    <div style="background: #f0f8ff; border-left: 4px solid #197bc0; padding: 16px; border-radius: 6px; margin-bottom: 20px;">
                        <div style="font-weight: 600; color: #197bc0; margin-bottom: 8px;">💡 AI分析依据</div>
                        <div style="font-size: 13px; color: #666; line-height: 1.6;">
                            基于参数匹配、供应商信誉、历史采购数据、市场价格趋势等多维度智能分析，为您筛选出最优替代方案。
                        </div>
                    </div>

                    <!-- 推荐列表 -->
                    <div id="aiRecommendList"></div>

                    <!-- 操作按钮 -->
                    <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 20px;">
                        <button class="btn-secondary" onclick="addAllAIRecommended()">
                            <span>✅</span> 全部添加
                        </button>
                        <button class="btn-secondary" onclick="addSelectedAIRecommended()">
                            <span>➕</span> 添加选中项
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeAIRecommendAlts()">关闭</button>
                <button class="btn-primary" onclick="exportAIRecommendReport()">📤 导出推荐报告</button>
            </div>
        </div>
    </div>

    <!-- 对比选中替代件模态框 -->
    <div class="modal-overlay" id="compareAltsModal">
        <div class="modal-content" style="max-width: 1440px;">
            <div class="modal-header">
                <h3 class="modal-title">📊 替代件智能对比</h3>
                <button class="modal-close" onclick="closeCompareAlts()">&times;</button>
            </div>
            <div class="modal-body">
                <!-- 对比说明 -->
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 8px; margin-bottom: 24px;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <div style="font-size: 14px; opacity: 0.9; margin-bottom: 4px;">全方位对比分析</div>
                            <div style="font-size: 20px; font-weight: 700;">正在对比 <span id="compareItemCount">3</span> 个替代件</div>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-size: 32px; font-weight: 700;" id="bestChoiceIndex">2</div>
                            <div style="font-size: 12px; opacity: 0.9;">号为最佳选择</div>
                        </div>
                    </div>
                </div>

                <!-- 对比维度选择 -->
                <div style="display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap;">
                    <button class="compare-dimension-btn active" data-dimension="all" onclick="switchCompareDimension('all')">
                        📊 综合对比
                    </button>
                    <button class="compare-dimension-btn" data-dimension="price" onclick="switchCompareDimension('price')">
                        💰 价格对比
                    </button>
                    <button class="compare-dimension-btn" data-dimension="stock" onclick="switchCompareDimension('stock')">
                        📦 库存对比
                    </button>
                    <button class="compare-dimension-btn" data-dimension="params" onclick="switchCompareDimension('params')">
                        ⚙️ 参数对比
                    </button>
                    <button class="compare-dimension-btn" data-dimension="supplier" onclick="switchCompareDimension('supplier')">
                        🏪 供应商对比
                    </button>
                </div>

                <!-- 对比表格 -->
                <div style="background: white; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden;">
                    <table style="width: 100%; border-collapse: collapse;" id="compareTable">
                        <thead>
                            <tr style="background: #f9f9f9; border-bottom: 2px solid #e0e0e0;">
                                <th style="padding: 16px; text-align: left; font-weight: 600; width: 180px;">对比项目</th>
                                <th style="padding: 16px; text-align: center; font-weight: 600; background: #e8f5e9;">
                                    <div style="color: #00890b; font-size: 16px; margin-bottom: 4px;">当前物料</div>
                                    <div style="font-size: 12px; font-weight: 400; color: #666;" id="currentMaterialForCompare">STM32F407VGT6</div>
                                </th>
                                <!-- 替代件列将动态生成 -->
                            </tr>
                        </thead>
                        <tbody id="compareTableBody">
                            <!-- 对比行将动态生成 -->
                        </tbody>
                    </table>
                </div>

                <!-- AI智能建议 -->
                <div style="background: #fff3e0; border-left: 4px solid #ff9800; padding: 16px; border-radius: 6px; margin-top: 20px;">
                    <div style="font-weight: 600; color: #ff9800; margin-bottom: 8px;">🤖 AI智能建议</div>
                    <div id="aiCompareAdvice" style="font-size: 13px; color: #666; line-height: 1.6;">
                        根据综合评分，推荐选择替代件 #2，其在价格、库存和参数匹配度上表现最优。
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeCompareAlts()">关闭</button>
                <button class="btn-primary" onclick="exportCompareReport()">📤 导出对比报告</button>
            </div>
        </div>
    </div>

    <!-- 编辑替代件模态框 -->
    <div class="modal-overlay" id="editAlternativeModal">
        <div class="modal-content" style="max-width: 700px;">
            <div class="modal-header">
                <h3 class="modal-title">✏️ 编辑替代件</h3>
                <button class="modal-close" onclick="closeEditAlternative()">&times;</button>
            </div>
            <div class="modal-body">
                <!-- 基本信息 -->
                <div class="form-group">
                    <label class="form-label required">型号 (MPN)</label>
                    <input type="text" class="form-input" id="editAltMPN" placeholder="例如: STM32F407ZGT6">
                </div>

                <div class="form-group">
                    <label class="form-label required">制造商</label>
                    <input type="text" class="form-input" id="editAltManufacturer" placeholder="例如: STMicroelectronics">
                </div>

                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
                    <div class="form-group">
                        <label class="form-label required">优先级</label>
                        <select class="form-input" id="editAltPriority">
                            <option value="primary">⭐ 主要替代件</option>
                            <option value="secondary">⚡ 次要替代件</option>
                            <option value="tertiary">🔸 备选替代件</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">单价 (¥)</label>
                        <input type="number" class="form-input" id="editAltPrice" step="0.01" min="0" placeholder="例如: 42.50">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
                    <div class="form-group">
                        <label class="form-label">库存数量</label>
                        <input type="number" class="form-input" id="editAltStock" min="0" placeholder="例如: 5000">
                    </div>

                    <div class="form-group">
                        <label class="form-label">库存状态</label>
                        <select class="form-input" id="editAltStockStatus">
                            <option value="available">✅ 有货</option>
                            <option value="low">⚠️ 低库存</option>
                            <option value="out">❌ 缺货</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">相似度 (%)</label>
                    <input type="range" class="form-input" id="editAltSimilarity" min="0" max="100" value="85"
                           oninput="document.getElementById('editSimilarityValue').textContent = this.value">
                    <div style="text-align: center; margin-top: 8px; font-weight: 600; color: #00890b;">
                        <span id="editSimilarityValue">85</span>%
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">应用场景说明</label>
                    <textarea class="form-input" id="editAltScenario" rows="3" placeholder="例如: 适用于工业级应用，温度范围-40°C至+85°C"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeEditAlternative()">取消</button>
                <button class="btn-primary" onclick="saveEditAlternative()">💾 保存修改</button>
            </div>
        </div>
    </div>

    <!-- 查看替代件详情模态框 -->
    <div class="modal-overlay" id="viewAltDetailsModal">
        <div class="modal-content" style="max-width: 800px;">
            <div class="modal-header">
                <h3 class="modal-title">📋 替代件详细信息</h3>
                <button class="modal-close" onclick="closeViewAltDetails()">&times;</button>
            </div>
            <div class="modal-body">
                <!-- 头部卡片 -->
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 24px; border-radius: 12px; margin-bottom: 24px;">
                    <div style="display: flex; justify-content: space-between; align-items: start;">
                        <div>
                            <div style="font-size: 24px; font-weight: 700; margin-bottom: 8px;" id="viewAltMPN">STM32F407ZGT6</div>
                            <div style="font-size: 14px; opacity: 0.9;" id="viewAltManufacturer">STMicroelectronics</div>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-size: 32px; font-weight: 700;" id="viewAltSimilarity">95</div>
                            <div style="font-size: 12px; opacity: 0.9;">相似度 %</div>
                        </div>
                    </div>
                </div>

                <!-- 详细信息 -->
                <div class="detail-section">
                    <h4 class="detail-section-title">基本信息</h4>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <span class="detail-label">型号 (MPN)</span>
                            <span class="detail-value" id="viewAltMPNDetail">-</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">制造商</span>
                            <span class="detail-value" id="viewAltManufacturerDetail">-</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">优先级</span>
                            <span class="detail-value" id="viewAltPriority">-</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">单价</span>
                            <span class="detail-value" id="viewAltPrice" style="color: #00890b; font-weight: 600;">-</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">库存数量</span>
                            <span class="detail-value" id="viewAltStock">-</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">库存状态</span>
                            <span class="detail-value" id="viewAltStockStatus">-</span>
                        </div>
                    </div>
                </div>

                <!-- 应用场景 -->
                <div class="detail-section" id="viewAltScenarioSection" style="display: none;">
                    <h4 class="detail-section-title">应用场景说明</h4>
                    <div style="background: #f9f9f9; padding: 16px; border-radius: 8px; border-left: 4px solid #197bc0;">
                        <p id="viewAltScenario" style="font-size: 14px; color: #666; line-height: 1.6; margin: 0;">-</p>
                    </div>
                </div>

                <!-- 对比原物料 -->
                <div class="detail-section">
                    <h4 class="detail-section-title">与原物料对比</h4>
                    <div style="background: #fff3e0; border-left: 4px solid #ff9800; padding: 16px; border-radius: 6px;">
                        <div id="viewAltComparison" style="font-size: 13px; color: #666; line-height: 1.8;">
                            <!-- 对比信息将动态生成 -->
                        </div>
                    </div>
                </div>

                <!-- 匹配分析 -->
                <div class="detail-section">
                    <h4 class="detail-section-title">智能匹配分析</h4>
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
                        <div style="background: #e8f5e9; padding: 16px; border-radius: 8px; text-align: center;">
                            <div style="font-size: 28px; font-weight: 700; color: #00890b;" id="viewParamMatch">92</div>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">参数匹配度</div>
                        </div>
                        <div style="background: #fff3e0; padding: 16px; border-radius: 8px; text-align: center;">
                            <div style="font-size: 28px; font-weight: 700; color: #ff9800;" id="viewPriceAdvantage">15</div>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">价格优势 %</div>
                        </div>
                        <div style="background: #e3f2fd; padding: 16px; border-radius: 8px; text-align: center;">
                            <div style="font-size: 28px; font-weight: 700; color: #197bc0;" id="viewStockLevel">高</div>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">库存水平</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeViewAltDetails()">关闭</button>
                <button class="btn-primary" onclick="editAlternativeFromView()">✏️ 编辑此替代件</button>
            </div>
        </div>
    </div>

    <!-- 元零件组管理模态框 -->
    <div class="modal-overlay" id="metaPartModal">
        <div class="modal-content" style="max-width: 900px;">
            <div class="modal-header">
                <h3 class="modal-title">🔄 创建元零件组</h3>
                <button class="modal-close" onclick="closeMetaPartModal()">&times;</button>
            </div>
            <div class="modal-body">
                <!-- 说明区域 -->
                <div style="background: linear-gradient(135deg, #e3f2fd 0%, #f1f8ff 100%); border: 2px solid #197bc0; border-radius: 12px; padding: 20px; margin-bottom: 24px;">
                    <div style="font-size: 16px; font-weight: 700; color: #197bc0; margin-bottom: 8px;">
                        什么是元零件组？
                    </div>
                    <div style="font-size: 14px; color: #666; line-height: 1.6;">
                        元零件组（Meta Part）是将多个可互换的物料归为一组进行管理。当选型时，系统会根据价格、库存等因素自动推荐最优物料。
                        这对于标准件（如电阻、电容）和有多个替代件的物料特别有用。
                    </div>
                </div>

                <!-- 基本信息 -->
                <div class="form-group">
                    <label class="form-label required">元零件组名称</label>
                    <input type="text" class="form-input" id="metaPartName" placeholder="例如: 10K电阻组、STM32F4系列MCU组">
                </div>

                <div class="form-group">
                    <label class="form-label">组描述</label>
                    <textarea class="form-textarea" id="metaPartDesc" placeholder="描述该组物料的共同特点和应用场景..."></textarea>
                </div>

                <!-- 添加物料到组 -->
                <div class="form-group">
                    <label class="form-label">选择物料</label>
                    <div class="alt-search-box">
                        <input type="text" class="alt-search-input" id="metaPartSearchInput" placeholder="搜索要添加到组的物料...">
                        <button class="btn-primary" onclick="searchMetaPartMaterials()">
                            🔍 搜索
                        </button>
                    </div>
                </div>

                <!-- 已选物料列表 -->
                <div class="form-group">
                    <label class="form-label">已添加物料 (<span id="metaPartCount">0</span> 个)</label>
                    <div id="metaPartList" style="border: 2px dashed #e0e0e0; border-radius: 8px; padding: 16px; min-height: 200px;">
                        <div style="text-align: center; color: #999; padding: 40px 0;">
                            <div style="font-size: 48px; margin-bottom: 8px;">📦</div>
                            <div>暂无物料，请搜索并添加物料</div>
                        </div>
                    </div>
                </div>

                <!-- 优先级排序说明 -->
                <div class="help-tip">
                    <span class="help-tip-icon">💡</span>
                    <span>提示：可通过拖拽调整物料优先级顺序。系统会优先推荐排在前面的物料。</span>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeMetaPartModal()">取消</button>
                <button class="btn-primary" onclick="saveMetaPart()">创建元零件组</button>
            </div>
        </div>
    </div>

    <!-- 分销商详情模态框 -->
    <div class="modal-overlay" id="distributorModal">
        <div class="modal-content" style="max-width: 700px;">
            <div class="modal-header">
                <h3 class="modal-title">🏪 分销商详情</h3>
                <button class="modal-close" onclick="closeDistributorModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 24px;">
                    <div>
                        <div style="width: 100%; aspect-ratio: 1; background: #f0f0f0; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 48px; margin-bottom: 12px;" id="distLogo">
                            🏪
                        </div>
                        <div id="distBadge" style="text-align: center;"></div>
                    </div>
                    <div>
                        <h3 id="distName" style="font-size: 20px; font-weight: 700; margin-bottom: 12px;">-</h3>
                        <div class="detail-grid">
                            <div class="detail-item">
                                <span class="detail-label">公司类型</span>
                                <span class="detail-value" id="distType">-</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">授权状态</span>
                                <span class="detail-value" id="distAuth">-</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">成立时间</span>
                                <span class="detail-value" id="distYear">-</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">服务评分</span>
                                <span class="detail-value" id="distRating">-</span>
                            </div>
                            <div class="detail-item" style="grid-column: 1 / -1;">
                                <span class="detail-label">官方网站</span>
                                <a class="detail-value" id="distWebsite" href="#" target="_blank" style="color: #197bc0;">-</a>
                            </div>
                            <div class="detail-item" style="grid-column: 1 / -1;">
                                <span class="detail-label">联系电话</span>
                                <span class="detail-value" id="distPhone">-</span>
                            </div>
                            <div class="detail-item" style="grid-column: 1 / -1;">
                                <span class="detail-label">公司简介</span>
                                <span class="detail-value" id="distDesc" style="line-height: 1.6;">-</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeDistributorModal()">关闭</button>
                <button class="btn-primary" onclick="window.open(document.getElementById('distWebsite').href, '_blank')">访问官网</button>
            </div>
        </div>
    </div>

    <!-- 编程助手模态框 -->
