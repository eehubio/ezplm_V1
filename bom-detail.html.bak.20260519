            if (confirm('确认要应用最新价格吗？\n\nBOM成本将从 ¥85.60 更新为 ¥82.30')) {
                alert('✅ 价格更新成功！\n\n新的BOM成本已保存：¥82.30\n成本节省：¥3.30 (-3.9%)');
                closeRealTimePriceModal();
                // 实际应用中会更新页面上的价格显示
                document.querySelector('.header-info .value').textContent = '¥82.30';
            }
        }

        // 3. 库存检查

        // BOM物料库存数据
        const bomInventoryData = [
            { partNumber: 'MT-IC-2024-0001', name: 'TI MSP430F5529 MCU', bomQty: 1, currentStock: 1200, unit: '个' },
            { partNumber: 'MT-SENSOR-2024-003', name: 'MAXIM MAX30102 心率传感器', bomQty: 1, currentStock: 0, unit: '个' },
            { partNumber: 'MT-IC-2024-0089', name: 'TI BQ24075 充电管理IC', bomQty: 1, currentStock: 80, unit: '个' },
            { partNumber: 'MT-R-2024-0156', name: '贴片电阻 10KΩ 0805', bomQty: 4, currentStock: 450, unit: '个' },
            { partNumber: 'MT-C-2024-0089', name: '陶瓷电容 100nF 0603', bomQty: 8, currentStock: 1200, unit: '个' },
            { partNumber: 'MT-OSC-2024-0015', name: '32.768KHz 晶振', bomQty: 1, currentStock: 500, unit: '个' },
            { partNumber: 'MT-LED-2024-0024', name: '红色LED 0805', bomQty: 2, currentStock: 300, unit: '个' },
            { partNumber: 'MT-CON-2024-0012', name: 'Micro USB 连接器', bomQty: 1, currentStock: 150, unit: '个' }
        ];

        // 打开库存检查模态框
        function checkInventoryAvailability(bomId) {
            document.getElementById('inventoryCheckModal').classList.add('active');
            updateInventoryCheck();
        }

        // 关闭库存检查模态框
        function closeInventoryCheckModal() {
            document.getElementById('inventoryCheckModal').classList.remove('active');
        }

        // 更新库存检查数据
        function updateInventoryCheck() {
            const projectQty = parseInt(document.getElementById('projectQuantity').value) || 250;

            let sufficientCount = 0;
            let lowCount = 0;
            let outOfStockCount = 0;
            let minProducible = Infinity;
            const warnings = [];
            const purchaseItems = [];

            // 计算每个物料的状态
            const results = bomInventoryData.map(item => {
                const totalRequired = item.bomQty * projectQty;
                const shortage = Math.max(0, totalRequired - item.currentStock);
                const percentage = item.currentStock / totalRequired * 100;
                const canMake = Math.floor(item.currentStock / item.bomQty);

                minProducible = Math.min(minProducible, canMake);

                let status = '';
                let statusClass = '';

                if (percentage >= 100) {
                    status = '充足';
                    statusClass = 'status-active';
                    sufficientCount++;
                } else if (percentage >= 50) {
                    status = '偏低';
                    statusClass = 'status-warning';
                    lowCount++;
                    warnings.push(`<strong>${item.name}</strong> 库存偏低（剩余${item.currentStock}${item.unit}），仅够生产${canMake}个，建议提前补货`);
                } else {
                    status = '缺货';
                    statusClass = 'status-danger';
                    outOfStockCount++;
                    if (item.currentStock === 0) {
                        warnings.push(`<strong>${item.name}</strong> 库存为0，无法开始生产，需紧急采购`);
                    } else {
                        warnings.push(`<strong>${item.name}</strong> 库存严重不足（剩余${item.currentStock}${item.unit}），仅够生产${canMake}个，需紧急采购`);
                    }
                }

                // 如果需要采购
                if (shortage > 0) {
                    purchaseItems.push({
                        partNumber: item.partNumber,
                        name: item.name,
                        shortage: shortage,
                        unit: item.unit
                    });
                }

                return {
                    ...item,
                    totalRequired,
                    shortage,
                    percentage: Math.min(percentage, 100),
                    status,
                    statusClass,
                    canMake
                };
            });

            // 更新统计卡片
            document.getElementById('sufficientCount').textContent = sufficientCount;
            document.getElementById('lowCount').textContent = lowCount;
            document.getElementById('outOfStockCount').textContent = outOfStockCount;
            document.getElementById('canProduceCount').textContent = minProducible === Infinity ? 0 : minProducible;

            // 更新表格
            const tbody = document.getElementById('inventoryTableBody');
            tbody.innerHTML = results.filter(item => item.shortage > 0 || item.percentage < 100).map(item => `
                <tr>
                    <td><strong>${item.partNumber}</strong></td>
                    <td>${item.name}</td>
                    <td style="text-align: center;">${item.bomQty}</td>
                    <td style="text-align: center;"><strong>${projectQty}</strong></td>
                    <td style="text-align: center;"><strong>${item.totalRequired}</strong></td>
                    <td style="text-align: center;">${item.currentStock}</td>
                    <td style="text-align: center;">
                        <strong style="color: ${item.shortage > 0 ? '#e74c3c' : '#00890b'};">
                            ${item.shortage > 0 ? item.shortage : '无需采购'}
                        </strong>
                    </td>
                    <td>
                        <div class="inventory-progress">
                            <div class="inventory-progress-bar ${item.statusClass === 'status-active' ? 'inventory-good' : item.statusClass === 'status-warning' ? 'inventory-medium' : 'inventory-low'}"
                                 style="width: ${item.percentage}%;"></div>
                        </div>
                        <div style="font-size: 11px; color: #666; text-align: center; margin-top: 4px;">
                            ${item.percentage.toFixed(0)}%
                        </div>
                    </td>
                    <td><span class="status-badge ${item.statusClass}">${item.status}</span></td>
                </tr>
            `).join('');

            // 如果没有需要关注的零件
            if (results.filter(item => item.shortage > 0 || item.percentage < 100).length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="9" style="text-align: center; padding: 40px 20px; color: #00890b;">
                            <div style="font-size: 48px; margin-bottom: 12px;">✅</div>
                            <div style="font-size: 16px; font-weight: 600;">所有物料库存充足，可以开始生产！</div>
                        </td>
                    </tr>
                `;
            }

            // 更新警告信息
            const warningDiv = document.getElementById('productionWarning');
            const warningList = document.getElementById('warningList');

            if (warnings.length > 0) {
                warningDiv.style.display = 'block';
                warningList.innerHTML = warnings.map(w => `<li>${w}</li>`).join('');
            } else {
                warningDiv.style.display = 'none';
            }

            // 存储采购项目供后续使用
            window.currentPurchaseItems = purchaseItems;
            window.currentProjectQty = projectQty;
        }

        // 生成采购申请
        function generatePurchaseRequest() {
            const purchaseItems = window.currentPurchaseItems || [];
            const projectQty = window.currentProjectQty || 250;

            if (purchaseItems.length === 0) {
                alert('✅ 库存充足\n\n所有物料库存充足，无需生成采购申请！');
                return;
            }

            const itemsList = purchaseItems.map(item =>
                `• ${item.name} (${item.partNumber})\n  需采购数量: ${item.shortage} ${item.unit}`
            ).join('\n\n');

            const summary = `
📋 采购申请汇总

项目名称: 智能手环 V2.0 主板
BOM编号: BOM-2024-0012
生产数量: ${projectQty} 个
缺货物料: ${purchaseItems.length} 项

需采购物料清单:
${itemsList}

计算公式: 采购量 = BOM需求量 × 项目数量 - 当前库存
            `.trim();

            if (confirm(summary + '\n\n是否生成采购申请？')) {
                // 生成采购申请编号
                const requestNo = 'PR-' + new Date().getFullYear() + '-' + String(Date.now()).slice(-6);

                const result = `
✅ 采购申请已生成！

申请编号: ${requestNo}
申请人: 你
申请时间: ${new Date().toLocaleString('zh-CN')}
采购物料: ${purchaseItems.length} 项
预计审批时间: 1-2 个工作日

请到采购管理页面跟踪审批进度。
                `.trim();

                alert(result);

                // 显示活动通知
                if (typeof showActivityNotification === 'function') {
                    showActivityNotification({
                        user: '你',
                        action: `生成了采购申请 ${requestNo}（${purchaseItems.length} 项物料）`,
                        type: 'editing'
                    });
                }

                closeInventoryCheckModal();

                // 询问是否跳转到采购申请页面
                if (confirm('是否立即查看采购申请详情？')) {
                    window.location.href = 'purchase-request.html';
                }
            }
        }

        // 4. BOM对比
        function openBOMComparison() {
