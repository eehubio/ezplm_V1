        // 显示活动通知
        function showActivityNotification(activity) {
            const container = document.getElementById('activityNotifications');

            const notification = document.createElement('div');
            notification.className = `activity-notification ${activity.type}`;
            notification.innerHTML = `
                <div style="width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12px; flex-shrink: 0;">
                    ${activity.user.charAt(0)}
                </div>
                <div style="flex: 1; font-size: 13px;">
                    <div style="font-weight: 600; color: #3d4647; margin-bottom: 2px;">
                        ${activity.user}
                    </div>
                    <div style="color: #666;">
                        ${activity.action}
                    </div>
                </div>
                <div style="font-size: 11px; color: #999; white-space: nowrap;">
                    刚刚
                </div>
            `;

            container.insertBefore(notification, container.firstChild);

            // 3秒后移除通知
            setTimeout(() => {
                notification.style.opacity = '0';
                notification.style.transform = 'translateX(20px)';
                setTimeout(() => notification.remove(), 300);
            }, 3000);

            // 限制通知数量
            while (container.children.length > 5) {
                container.lastChild.remove();
            }
        }

        // 模拟实时活动
        function simulateRealtimeActivity() {
            const activities = [
                { user: '张三', action: '修改了第 8 行物料备注', type: 'editing' },
