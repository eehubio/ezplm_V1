                            <option value="SUB-BOM-002">SUB-BOM-002 - 传感器模块</option>
                            <option value="SUB-BOM-003">SUB-BOM-003 - 电源管理模块</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">备注</label>
                        <textarea class="form-textarea" id="itemNotes" placeholder="物料用途、替代方案等备注信息"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeAddItemModal()">取消</button>
                <button class="btn-primary" onclick="submitAddItem()">添加物料</button>
