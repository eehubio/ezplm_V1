                            <option value="MT-C-2024-0089">MT-C-2024-0089 - 陶瓷电容 100nF 0603</option>
                        </select>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label required">位号 (Designator)</label>
                            <input type="text" class="form-input" id="itemDesignator" placeholder="例如: U1, R1-R4, C1-C8" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label required">数量</label>
                            <input type="number" class="form-input" id="itemQuantity" min="1" value="1" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">添加到</label>
                        <select class="form-select" id="itemParent">
