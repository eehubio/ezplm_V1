    <!-- 库存检查 Modal -->
    <div class="partsbox-modal" id="inventoryCheckModal">
        <div class="partsbox-modal-content">
            <div class="modal-header">
                <h3 class="modal-title">📦 库存可用性检查</h3>
                <button class="modal-close" onclick="closeInventoryCheckModal()">&times;</button>
            </div>
            <div class="modal-body">
                <p style="color: #666; margin-bottom: 20px;">检查BOM中所有零件的库存状态，预测生产可行性</p>

                <!-- 项目数量设置 -->
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 16px 20px; border-radius: 12px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <div style="font-size: 14px; opacity: 0.9; margin-bottom: 4px;">生产数量设置</div>
                        <div style="font-size: 18px; font-weight: 700;">设置本次生产计划数量</div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <label style="font-size: 14px; font-weight: 600;">数量:</label>
                        <input type="number"
                               id="projectQuantity"
                               value="250"
                               min="1"
                               onchange="updateInventoryCheck()"
                               style="width: 100px; padding: 8px 12px; border: none; border-radius: 6px; font-size: 16px; font-weight: 700; text-align: center;">
                        <button onclick="updateInventoryCheck()"
                                style="background: white; color: #667eea; border: none; padding: 8px 16px; border-radius: 6px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.3s;"
                                onmouseover="this.style.transform='translateY(-2px)'"
                                onmouseout="this.style.transform='translateY(0)'">
                            🔄 重新计算
                        </button>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
                    <div class="cost-card" style="text-align: center;">
                        <div style="font-size: 36px; margin-bottom: 8px;">✅</div>
                        <div id="sufficientCount" style="font-size: 24px; font-weight: 700; color: #00890b;">-</div>
                        <div style="font-size: 12px; color: #666;">库存充足</div>
                    </div>
                    <div class="cost-card" style="text-align: center;">
                        <div style="font-size: 36px; margin-bottom: 8px;">⚠️</div>
                        <div id="lowCount" style="font-size: 24px; font-weight: 700; color: #f39c12;">-</div>
                        <div style="font-size: 12px; color: #666;">库存偏低</div>
                    </div>
                    <div class="cost-card" style="text-align: center;">
                        <div style="font-size: 36px; margin-bottom: 8px;">❌</div>
                        <div id="outOfStockCount" style="font-size: 24px; font-weight: 700; color: #e74c3c;">-</div>
                        <div style="font-size: 12px; color: #666;">库存缺货</div>
                    </div>
                    <div class="cost-card" style="text-align: center; border-color: #00890b; background: rgba(0, 137, 11, 0.05);">
                        <div style="font-size: 36px; margin-bottom: 8px;">🏭</div>
                        <div id="canProduceCount" style="font-size: 24px; font-weight: 700; color: #00890b;">-</div>
                        <div style="font-size: 12px; color: #666;">可生产数量</div>
                    </div>
                </div>

                <h4 style="font-size: 16px; font-weight: 700; margin-bottom: 16px; color: #3d4647;">⚠️ 需要关注的零件</h4>

                <table class="comparison-table">
                    <thead>
                        <tr>
                            <th>零件型号</th>
                            <th>零件名称</th>
                            <th>BOM需求</th>
                            <th>项目数量</th>
                            <th>总需求</th>
                            <th>当前库存</th>
                            <th>需采购</th>
                            <th>库存进度</th>
                            <th>状态</th>
                        </tr>
                    </thead>
                    <tbody id="inventoryTableBody">
                        <!-- 库存数据将通过JavaScript动态生成 -->
                    </tbody>
                </table>

                <div id="productionWarning" style="background: #ffebee; border-left: 4px solid #e74c3c; padding: 16px; border-radius: 6px; margin-top: 20px; display: none;">
                    <div style="font-weight: 600; margin-bottom: 8px; color: #e74c3c;">🚨 生产阻塞提醒</div>
                    <ul id="warningList" style="margin-left: 20px; color: #666; font-size: 13px; line-height: 1.8;">
                        <!-- 警告信息将通过JavaScript动态生成 -->
                    </ul>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeInventoryCheckModal()">关闭</button>
                <button class="btn-primary" onclick="generatePurchaseRequest()">
                    ⚡ 一键生成采购申请
                </button>
            </div>
        </div>
    </div>

    <!-- BOM对比 Modal -->
    <div class="partsbox-modal" id="bomComparisonModal">
        <div class="partsbox-modal-content">
            <div class="modal-header">
                <h3 class="modal-title">🔀 BOM版本对比</h3>
                <button class="modal-close" onclick="closeBOMComparisonModal()">&times;</button>
            </div>
            <div class="modal-body">
                <p style="color: #666; margin-bottom: 20px;">对比不同BOM版本或产品之间的差异</p>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">对比源 (A)</label>
                        <select class="form-select">
                            <option>BOM-2024-0012 V1.3 - 智能手环 V2.0 主板</option>
                            <option>BOM-2024-0012 V1.2 - 智能手环 V2.0 主板</option>
                            <option>BOM-2024-0015 - 智能手环 V1.8 主板</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">对比目标 (B)</label>
                        <select class="form-select">
                            <option>BOM-2024-0012 V1.2 - 智能手环 V2.0 主板</option>
                            <option>BOM-2024-0012 V1.1 - 智能手环 V2.0 主板</option>
                            <option>BOM-2024-0015 - 智能手环 V1.8 主板</option>
                        </select>
                    </div>
                </div>

                <div style="text-align: center; margin: 20px 0;">
                    <button class="btn-primary" onclick="performBOMComparison()">🔍 开始对比</button>
                </div>

                <div id="bomComparisonResult" style="display: none;">
                    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
                        <div class="cost-card" style="text-align: center; background: rgba(0, 137, 11, 0.05); border-color: #00890b;">
                            <div style="font-size: 36px; margin-bottom: 8px;">➕</div>
                            <div style="font-size: 24px; font-weight: 700; color: #00890b;">5</div>
                            <div style="font-size: 12px; color: #666;">新增零件</div>
                        </div>
                        <div class="cost-card" style="text-align: center; background: rgba(231, 76, 60, 0.05); border-color: #e74c3c;">
                            <div style="font-size: 36px; margin-bottom: 8px;">➖</div>
                            <div style="font-size: 24px; font-weight: 700; color: #e74c3c;">3</div>
                            <div style="font-size: 12px; color: #666;">删除零件</div>
                        </div>
                        <div class="cost-card" style="text-align: center; background: rgba(243, 156, 18, 0.05); border-color: #f39c12;">
                            <div style="font-size: 36px; margin-bottom: 8px;">🔄</div>
                            <div style="font-size: 24px; font-weight: 700; color: #f39c12;">7</div>
                            <div style="font-size: 12px; color: #666;">修改零件</div>
                        </div>
                        <div class="cost-card" style="text-align: center;">
                            <div style="font-size: 36px; margin-bottom: 8px;">💰</div>
                            <div style="font-size: 24px; font-weight: 700; color: #3d4647;">+¥3.20</div>
                            <div style="font-size: 12px; color: #666;">成本差异</div>
                        </div>
                    </div>

                    <h4 style="font-size: 16px; font-weight: 700; margin-bottom: 16px; color: #3d4647;">📋 详细差异</h4>

                    <table class="comparison-table">
                        <thead>
                            <tr>
                                <th>变更类型</th>
                                <th>零件型号</th>
                                <th>零件名称</th>
                                <th>V1.2 数量</th>
                                <th>V1.3 数量</th>
                                <th>成本影响</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="diff-added">
                                <td><strong>➕ 新增</strong></td>
                                <td>MT-SENSOR-2024-009</td>
                                <td>温湿度传感器 SHT31</td>
                                <td>-</td>
                                <td>1</td>
                                <td>+¥4.50</td>
                            </tr>
                            <tr class="diff-removed">
                                <td><strong>➖ 删除</strong></td>
                                <td>MT-C-2024-0103</td>
                                <td>钽电容 10uF</td>
                                <td>2</td>
                                <td>-</td>
                                <td>-¥1.80</td>
                            </tr>
                            <tr class="diff-modified">
                                <td><strong>🔄 修改</strong></td>
                                <td>MT-R-2024-0156</td>
                                <td>贴片电阻 10KΩ 0805</td>
                                <td>4</td>
                                <td>6</td>
                                <td>+¥0.04</td>
                            </tr>
                            <tr class="diff-modified">
                                <td><strong>🔄 修改</strong></td>
                                <td>MT-C-2024-0089</td>
                                <td>陶瓷电容 100nF 0603</td>
                                <td>8</td>
                                <td>10</td>
                                <td>+¥0.10</td>
                            </tr>
                            <tr class="diff-added">
                                <td><strong>➕ 新增</strong></td>
                                <td>MT-LED-2024-001</td>
                                <td>RGB LED WS2812B</td>
                                <td>-</td>
                                <td>2</td>
                                <td>+¥0.60</td>
                            </tr>
                        </tbody>
                    </table>

                    <div style="background: #f0f8ff; border-left: 4px solid #197bc0; padding: 16px; border-radius: 6px; margin-top: 20px;">
                        <div style="font-weight: 600; margin-bottom: 8px; color: #197bc0;">📝 变更摘要</div>
                        <ul style="margin-left: 20px; color: #666; font-size: 13px; line-height: 1.8;">
                            <li>V1.3版本新增了温湿度传感器和RGB LED，增强了功能</li>
                            <li>移除了钽电容，改用陶瓷电容方案，降低成本</li>
                            <li>部分零件数量调整以适应新的PCB布局</li>
                            <li>总体成本增加¥3.20/件，功能提升显著</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeBOMComparisonModal()">关闭</button>
                <button class="btn-primary">📥 导出对比报告</button>
            </div>
        </div>
    </div>

    <!-- 评论讨论Modal -->
    <div class="modal-overlay" id="commentModal">
        <div class="modal-content" style="max-width: 700px; max-height: 80vh;">
            <div class="modal-header">
                <h3 class="modal-title">💬 物料讨论</h3>
                <button class="modal-close" onclick="closeCommentModal()">&times;</button>
            </div>
            <div class="modal-body" style="padding: 0;">
                <!-- 物料信息头部 -->
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 16px 24px; display: flex; align-items: center; gap: 12px;">
                    <div style="font-size: 32px;">💬</div>
                    <div style="flex: 1;">
                        <div id="commentMaterialNumber" style="font-size: 14px; opacity: 0.9; margin-bottom: 4px;">序号: -</div>
                        <div id="commentMaterialName" style="font-size: 16px; font-weight: 700;">物料名称</div>
                    </div>
                    <div id="commentCount" style="background: rgba(255,255,255,0.2); padding: 8px 16px; border-radius: 20px; font-weight: 700;">
                        0 条评论
                    </div>
                </div>

                <!-- 评论列表 -->
                <div id="commentsList" style="max-height: 400px; overflow-y: auto; padding: 20px 24px; background: #f9f9f9;">
                    <!-- 评论将通过JavaScript动态生成 -->
                    <div style="text-align: center; padding: 40px 20px; color: #999;">
                        <div style="font-size: 48px; margin-bottom: 12px;">💭</div>
                        <div>暂无评论，快来发表第一条评论吧！</div>
                    </div>
                </div>

                <!-- 新增评论输入框 -->
                <div style="padding: 20px 24px; background: white; border-top: 2px solid #e0e0e0;">
                    <div style="display: flex; gap: 12px; align-items: flex-start;">
                        <div style="width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #00890b 0%, #00b30e 100%); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; flex-shrink: 0;">
                            你
                        </div>
                        <div style="flex: 1;">
                            <textarea id="newCommentInput"
                                      placeholder="输入您的评论或建议..."
                                      style="width: 100%; min-height: 60px; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 14px; resize: vertical; font-family: inherit;"
                                      onfocus="this.style.borderColor='#00890b'"
                                      onblur="this.style.borderColor='#e0e0e0'"></textarea>
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px;">
                                <div style="font-size: 12px; color: #999;">
                                    💡 提示：支持 <strong>@成员名</strong> 提及团队成员
                                </div>
                                <button class="btn-primary" onclick="submitComment()" style="padding: 8px 24px; font-size: 13px;">
                                    发送 📤
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 物料详情快速查看Modal -->
    <div class="modal-overlay" id="materialDetailModal">
        <div class="modal-content" style="max-width: 900px;">
            <div class="modal-header">
                <h3 class="modal-title">📦 物料详情</h3>
                <button class="modal-close" onclick="closeMaterialDetailModal()">&times;</button>
            </div>
            <div class="modal-body">
                <!-- 物料头部信息 -->
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px 24px; border-radius: 12px; margin-bottom: 20px;">
                    <div style="display: flex; align-items: center; gap: 16px;">
                        <div style="font-size: 48px;">📦</div>
                        <div style="flex: 1;">
                            <div id="matDetailCode" style="font-size: 14px; opacity: 0.9; margin-bottom: 4px;">MT-IC-2024-0001</div>
                            <div id="matDetailName" style="font-size: 20px; font-weight: 700;">TI MSP430F5529 MCU</div>
                        </div>
                        <div id="matDetailStock" style="background: rgba(255,255,255,0.2); padding: 12px 20px; border-radius: 8px; text-align: center;">
                            <div style="font-size: 24px; font-weight: 700;">1200</div>
                            <div style="font-size: 12px; opacity: 0.9;">当前库存</div>
                        </div>
                    </div>
                </div>

                <!-- 标签页导航 -->
                <div style="display: flex; gap: 8px; margin-bottom: 20px; border-bottom: 2px solid #e0e0e0;">
                    <button class="mat-detail-tab active" onclick="switchMatDetailTab('basic')" style="padding: 12px 20px; background: none; border: none; border-bottom: 3px solid transparent; font-size: 14px; font-weight: 600; color: #666; cursor: pointer; transition: all 0.3s;">
                        📋 基本信息
                    </button>
                    <button class="mat-detail-tab" onclick="switchMatDetailTab('where-used')" style="padding: 12px 20px; background: none; border: none; border-bottom: 3px solid transparent; font-size: 14px; font-weight: 600; color: #666; cursor: pointer; transition: all 0.3s;">
                        🔍 用途查询
                    </button>
                </div>

                <!-- 基本信息标签页 -->
                <div id="matDetailBasicTab" class="mat-detail-tab-content" style="display: block;">
                    <!-- 基本信息 -->
                    <div style="background: #f9f9f9; border-radius: 8px; padding: 20px; margin-bottom: 20px;">
                        <h4 style="font-size: 16px; font-weight: 700; color: #3d4647; margin-bottom: 16px;">基本信息</h4>
                        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
                            <div>
                                <div style="font-size: 13px; color: #666; margin-bottom: 4px;">制造商</div>
                                <div id="matDetailManufacturer" style="font-size: 14px; font-weight: 600; color: #3d4647;">Texas Instruments</div>
                            </div>
                            <div>
                                <div style="font-size: 13px; color: #666; margin-bottom: 4px;">分类</div>
                                <div id="matDetailCategory" style="font-size: 14px; font-weight: 600; color: #3d4647;">微控制器 (MCU)</div>
                            </div>
                            <div>
                                <div style="font-size: 13px; color: #666; margin-bottom: 4px;">封装</div>
                                <div id="matDetailPackage" style="font-size: 14px; font-weight: 600; color: #3d4647;">LQFP-80</div>
                            </div>
                            <div>
                                <div style="font-size: 13px; color: #666; margin-bottom: 4px;">单价</div>
                                <div id="matDetailPrice" style="font-size: 14px; font-weight: 600; color: #00890b;">¥28.50</div>
                            </div>
                        </div>
                    </div>

                    <!-- 规格参数 -->
                    <div style="background: white; border: 2px solid #e0e0e0; border-radius: 8px; padding: 20px;">
                        <h4 style="font-size: 16px; font-weight: 700; color: #3d4647; margin-bottom: 16px;">规格参数</h4>
                        <div id="matDetailSpecs" style="font-size: 14px; color: #666; line-height: 1.8;">
                            16-bit RISC, 25MHz, 128KB Flash, LQFP-80
                        </div>
                    </div>
                </div>

                <!-- 用途查询标签页 -->
                <div id="matDetailWhereUsedTab" class="mat-detail-tab-content" style="display: none;">
                    <!-- 统计卡片 -->
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 20px;">
                        <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 16px; border-radius: 8px;">
                            <div style="font-size: 12px; opacity: 0.9; margin-bottom: 4px;">使用的BOM数量</div>
                            <div id="whereUsedBomCount" style="font-size: 24px; font-weight: 700;">3</div>
                        </div>
                        <div style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; padding: 16px; border-radius: 8px;">
                            <div style="font-size: 12px; opacity: 0.9; margin-bottom: 4px;">总需求量</div>
                            <div id="whereUsedTotalQty" style="font-size: 24px; font-weight: 700;">15</div>
                        </div>
                        <div style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; padding: 16px; border-radius: 8px;">
                            <div style="font-size: 12px; opacity: 0.9; margin-bottom: 4px;">最后使用日期</div>
                            <div id="whereUsedLastDate" style="font-size: 16px; font-weight: 700; margin-top: 4px;">2024-11-20</div>
                        </div>
                    </div>

                    <!-- BOM列表 -->
                    <div style="background: white; border: 2px solid #e0e0e0; border-radius: 8px; overflow: hidden;">
                        <div style="background: #f9f9f9; padding: 16px; border-bottom: 2px solid #e0e0e0;">
                            <h4 style="font-size: 16px; font-weight: 700; color: #3d4647; margin: 0;">使用此物料的BOM列表</h4>
                        </div>
                        <div id="whereUsedBomList" style="max-height: 400px; overflow-y: auto;">
                            <!-- BOM列表将通过JavaScript动态生成 -->
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeMaterialDetailModal()">关闭</button>
                <button class="btn-primary" onclick="viewFullMaterialDetail()">
                    📄 查看完整详情
                </button>
            </div>
        </div>
    </div>

    <!-- 子BOM详情Modal -->
    <div class="modal-overlay" id="subBomModal">
        <div class="modal-content" style="max-width: 900px;">
            <div class="modal-header">
                <h3 class="modal-title">🔧 子BOM详情</h3>
                <button class="modal-close" onclick="closeSubBomModal()">&times;</button>
            </div>
            <div class="modal-body">
                <!-- 子BOM头部 -->
                <div style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; padding: 20px 24px; border-radius: 12px; margin-bottom: 24px;">
                    <div style="display: flex; align-items: center; gap: 16px;">
                        <div style="font-size: 48px;">🔧</div>
                        <div style="flex: 1;">
                            <div id="subBomCode" style="font-size: 14px; opacity: 0.9; margin-bottom: 4px;">SUB-BOM-001</div>
                            <div id="subBomName" style="font-size: 20px; font-weight: 700;">MCU及外围电路</div>
                        </div>
                        <div style="background: rgba(255,255,255,0.2); padding: 12px 20px; border-radius: 8px; text-align: center;">
                            <div id="subBomItemCount" style="font-size: 24px; font-weight: 700;">5</div>
                            <div style="font-size: 12px; opacity: 0.9;">物料项</div>
                        </div>
                    </div>
                </div>

                <!-- 子BOM信息 -->
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
                    <div style="background: #f9f9f9; padding: 16px; border-radius: 8px;">
                        <div style="font-size: 13px; color: #666; margin-bottom: 4px;">数量</div>
                        <div id="subBomQuantity" style="font-size: 20px; font-weight: 700; color: #3d4647;">1</div>
                    </div>
                    <div style="background: #f9f9f9; padding: 16px; border-radius: 8px;">
                        <div style="font-size: 13px; color: #666; margin-bottom: 4px;">成本</div>
                        <div id="subBomCost" style="font-size: 20px; font-weight: 700; color: #00890b;">¥42.30</div>
                    </div>
                    <div style="background: #f9f9f9; padding: 16px; border-radius: 8px;">
                        <div style="font-size: 13px; color: #666; margin-bottom: 4px;">类型</div>
                        <div style="font-size: 16px; font-weight: 700; color: #3d4647;">子BOM</div>
                    </div>
                </div>

                <!-- 子BOM物料清单 -->
                <div>
                    <h4 style="font-size: 16px; font-weight: 700; color: #3d4647; margin-bottom: 16px;">包含物料</h4>
                    <div id="subBomMaterialsList" style="background: #f9f9f9; border-radius: 8px; padding: 16px;">
                        <!-- 物料列表将通过JavaScript动态生成 -->
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeSubBomModal()">关闭</button>
                <button class="btn-primary" onclick="openSubBomInNewTab()">
                    🔗 在新标签页打开
                </button>
            </div>
        </div>
    </div>

    <script>
        // 保存BOM
        function saveBOM() {
            alert('BOM已保存！\n\n所有修改已成功保存到系统中。');
        }

        // 版本历史 - 切换到版本历史标签页
        function showVersionHistory() {
            switchTab('version-history');
        }

        // ==================== 标签页切换功能 ====================
        function switchTab(tabName) {
            // 移除所有标签页按钮的 active 类
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });

            // 隐藏所有标签页内容
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });

            // 激活选中的标签页
            const targetBtn = document.querySelector(`.tab-btn[onclick*="${tabName}"]`);
            const targetContent = document.getElementById(`tab-${tabName}`);

            if (targetBtn && targetContent) {
                targetBtn.classList.add('active');
                targetContent.classList.add('active');

                // 平滑滚动到标签页顶部
                document.querySelector('.tabs-container').scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            }
        }

        // ==================== 版本管理功能 ====================

        // 查看版本详情
        function viewVersionDetail(version) {
            alert(`查看版本详情: ${version}\n\n实际系统中，这里会显示该版本的完整BOM物料清单。`);
        }

        // 导出版本BOM
        function exportVersion(version) {
            alert(`导出版本: ${version}\n\n正在导出BOM数据...\n\n支持格式:\n- Excel (.xlsx)\n- CSV (.csv)\n- PDF (.pdf)`);
        }

        // 与当前版本对比
        function compareWith(version) {
            // 切换到版本对比模态框
            openVersionComparisonModal('v1.3', version);
        }

        // 版本对比
        function compareVersions() {
            const selectedVersion = document.getElementById('versionCompareFrom').value;
            if (!selectedVersion) {
                alert('请先选择要对比的版本！');
                return;
            }
            openVersionComparisonModal('v1.3', selectedVersion);
        }

        // 打开版本对比模态框
        function openVersionComparisonModal(versionA, versionB) {
            const modal = document.getElementById('versionComparisonModal');
            if (modal) {
                modal.classList.add('active');
                // 更新对比内容
                document.getElementById('compareVersionA').textContent = versionA;
                document.getElementById('compareVersionB').textContent = versionB;
            } else {
                // 如果modal不存在，用alert显示
                alert(`版本对比\n\n${versionA} vs ${versionB}\n\n变更内容:\n➕ 新增 2 个物料\n📝 修改 3 个物料\n➖ 删除 1 个物料\n\n成本变化: ¥82.30 → ¥85.60 (+¥3.30)`);
            }
        }

        // 回滚到指定版本
        function rollbackToVersion(version) {
            if (confirm(`确认回滚到版本 ${version}？\n\n⚠️ 警告：\n- 当前版本将保存为历史版本\n- 系统将恢复到 ${version} 的所有物料配置\n- 此操作可以撤销\n\n是否继续？`)) {
                // 模拟回滚过程
                showRollbackProgress(version);
            }
        }

        // 显示回滚进度
        function showRollbackProgress(version) {
            const steps = [
                '正在备份当前版本...',
                '正在加载历史版本数据...',
                '正在恢复物料配置...',
                '正在更新BOM表格...',
                '回滚完成！'
            ];

            let currentStep = 0;
            const progressInterval = setInterval(() => {
                if (currentStep < steps.length - 1) {
                    console.log(steps[currentStep]);
                    currentStep++;
                } else {
                    clearInterval(progressInterval);
                    alert(`✅ 回滚成功！\n\n已回滚到版本: ${version}\n当前版本已保存为: v1.3-backup-${new Date().toISOString().slice(0,10)}\n\n页面将刷新以显示新版本...`);
                    // 实际系统中这里会刷新页面或重新加载BOM数据
                    // location.reload();
                }
            }, 500);
        }

        // 创建新版本
        function openCreateVersionModal() {
            const versionName = prompt('请输入新版本号:\n\n当前版本: v1.3\n建议版本号: v1.4 或 v2.0\n\n遵循规则:\n- 主版本号.次版本号.修订号\n- 重大变更使用主版本号 (v2.0)\n- 功能新增使用次版本号 (v1.4)\n- 小改动使用修订号 (v1.3.1)', 'v1.4');

            if (versionName && versionName.trim()) {
                const description = prompt(`创建版本 ${versionName}\n\n请输入版本变更说明:`, '');
                if (description) {
                    alert(`✅ 新版本创建成功！\n\n版本号: ${versionName}\n变更说明: ${description}\n创建时间: ${new Date().toLocaleString()}\n\n新版本已保存到历史记录中。`);
                    // 实际系统中这里会调用API创建新版本
                }
            }
        }

        // ==================== 工程变更管理功能 ====================

        // 提交变更请求
        function openCreateChangeRequestModal() {
            alert('📝 提交工程变更请求 (ECR)\n\n实际系统中，这里会打开一个表单，包含以下字段:\n\n- 变更标题\n- 变更原因\n- 影响分析\n- 物料变更明细\n- 成本影响评估\n- 预期实施时间\n\n提交后将进入审批流程。');
        }

        // 树形展开/折叠
        document.querySelectorAll('.tree-toggle').forEach(toggle => {
            toggle.addEventListener('click', function(e) {
                e.stopPropagation();
                const icon = this.textContent;
                const isExpanded = icon === '▼';
                this.textContent = isExpanded ? '▶' : '▼';

                // 获取当前行
                const currentRow = this.closest('tr');
                if (!currentRow) return;

                // 确定当前行的层级
                const currentIndent = currentRow.querySelector('[class*="tree-indent-"]');
                let currentLevel = 0;
                if (currentIndent) {
                    const classList = Array.from(currentIndent.classList);
                    const indentClass = classList.find(c => c.startsWith('tree-indent-'));
                    if (indentClass) {
                        currentLevel = parseInt(indentClass.split('-')[2]) || 0;
                    }
                } else if (this.parentElement.classList.contains('material-cell')) {
                    // 这是第一级（没有indent）
                    currentLevel = 0;
                }

                // 获取所有行
                const tbody = currentRow.closest('tbody');
                const allRows = Array.from(tbody.querySelectorAll('tr'));
                const currentIndex = allRows.indexOf(currentRow);

                // 切换子行的显示/隐藏
                for (let i = currentIndex + 1; i < allRows.length; i++) {
                    const row = allRows[i];
                    const indent = row.querySelector('[class*="tree-indent-"]');

                    if (!indent) {
                        // 遇到下一个顶级项，停止
                        break;
                    }

                    // 获取该行的层级
                    const classList = Array.from(indent.classList);
                    const indentClass = classList.find(c => c.startsWith('tree-indent-'));
                    let rowLevel = 0;
                    if (indentClass) {
                        rowLevel = parseInt(indentClass.split('-')[2]) || 0;
                    }

                    // 如果是直接子行（层级正好大1）
                    if (rowLevel === currentLevel + 1) {
                        row.style.display = isExpanded ? 'none' : '';
                        // 如果折叠，也折叠该行的子行
                        if (isExpanded) {
                            const rowToggle = row.querySelector('.tree-toggle');
                            if (rowToggle) {
                                rowToggle.textContent = '▶';
                            }
                        }
                    } else if (rowLevel > currentLevel + 1) {
                        // 更深层的子行，只在展开时才处理
                        if (isExpanded) {
                            row.style.display = 'none';
                        }
                    } else {
                        // 层级相同或更小，说明已经到了兄弟节点或上层节点，停止
                        break;
                    }
                }
            });
        });

        // 添加物料 - Modal functions
        function addItem() {
            document.getElementById('addItemModal').classList.add('active');
        }

        function closeAddItemModal() {
            document.getElementById('addItemModal').classList.remove('active');
            document.getElementById('addItemForm').reset();
        }

        function submitAddItem() {
            const material = document.getElementById('itemMaterial').value;
            const designator = document.getElementById('itemDesignator').value;
            const quantity = document.getElementById('itemQuantity').value;
            const parent = document.getElementById('itemParent').value;

            if (!material || !designator || !quantity) {
                alert('请填写所有必填项！');
                return;
            }

            alert(`物料添加成功！\n\n物料: ${material}\n位号: ${designator}\n数量: ${quantity}\n添加到: ${parent}`);
            closeAddItemModal();
        }

        // 添加子BOM - Modal functions
        function addSubBOM() {
            // Auto-generate sub-BOM number
            const subBOMNumber = 'SUB-BOM-' + String(Math.floor(Math.random() * 900) + 100).padStart(3, '0');
            document.getElementById('subBOMNumber').value = subBOMNumber;
            document.getElementById('addSubBOMModal').classList.add('active');
        }

        function closeAddSubBOMModal() {
            document.getElementById('addSubBOMModal').classList.remove('active');
            document.getElementById('addSubBOMForm').reset();
        }

        function submitAddSubBOM() {
            const name = document.getElementById('subBOMName').value;
            const number = document.getElementById('subBOMNumber').value;
            const quantity = document.getElementById('subBOMQuantity').value;
            const parent = document.getElementById('subBOMParent').value;

            if (!name || !quantity) {
                alert('请填写所有必填项！');
                return;
            }

            alert(`子BOM创建成功！\n\n编号: ${number}\n名称: ${name}\n数量: ${quantity}\n添加到: ${parent}`);
            closeAddSubBOMModal();
        }

        // 导入BOM
        function importBOM() {
            alert('导入BOM\n支持格式:\n- Excel (.xlsx)\n- CSV (.csv)\n- Altium Designer');
        }

        // 导出BOM
        function exportBOM() {
            alert('导出BOM\n支持格式:\n- Excel (.xlsx)\n- PDF (.pdf)\n- CSV (.csv)');
        }

        // 切换视图
        function switchView(view) {
            document.querySelectorAll('.view-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            const table = document.querySelector('.bom-table-card table tbody');
            const rows = table.querySelectorAll('tr');

            if (view === 'tree') {
                // 树形视图：显示所有indents，显示toggles
                rows.forEach(row => {
                    const indents = row.querySelectorAll('[class*="tree-indent-"]');
                    const toggle = row.querySelector('.tree-toggle');
                    indents.forEach(indent => indent.style.display = 'inline-block');
                    if (toggle) toggle.style.display = 'inline-flex';
                    row.style.display = '';
                });
            } else {
                // 平铺视图：隐藏所有indents，隐藏toggles，显示所有行
                rows.forEach(row => {
                    const indents = row.querySelectorAll('[class*="tree-indent-"]');
                    const toggle = row.querySelector('.tree-toggle');
                    indents.forEach(indent => indent.style.display = 'none');
                    if (toggle) toggle.style.display = 'none';
                    row.style.display = '';
                });
            }
        }

        // 全部展开
        function expandAll() {
            const table = document.querySelector('.bom-table-card table tbody');
            const rows = table.querySelectorAll('tr');

            // 显示所有行
            rows.forEach(row => {
                row.style.display = '';
            });

            // 更新所有toggle图标为展开状态
            document.querySelectorAll('.tree-toggle').forEach(toggle => {
                toggle.textContent = '▼';
                // 记录展开状态
                const row = toggle.closest('tr');
                if (row) row.dataset.expanded = 'true';
            });
        }

        // 全部折叠
        function collapseAll() {
            const table = document.querySelector('.bom-table-card table tbody');
            const rows = Array.from(table.querySelectorAll('tr'));

            // 首先，更新所有toggle图标为折叠状态
            document.querySelectorAll('.tree-toggle').forEach(toggle => {
                toggle.textContent = '▶';
                const row = toggle.closest('tr');
                if (row) row.dataset.expanded = 'false';
            });

            // 隐藏所有子行（有indent的行）
            rows.forEach(row => {
                const hasIndent = row.querySelector('[class*="tree-indent-"]');
                if (hasIndent) {
                    row.style.display = 'none';
                }
            });
        }

        // 可编辑单元格双击编辑
        document.querySelectorAll('.editable-cell').forEach(cell => {
            cell.addEventListener('dblclick', function() {
                const value = this.textContent.trim();
                const input = document.createElement('input');
                input.value = value;
                input.style.width = '100%';
                input.style.border = '2px solid #00890b';
                input.style.borderRadius = '4px';
                input.style.padding = '4px';
                this.textContent = '';
                this.appendChild(input);
                input.focus();

                input.addEventListener('blur', function() {
                    const newValue = this.value;
                    cell.textContent = newValue;
                    console.log('更新值:', value, '→', newValue);
                });
            });
        });

        // Click outside to close modals
        document.getElementById('addItemModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeAddItemModal();
            }
        });

        document.getElementById('addSubBOMModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeAddSubBOMModal();
            }
        });
    
        // AI助手功能
        function openCodeAssistant() {
            document.getElementById('codeAssistantModal').classList.add('active');
        }

        function closeCodeAssistant() {
            document.getElementById('codeAssistantModal').classList.remove('active');
        }

        function openPCBLayout() {
            document.getElementById('pcbLayoutModal').classList.add('active');
        }

        function closePCBLayout() {
            document.getElementById('pcbLayoutModal').classList.remove('active');
        }

        // ========== PartsBox功能 ==========

        // 1. 共享零件分析
        function openSharedPartsAnalysis() {
            document.getElementById('sharedPartsModal').classList.add('active');
        }

        function closeSharedPartsModal() {
            document.getElementById('sharedPartsModal').classList.remove('active');
            document.getElementById('sharedPartsResult').style.display = 'none';
        }

        function analyzeSharedParts() {
            // 模拟分析过程
            const selectedBOMs = [];
            if (document.getElementById('bom1').checked) selectedBOMs.push('BOM-2024-0012');
            if (document.getElementById('bom2').checked) selectedBOMs.push('BOM-2024-0015');
            if (document.getElementById('bom3').checked) selectedBOMs.push('BOM-2024-0018');
            if (document.getElementById('bom4').checked) selectedBOMs.push('BOM-2024-0021');

            if (selectedBOMs.length < 2) {
                alert('请至少选择2个BOM进行分析！');
                return;
            }

            // 显示分析结果
            document.getElementById('sharedPartsResult').style.display = 'block';

            // 平滑滚动到结果区域
            setTimeout(() => {
                document.getElementById('sharedPartsResult').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }, 100);
        }

        // 2. 实时定价
        function updateRealTimePrice(bomId) {
            document.getElementById('realTimePriceModal').classList.add('active');
        }

        function closeRealTimePriceModal() {
            document.getElementById('realTimePriceModal').classList.remove('active');
        }

