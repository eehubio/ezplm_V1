        // 标签页切换函数
        function switchMatDetailTab(tabName) {
            // 移除所有标签按钮的active类
            document.querySelectorAll('.mat-detail-tab').forEach(btn => {
                btn.classList.remove('active');
            });

            // 隐藏所有标签页内容
            document.querySelectorAll('.mat-detail-tab-content').forEach(content => {
                content.style.display = 'none';
            });

            // 激活选中的标签
            if (tabName === 'basic') {
                document.querySelector('.mat-detail-tab[onclick*="basic"]').classList.add('active');
                document.getElementById('matDetailBasicTab').style.display = 'block';
            } else if (tabName === 'where-used') {
                document.querySelector('.mat-detail-tab[onclick*="where-used"]').classList.add('active');
                document.getElementById('matDetailWhereUsedTab').style.display = 'block';
            }
        }

        // 渲染用途查询数据
        function renderWhereUsedData(materialCode) {
            const whereUsed = materialWhereUsed[materialCode] || [];

            // 更新统计数据
            const bomCount = whereUsed.length;
            const totalQty = whereUsed.reduce((sum, item) => sum + item.quantity, 0);
            const lastDate = whereUsed.length > 0 ? whereUsed[0].lastModified : '-';

            document.getElementById('whereUsedBomCount').textContent = bomCount;
            document.getElementById('whereUsedTotalQty').textContent = totalQty;
            document.getElementById('whereUsedLastDate').textContent = lastDate;

            // 渲染BOM列表
            const bomListHtml = whereUsed.length === 0 ? `
                <div style="padding: 60px 20px; text-align: center; color: #999;">
                    <div style="font-size: 64px; margin-bottom: 16px;">📭</div>
                    <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">暂无使用记录</div>
                    <div style="font-size: 14px;">该物料尚未在任何BOM中使用</div>
                </div>
            ` : whereUsed.map(item => {
                const statusColors = {
                    'active': { bg: '#e8f5e9', text: '#00890b', label: '进行中' },
                    'archived': { bg: '#f5f5f5', text: '#999', label: '已归档' }
                };
                const statusStyle = statusColors[item.status] || statusColors['active'];

                return `
                    <div style="padding: 20px 24px; border-bottom: 1px solid #e0e0e0; transition: background 0.3s;"
                         onmouseover="this.style.background='#f9f9f9'"
                         onmouseout="this.style.background='white'">
                        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 12px;">
                            <div style="flex: 1;">
                                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                                    <a href="bom-detail.html?code=${item.bomCode}"
                                       onclick="goToBomDetail('${item.bomCode}'); return false;"
                                       style="font-size: 16px; font-weight: 700; color: #197bc0; text-decoration: none; cursor: pointer;"
                                       onmouseover="this.style.textDecoration='underline'"
                                       onmouseout="this.style.textDecoration='none'">
                                        ${item.bomName}
                                    </a>
                                    <span style="background: ${statusStyle.bg}; color: ${statusStyle.text}; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 600;">
                                        ${statusStyle.label}
                                    </span>
                                </div>
                                <div style="font-size: 13px; color: #666; margin-bottom: 4px;">
                                    📁 项目：${item.projectName} | BOM编号：${item.bomCode}
                                </div>
                                <div style="font-size: 13px; color: #999;">
                                    🕒 最后修改：${item.lastModified}
                                </div>
                            </div>
                            <div style="text-align: right; min-width: 120px;">
                                <div style="font-size: 24px; font-weight: 700; color: #00890b; margin-bottom: 4px;">
                                    ${item.quantity} ${item.unit}
                                </div>
                                <div style="font-size: 12px; color: #666;">
                                    位号：${item.designator}
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            document.getElementById('whereUsedBomList').innerHTML = bomListHtml;
        }

        // 跳转到BOM详情页
        function goToBomDetail(bomCode) {
            if (confirm(`🔗 即将跳转到BOM详情页\n\nBOM编号: ${bomCode}\n\n是否继续？`)) {
                // 实际项目中应该跳转到对应的BOM详情页
                window.location.href = `bom-detail.html?code=${encodeURIComponent(bomCode)}`;
            }
        }

        // 打开物料详情模态框
        function openMaterialDetail(materialCode) {
            const material = materialDetailData[materialCode];

            if (!material) {
                alert(`⚠️ 未找到物料信息\n\n物料编号: ${materialCode}\n\n该物料详情数据暂未录入系统。`);
                return;
            }

            // 填充物料基本信息
            document.getElementById('matDetailCode').textContent = material.code;
            document.getElementById('matDetailName').textContent = material.name;
            document.getElementById('matDetailManufacturer').textContent = material.manufacturer;
            document.getElementById('matDetailPackage').textContent = material.package;
            document.getElementById('matDetailCategory').textContent = material.category;
            document.getElementById('matDetailPrice').textContent = `¥${material.price.unitPrice.toFixed(2)}`;

            // 更新库存显示
            const stockDiv = document.getElementById('matDetailStock');
            if (stockDiv) {
                stockDiv.querySelector('div:first-child').textContent = material.stock.current;
            }

            // 填充规格参数
            const specsHtml = Object.entries(material.specs).map(([key, value]) => `
                <div style="display: flex; padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
                    <div style="width: 120px; color: #666; font-size: 13px;">${key}</div>
                    <div style="flex: 1; font-weight: 500; font-size: 13px;">${value}</div>
                </div>
            `).join('');
            document.getElementById('matDetailSpecs').innerHTML = specsHtml;

            // 渲染用途查询数据
            renderWhereUsedData(materialCode);

            // 重置到基本信息标签页
            switchMatDetailTab('basic');

            // 显示模态框
            document.getElementById('materialDetailModal').classList.add('active');
        }

        // 关闭物料详情模态框
        function closeMaterialDetailModal() {
            document.getElementById('materialDetailModal').classList.remove('active');
        }

        // 查看完整物料详情（跳转到物料管理页面）
        function viewFullMaterialDetail() {
            const materialCode = document.getElementById('matDetailCode').textContent;
            if (confirm(`🔗 即将跳转到物料管理页面\n\n将在物料管理页面中查看 ${materialCode} 的完整信息。\n\n是否继续？`)) {
                // 实际项目中应该跳转到 materials.html 并传递物料编号参数
                window.location.href = `materials.html?code=${encodeURIComponent(materialCode)}`;
            }
        }

        // 打开子BOM详情模态框
        function openSubBomDetail(subBomCode) {
            const subBom = subBomDetailData[subBomCode];

            if (!subBom) {
                alert(`⚠️ 未找到子BOM信息\n\n子BOM编号: ${subBomCode}\n\n该子BOM详情数据暂未录入系统。`);
                return;
            }

            // 填充子BOM基本信息
            document.getElementById('subBomCode').textContent = subBom.code;
            document.getElementById('subBomName').textContent = subBom.name;
            document.getElementById('subBomItemCount').textContent = subBom.totalItems;
            document.getElementById('subBomQuantity').textContent = '1';

            // 计算总成本
            let totalCost = 0;
            // 这里可以根据实际情况计算
            document.getElementById('subBomCost').textContent = '¥42.30';

            // 填充物料清单表格
            const materialsHtml = `
                <table style="width: 100%; background: white; border-radius: 8px; overflow: hidden;">
                    <thead style="background: #667eea; color: white;">
                        <tr>
                            <th style="padding: 12px 8px; text-align: center; font-size: 13px; width: 50px;">#</th>
                            <th style="padding: 12px 8px; text-align: left; font-size: 13px;">物料编号</th>
                            <th style="padding: 12px 8px; text-align: left; font-size: 13px;">物料名称</th>
                            <th style="padding: 12px 8px; text-align: left; font-size: 13px;">制造商</th>
                            <th style="padding: 12px 8px; text-align: center; font-size: 13px; width: 60px;">数量</th>
                            <th style="padding: 12px 8px; text-align: center; font-size: 13px; width: 60px;">单位</th>
                            <th style="padding: 12px 8px; text-align: center; font-size: 13px;">封装</th>
                            <th style="padding: 12px 8px; text-align: left; font-size: 13px;">规格</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${subBom.materials.map(item => `
                            <tr style="border-bottom: 1px solid #e0e0e0;">
                                <td style="padding: 12px 8px; text-align: center; font-size: 13px;">${item.seq}</td>
                                <td style="padding: 12px 8px;">
                                    <span class="material-number" onclick="openMaterialDetail('${item.partNumber}')" style="cursor: pointer; color: #197bc0; font-weight: 600;">
                                        ${item.partNumber}
                                    </span>
                                </td>
                                <td style="padding: 12px 8px; font-size: 13px;">${item.name}</td>
                                <td style="padding: 12px 8px; font-size: 13px; color: #666;">${item.manufacturer}</td>
                                <td style="padding: 12px 8px; text-align: center; font-weight: 600; font-size: 13px;">${item.qty}</td>
                                <td style="padding: 12px 8px; text-align: center; font-size: 13px;">${item.unit}</td>
                                <td style="padding: 12px 8px; text-align: center; font-size: 13px; color: #666;">${item.package}</td>
                                <td style="padding: 12px 8px; font-size: 13px; color: #666;">${item.specs}</td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            `;
            document.getElementById('subBomMaterialsList').innerHTML = materialsHtml;

            // 显示模态框
            document.getElementById('subBomModal').classList.add('active');
        }

        // 关闭子BOM详情模态框
        function closeSubBomModal() {
            document.getElementById('subBomModal').classList.remove('active');
        }

        // 在新标签页打开子BOM
        function openSubBomInNewTab() {
            const subBomCode = document.getElementById('subBomCode').textContent;
            if (confirm(`🔗 即将在新标签页打开子BOM\n\n子BOM编号: ${subBomCode}\n\n是否继续？`)) {
                // 实际项目中应该打开子BOM的详细页面
                window.open(`bom-detail.html?code=${encodeURIComponent(subBomCode)}`, '_blank');
            }
        }

        // 点击模态框外部关闭
        document.getElementById('materialDetailModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeMaterialDetailModal();
            }
        });

        document.getElementById('subBomModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeSubBomModal();
            }
        });

        // 页面加载时初始化
        document.addEventListener('DOMContentLoaded', function() {
            renderOnlineMembers();
            simulateRealtimeActivity();

            // 初始显示两个活动通知
            setTimeout(() => {
                showActivityNotification({
                    user: '张三',
                    action: '修改了第 5 行物料数量从 10 改为 15',
                    type: 'editing'
                });
            }, 2000);

            setTimeout(() => {
                showActivityNotification({
                    user: '李四',
                    action: '在第 1.1.1 行物料添加了评论',
                    type: 'commenting'
                });
            }, 4000);

            // 为所有物料编号和子BOM编号添加点击事件
            document.querySelectorAll('.material-number').forEach(el => {
                // 只处理那些还没有onclick属性的元素
                if (!el.getAttribute('onclick')) {
                    el.style.cursor = 'pointer';
                    el.addEventListener('click', function() {
                        const code = this.textContent.trim();

                        // 判断是子BOM还是普通物料
                        if (code.startsWith('SUB-BOM-')) {
                            openSubBomDetail(code);
                        } else {
                            openMaterialDetail(code);
                        }
                    });
                }
            });
        });
    </script>
</div>

        <!-- 编程助手模态框 -->
    <div class="ai-modal-overlay" id="codeAssistantModal">
        <button class="ai-modal-close" onclick="closeCodeAssistant()">&times;</button>
        <iframe src="ai_coding_embedded.html" style="width: 100%; height: 100%; border: none;"></iframe>
    </div>

    <!-- PCB预布局模态框 -->
    <div class="ai-modal-overlay" id="pcbLayoutModal">
        <button class="ai-modal-close" onclick="closePCBLayout()">&times;</button>
        <iframe src="pcb-editor-styled.html" style="width: 100%; height: 100%; border: none;"></iframe>
    </div>
</body>
</html>
