                            <option value="">-- 请选择物料 --</option>
                            <option value="MT-IC-2024-0001">MT-IC-2024-0001 - TI MSP430F5529 MCU</option>
                            <option value="MT-IC-2024-0089">MT-IC-2024-0089 - TI BQ24075 充电管理IC</option>
