        </div>

    <!-- 主内容区 -->
    <div class="main-content">
        <!-- BOM项目信息 -->
        <div style="background: white; border-radius: 8px; padding: 24px 32px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center;">
            <div style="flex: 1;">
                <h1 style="font-size: 24px; font-weight: 700; color: #3d4647; margin-bottom: 8px;">智能手环 V2.0 主板 BOM</h1>
                <div style="font-size: 14px; color: #666; display: flex; gap: 16px; flex-wrap: wrap;">
                    <span>📋 <strong>BOM编号:</strong> BOM-2024-0012</span>
                    <span>🔖 <strong>BOM版本:</strong> v1.3</span>
                    <!-- 新增：关联信息 -->
                    <span>🔗 <strong>关联项目:</strong> <a href="project-detail.html?id=1" style="color: #00890b; text-decoration: none; font-weight: 600;">智能手环开发</a></span>
                    <span>📦 <strong>关联模块:</strong> <a href="project-detail.html?id=1&moduleId=1" style="color: #00890b; text-decoration: none; font-weight: 600;">主控板 V2.1</a></span>
                    <span>👤 <strong>创建人:</strong> 张三</span>
                    <span>📅 <strong>最后更新:</strong> 2024-10-15</span>
                    <span style="padding: 4px 12px; background: rgba(0, 137, 11, 0.1); color: #00890b; border-radius: 4px; font-weight: 600;">✅ 已发布</span>
                </div>
            </div>

            <!-- 在线成员显示 -->
            <div style="display: flex; align-items: center; gap: 16px; margin: 0 24px;">
                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
                    <div style="font-size: 12px; font-weight: 600; color: #999;">协作中</div>
                    <div id="onlineMembersContainer" style="display: flex; align-items: center; gap: -8px;">
                        <!-- 在线成员头像将通过JavaScript动态生成 -->
                    </div>
                </div>
            </div>

            <div style="display: flex; gap: 12px;">
                <button class="btn-secondary" onclick="showVersionHistory()">📜 版本历史</button>
                <button class="btn-primary" onclick="saveBOM()">💾 保存</button>
            </div>
        </div>

        <!-- 实时活动通知区域 -->
        <div id="activityNotifications" style="position: fixed; top: 100px; right: 24px; width: 320px; z-index: 999; display: flex; flex-direction: column; gap: 8px;">
            <!-- 活动通知将通过JavaScript动态添加 -->
        </div>

        <!-- BOM头部信息 -->
        <div class="bom-header-card">
            <div class="header-grid">
                <div class="header-item">
                    <div class="header-icon">📦</div>
                    <div class="header-info">
                        <h4>总物料数</h4>
                        <div class="value">42</div>
                    </div>
                </div>
                <div class="header-item">
                    <div class="header-icon">🔧</div>
                    <div class="header-info">
                        <h4>子BOM数</h4>
                        <div class="value">3</div>
                    </div>
                </div>
                <div class="header-item">
                    <div class="header-icon">💰</div>
                    <div class="header-info">
                        <h4>单件成本</h4>
                        <div class="value">¥85.60</div>
                    </div>
                </div>
                <div class="header-item">
                    <div class="header-icon">📊</div>
                    <div class="header-info">
                        <h4>库存状态</h4>
                        <div class="value" style="color: #f39c12;">3个预警</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 工具栏 -->
        <div class="toolbar">
            <div class="toolbar-left">
                <button class="btn-icon" onclick="addItem()">➕ 添加物料</button>
                <button class="btn-icon" onclick="addSubBOM()">📂 添加子BOM</button>
                <button class="btn-icon" onclick="importBOM()">📥 导入</button>
                <button class="btn-icon" onclick="exportBOM()">📤 导出</button>
            </div>
            <div class="toolbar-right">
                <div class="view-toggle">
                    <button class="view-btn active" onclick="switchView('tree')">🌳 树形</button>
                    <button class="view-btn" onclick="switchView('flat')">📋 平铺</button>
                </div>
                <button class="btn-icon" onclick="expandAll()">⬇️ 全部展开</button>
                <button class="btn-icon" onclick="collapseAll()">⬆️ 全部折叠</button>
            </div>
        </div>

        <!-- PartsBox功能工具栏 -->
        <div class="toolbar" style="margin-top: 12px;">
            <div class="toolbar-left">
                <button class="btn-icon" onclick="openSharedPartsAnalysis()" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none;">📊 共享零件分析</button>
                <button class="btn-icon" onclick="updateRealTimePrice('BOM-2024-0012')" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; border: none;">💰 实时定价</button>
                <button class="btn-icon" onclick="checkInventoryAvailability('BOM-2024-0012')" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; border: none;">📦 库存检查</button>
                <button class="btn-icon" onclick="openBOMComparison()" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); color: white; border: none;">🔀 BOM对比</button>
            </div>
        </div>

        <!-- 标签页导航 -->
        <div class="tabs-container" style="margin-top: 24px;">
            <div class="tabs-nav">
                <button class="tab-btn active" onclick="switchTab('materials')">
                    <span>📦</span>
                    <span>物料清单</span>
                </button>
                <button class="tab-btn" onclick="switchTab('version-history')">
                    <span>📜</span>
                    <span>版本历史</span>
                </button>
                <button class="tab-btn" onclick="switchTab('changes')">
                    <span>🔄</span>
                    <span>变更记录</span>
                </button>
                <button class="tab-btn" onclick="switchTab('info')">
                    <span>ℹ️</span>
                    <span>基本信息</span>
                </button>
            </div>
        </div>

        <!-- 标签页内容：物料清单 -->
        <div id="tab-materials" class="tab-content active">
            <!-- BOM表格 -->
            <div class="bom-table-card" style="border-radius: 0 0 8px 8px; margin-bottom: 0;">
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th style="width: 40px;">#</th>
                            <th style="width: 350px;">物料信息</th>
                            <th style="width: 100px;">位号</th>
                            <th style="width: 80px;">数量</th>
                            <th style="width: 100px;">单价</th>
                            <th style="width: 100px;">小计</th>
                            <th style="width: 120px;">库存状态</th>
                            <th style="width: 100px;">供应商</th>
                            <th style="width: 150px;">备注</th>
                            <th style="width: 80px;">💬 评论</th>
                            <th style="width: 100px;">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- 第一级 - 主BOM -->
                        <tr style="background: #f9f9f9; font-weight: 600;">
                            <td>1</td>
                            <td>
                                <div class="material-cell">
                                    <span class="tree-toggle">▼</span>
                                    <div class="material-icon">📋</div>
                                    <div class="material-info">
                                        <div class="material-number">BOM-2024-0012</div>
                                        <div class="material-name">智能手环 V2.0 主板</div>
                                    </div>
                                </div>
                            </td>
                            <td>-</td>
                            <td>1</td>
                            <td>-</td>
                            <td><strong>¥85.60</strong></td>
                            <td>-</td>
                            <td>-</td>
                            <td>主BOM</td>
                            <td style="text-align: center;">
                                <button class="comment-btn" onclick="openCommentModal('1', '智能手环 V2.0 主板')" title="查看/添加评论">
                                    💬 <span class="comment-count">0</span>
                                </button>
                            </td>
                            <td>-</td>
                        </tr>

                        <!-- 第二级 - MCU及外围 -->
                        <tr>
                            <td>1.1</td>
                            <td>
                                <div class="material-cell">
                                    <span class="tree-indent-1"></span>
                                    <span class="tree-toggle">▼</span>
                                    <div class="material-icon">🔧</div>
                                    <div class="material-info">
                                        <div class="material-number">SUB-BOM-001</div>
                                        <div class="material-name">MCU及外围电路</div>
                                    </div>
                                </div>
                            </td>
