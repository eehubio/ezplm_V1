                            <tr>
                                <td><strong>MT-IC-2024-0102</strong></td>
                                <td>TI TPS73633 LDO 3.3V</td>
                                <td><span class="status-badge status-warning">2个BOM</span></td>
                                <td>12</td>
                                <td><span class="price-trend-down">¥5.80</span></td>
